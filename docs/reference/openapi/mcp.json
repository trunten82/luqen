              "schema": {
                "type": "object",
                "properties": {
                  "status": {
                    "description": "Filter by scan status",
                    "type": "string",
                    "enum": [
                      "queued",
                      "running",
                      "completed",
                      "failed"
                    ]
                  },
                  "limit": {
                    "description": "Page size (default 50)",
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 200
                  },
                  "offset": {
                    "description": "Pagination offset",
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  }
                },
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "MCP tool result envelope (JSON-RPC response)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true,
                  "description": "MCP tool result envelope (JSON-RPC response)"
                }
