{
  "name": "storage-postgres",
  "displayName": "PostgreSQL Storage",
  "type": "storage",
  "version": "1.0.0",
  "description": "PostgreSQL database backend for the Luqen dashboard, replacing the default SQLite storage",
  "configSchema": [
    { "key": "host", "label": "Host", "type": "string", "required": true, "default": "localhost" },
    { "key": "port", "label": "Port", "type": "number", "required": true, "default": 5432 },
    { "key": "database", "label": "Database", "type": "string", "required": true, "default": "luqen" },
    { "key": "username", "label": "Username", "type": "string", "required": true },
    { "key": "password", "label": "Password", "type": "secret", "required": true },
    { "key": "ssl", "label": "Use SSL", "type": "boolean", "default": false },
    { "key": "poolSize", "label": "Connection Pool Size", "type": "number", "default": 10 }
  ]
}
