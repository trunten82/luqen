{
  "name": "notify-email",
  "displayName": "Email Notifications & Reports",
  "type": "notification",
  "version": "1.0.0",
  "description": "Send scan notifications and scheduled reports via email (SMTP)",
  "configSchema": [
    { "key": "host", "label": "SMTP Host", "type": "string", "required": true },
    { "key": "port", "label": "SMTP Port", "type": "number", "default": 587 },
    { "key": "secure", "label": "Use TLS", "type": "boolean", "default": true },
    { "key": "username", "label": "SMTP Username", "type": "string", "required": true },
    { "key": "password", "label": "SMTP Password", "type": "secret", "required": true },
    { "key": "fromAddress", "label": "From Email", "type": "string", "required": true },
    { "key": "fromName", "label": "From Name", "type": "string", "default": "Pally Dashboard" },
    { "key": "events", "label": "Events to notify", "type": "string", "default": "scan.complete,scan.failed" }
  ],
  "adminPages": [
    {
      "path": "/admin/email-reports",
      "title": "Email Reports",
      "icon": "envelope",
      "permission": "admin.system"
    }
  ]
}
