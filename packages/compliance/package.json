{
  "name": "@pally-agent/compliance",
  "version": "0.1.0",
  "description": "Accessibility compliance rule engine service",
  "type": "module",
  "main": "dist/cli.js",
  "bin": { "pally-compliance": "dist/cli.js" },
  "scripts": {
    "build": "tsc && cp src/seed/baseline.json dist/seed/baseline.json",
