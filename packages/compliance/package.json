    "@modelcontextprotocol/sdk": "^1.27.1",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^11.0.0",
    "commander": "^14.0.3",
    "fastify": "^5.0.0",
    "jose": "^6.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
