{
  "name": "@luqen/dashboard",
  "version": "2.2.3",
  "description": "Web dashboard for luqen accessibility scanner",
  "type": "module",
  "main": "dist/cli.js",
  "types": "dist/cli.d.ts",
  "bin": {
    "luqen-dashboard": "dist/cli.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsc && cp -r src/views dist/views && cp -r src/static dist/static && cp -r src/i18n/locales dist/i18n/locales && cp plugin-registry.json dist/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "start": "node dist/cli.js serve"
  },
  "license": "MIT",
  "author": "trunten82",
  "repository": {
    "type": "git",
    "url": "https://github.com/trunten82/luqen.git",
    "directory": "packages/dashboard"
  },
  "bugs": {
    "url": "https://github.com/trunten82/luqen/issues"
  },
  "homepage": "https://github.com/trunten82/luqen#readme",
  "keywords": [
    "accessibility",
    "a11y",
    "wcag",
    "pa11y",
    "compliance",
    "testing",
    "dashboard",
    "htmx",
    "report-viewer"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@fastify/csrf-protection": "^7.1.0",
    "@fastify/formbody": "^8.0.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/secure-session": "^8.0.0",
    "@fastify/static": "^8.0.0",
    "@fastify/view": "^10.0.0",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^11.0.0",
    "commander": "^14.0.3",
    "exceljs": "^4.4.0",
    "fastify": "^5.0.0",
    "graphql": "^16.9.0",
    "handlebars": "^4.7.8",
    "ioredis": "^5.10.1",
    "jose": "^6.0.0",
    "mercurius": "^16.8.0",
    "nodemailer": "^8.0.3",
    "pdfkit": "^0.18.0",
    "tar": "^7.5.12",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pdfkit": "^0.17.5",
    "@vitest/coverage-v8": "^4.1.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
