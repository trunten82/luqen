{{! Connected Repositories — manage source code connections for fix proposals }}

<section aria-labelledby="repos-heading">
  <h2 id="repos-heading" class="section-title">{{t "repos.title"}}</h2>

  <p style="margin-bottom:1.5rem;color:var(--text-muted);max-width:60ch;">
    {{t "repos.intro"}}
  </p>

  {{! ── Create New Connection ──────────────────────────────────────── }}
  <div class="card mb-lg">
    <h3 style="margin:0 0 1rem;">{{t "repos.connectTitle"}}</h3>
    <form method="POST" action="/admin/repos"
          style="display:grid;gap:0.75rem;max-width:600px;">
      <input type="hidden" name="_csrf" value="{{csrfToken}}">

      <div class="form-group">
        <label for="siteUrlPattern">{{t "repos.siteUrlPattern"}}</label>
        <input type="text" id="siteUrlPattern" name="siteUrlPattern" class="input" required
               placeholder="https://example.com%" aria-required="true"
               title="URL pattern using SQL LIKE syntax. Use % as wildcard.">
        <small style="color:var(--text-muted);">{{{t "repos.siteUrlPatternHint"}}}</small>
      </div>

      <div class="form-group">
        <label for="repoUrl">{{t "repos.repoUrl"}}</label>
        <input type="text" id="repoUrl" name="repoUrl" class="input" required
               placeholder="https://github.com/org/repo.git" aria-required="true">
      </div>

      <div class="form-group">
        <label for="repoPath">{{t "repos.localPath"}} <span style="color:var(--text-muted);">({{t "common.optional"}})</span></label>
        <input type="text" id="repoPath" name="repoPath" class="input"
               placeholder="/home/user/projects/my-site">
        <small style="color:var(--text-muted);">{{t "repos.localPathHint"}}</small>
      </div>

      <div class="form-group">
        <label for="branch">{{t "repos.branch"}}</label>
        <input type="text" id="branch" name="branch" class="input"
               placeholder="main" value="main">
      </div>

      <div>
        <button type="submit" class="btn btn--primary">{{t "repos.connectButton"}}</button>
      </div>
    </form>
  </div>

  {{! ── Connected Repos Table ──────────────────────────────────────── }}
  {{#if repos.length}}
  <div class="card">
    <h3 style="margin:0 0 1rem;">{{t "repos.activeConnections"}}</h3>
    <div class="table-wrap">
      <table class="data-table" aria-label="Connected repositories">
        <thead>
          <tr>
            <th scope="col">{{t "repos.siteUrlPattern"}}</th>
            <th scope="col">{{t "repos.repository"}}</th>
            <th scope="col">{{t "repos.branch"}}</th>
            <th scope="col">{{t "repos.localPath"}}</th>
            <th scope="col">{{t "repos.created"}}</th>
            <th scope="col">{{t "common.actions"}}</th>
          </tr>
        </thead>
        <tbody>
          {{#each repos}}
          <tr id="repo-row-{{this.id}}">
            <td><code>{{this.siteUrlPattern}}</code></td>
            <td>
              <a href="{{this.repoUrl}}" target="_blank" rel="noopener noreferrer" style="word-break:break-all;">
                {{this.repoUrl}}
              </a>
            </td>
            <td><code>{{this.branch}}</code></td>
            <td>
              {{#if this.repoPath}}
              <code>{{this.repoPath}}</code>
              {{else}}
              <span style="color:var(--text-muted);">{{t "repos.notSet"}}</span>
              {{/if}}
            </td>
            <td>{{this.createdAt}}</td>
            <td>
              <form method="POST" action="/admin/repos/{{this.id}}?_method=DELETE" style="display:inline;">
                <input type="hidden" name="_csrf" value="{{../csrfToken}}">
                <button type="submit"
                        class="btn btn--ghost btn--sm btn--danger"
                        hx-delete="/admin/repos/{{this.id}}"
                        hx-target="#repo-row-{{this.id}}"
                        hx-swap="outerHTML"
                        hx-confirm="{{t "repos.disconnectConfirm"}}"
                        aria-label="Disconnect repository {{this.repoUrl}}">
                  {{t "repos.disconnect"}}
                </button>
              </form>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>
  {{else}}
  <div class="card" style="text-align:center;padding:2rem;">
    <p style="color:var(--text-muted);">{{t "repos.noRepos"}}</p>
  </div>
  {{/if}}

  {{! ── Integration Notes ──────────────────────────────────────────── }}
  <div class="card mt-lg" style="background:var(--surface-alt, var(--bg-secondary));">
    <h3 style="margin:0 0 0.75rem;">{{t "repos.integrationOptionsTitle"}}</h3>
    <p style="color:var(--text-muted);margin-bottom:0.5rem;">
      {{t "repos.integrationOptionsDesc"}}
    </p>
    <ul style="color:var(--text-muted);margin:0;padding-left:1.5rem;">
      <li>{{{t "repos.integrationMcp"}}}</li>
      <li>{{{t "repos.integrationRest"}}}</li>
      <li>{{t "repos.integrationA2a"}}</li>
    </ul>
  </div>
</section>
