{{! Connected Repositories — manage source code connections for fix proposals }}

<section aria-labelledby="repos-heading">
  <h2 id="repos-heading" class="section-title">{{t "repos.title"}}</h2>

  <p class="text--muted mb-lg page-intro">
    {{t "repos.intro"}}
  </p>

  {{! ── Create New Connection ──────────────────────────────────────── }}
  <div class="card mb-lg">
    <h3 class="card__title">{{t "repos.connectTitle"}}</h3>
    <form method="POST" action="/admin/repos"
          class="form-grid form-grid--narrow">
      <input type="hidden" name="_csrf" value="{{csrfToken}}">

      {{#if isAdmin}}
      <div class="form-group">
        <label for="orgId">Organization</label>
        <select id="orgId" name="orgId" class="select">
          <option value="system">System (global)</option>
          {{#each orgs}}
          <option value="{{this.id}}">{{this.name}}</option>
          {{/each}}
        </select>
        <p class="form-hint">Assign this repo connection to an organization.</p>
      </div>
      {{/if}}

      <div class="form-group">
        <label for="siteUrlPattern">{{t "repos.siteUrlPattern"}}</label>
        <input type="text" id="siteUrlPattern" name="siteUrlPattern" class="input" required
               placeholder="https://example.com%" aria-required="true"
               title="URL pattern using SQL LIKE syntax. Use % as wildcard.">
        <small class="text--muted">{{{t "repos.siteUrlPatternHint"}}}</small>
      </div>

      <div class="form-group">
        <label for="repoUrl">{{t "repos.repoUrl"}}</label>
        <input type="text" id="repoUrl" name="repoUrl" class="input" required
               placeholder="https://github.com/org/repo.git" aria-required="true">
      </div>

      <div class="form-group">
        <label for="repoPath">{{t "repos.localPath"}} <span class="text--muted">({{t "common.optional"}})</span></label>
        <input type="text" id="repoPath" name="repoPath" class="input"
               placeholder="/home/user/projects/my-site">
        <small class="text--muted">{{t "repos.localPathHint"}}</small>
      </div>

      <div class="form-group">
        <label for="gitHostConfigId">Git Host</label>
        <select id="gitHostConfigId" name="gitHostConfigId" class="select">
          <option value="">None (local path only)</option>
          {{#each gitHosts}}
          <option value="{{id}}">{{displayName}} ({{pluginType}})</option>
          {{/each}}
        </select>
        <p class="form-hint">Select the git host where this repo is hosted. Required for PR creation.</p>
      </div>

      <div class="form-group">
        <label for="branch">{{t "repos.branch"}}</label>
        <input type="text" id="branch" name="branch" class="input"
               placeholder="main" value="main">
      </div>

      <div>
        <button type="submit" class="btn btn--primary">{{t "repos.connectButton"}}</button>
      </div>
    </form>
  </div>

  {{! ── Connected Repos Table ──────────────────────────────────────── }}
  {{#if repos.length}}
  <div class="card">
    <h3 class="card__title">{{t "repos.activeConnections"}}</h3>
    <div class="table-responsive" role="region" aria-label="Connected repositories table" tabindex="0">
      <table class="data-table" aria-label="Connected repositories">
        <thead>
          <tr>
            <th scope="col">{{t "repos.siteUrlPattern"}}</th>
            <th scope="col">{{t "repos.repository"}}</th>
            <th scope="col">Git Host</th>
            <th scope="col">{{t "repos.branch"}}</th>
            <th scope="col">{{t "repos.localPath"}}</th>
            <th scope="col">{{t "repos.created"}}</th>
            <th scope="col">{{t "common.actions"}}</th>
          </tr>
        </thead>
        <tbody>
          {{#each repos}}
          <tr id="repo-row-{{this.id}}">
            <td><code>{{this.siteUrlPattern}}</code></td>
            <td>
              <a href="{{this.repoUrl}}" target="_blank" rel="noopener noreferrer" class="word-break">
                {{this.repoUrl}}
              </a>
            </td>
            <td>
              {{#if this.gitHostConfigId}}
              <span class="badge badge--info">{{this.gitHostConfigId}}</span>
              {{else}}
              <span class="text--muted">Local</span>
              {{/if}}
            </td>
            <td><code>{{this.branch}}</code></td>
            <td>
              {{#if this.repoPath}}
              <code>{{this.repoPath}}</code>
              {{else}}
              <span class="text--muted">{{t "repos.notSet"}}</span>
              {{/if}}
            </td>
            <td>{{this.createdAt}}</td>
            <td>
              <form method="POST" action="/admin/repos/{{this.id}}?_method=DELETE" style="display:inline;">
                <input type="hidden" name="_csrf" value="{{../csrfToken}}">
                <button type="submit"
                        class="btn btn--ghost btn--sm btn--danger"
                        hx-delete="/admin/repos/{{this.id}}"
                        hx-target="#repo-row-{{this.id}}"
                        hx-swap="outerHTML"
                        hx-confirm="{{t "repos.disconnectConfirm"}}"
                        aria-label="Disconnect repository {{this.repoUrl}}">
                  {{t "repos.disconnect"}}
                </button>
              </form>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>
  {{else}}
  <div class="empty-state" role="status">
    <p class="empty-state__desc">{{t "repos.noRepos"}}</p>
  </div>
  {{/if}}

  {{! ── Integration Notes ──────────────────────────────────────────── }}
  <div class="card card--alt mt-lg">
    <h3 class="card__title">{{t "repos.integrationOptionsTitle"}}</h3>
    <p class="text--muted mb-sm">
      {{t "repos.integrationOptionsDesc"}}
    </p>
    <ul class="text--muted list--padded">
      <li>{{{t "repos.integrationMcp"}}}</li>
      <li>{{{t "repos.integrationRest"}}}</li>
      <li>{{t "repos.integrationA2a"}}</li>
    </ul>
  </div>
</section>
