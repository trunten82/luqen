         aria-current="{{#if (startsWith currentPath '/admin/api-keys')}}page{{/if}}">
        <svg class="sidebar__icon" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M15 7a4 4 0 00-8 0 4 4 0 003 3.87V18l2 2 2-2v-1l-1-1 1-1v-1l-1-1 1-1v-1.13A4 4 0 0015 7zm-4-1.5a1.5 1.5 0 110 3 1.5 1.5 0 010-3z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        {{t "nav.identityAccess"}}
      </a>

      <a class="sidebar__item {{#if (eq currentPath '/admin/system')}}is-active{{/if}}"
         href="/admin/system">
        <svg class="sidebar__icon" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <circle cx="10" cy="10" r="3" stroke="currentColor" stroke-width="1.5"/>
          <path d="M10 2v2M10 16v2M2 10h2M16 10h2M4.22 4.22l1.42 1.42M14.36 14.36l1.42 1.42M4.22 15.78l1.42-1.42M14.36 5.64l1.42-1.42" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        {{t "nav.systemHealth"}}
      </a>
      {{/if}}

      {{!-- Audit + agent trails — visible to users with audit view permission. --}}
      {{#if (or perm.adminSystem perm.adminOrg)}}
      <a class="sidebar__item {{#if (startsWith currentPath '/admin/audit')}}is-active{{/if}}"
         href="/admin/audit"
         aria-current="{{#if (startsWith currentPath '/admin/audit')}}page{{/if}}">
        <svg class="sidebar__icon" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M10 2a8 8 0 100 16 8 8 0 000-16zM10 6v4l3 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        {{t "nav.agentAudit"}}
      </a>

      <a class="sidebar__item {{#if (startsWith currentPath '/admin/badges')}}is-active{{/if}}"
         href="/admin/badges"
         aria-current="{{#if (startsWith currentPath '/admin/badges')}}page{{/if}}">
        <svg class="sidebar__icon" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M10 2l2.4 4.9 5.4.8-3.9 3.8.9 5.4L10 14.4 5.2 16.9l.9-5.4L2.2 7.7l5.4-.8L10 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
        </svg>
        {{t "nav.shareableBadges"}}
      </a>
      {{/if}}

      {{#if perm.auditView}}
      {{#if perm.adminSystem}}
      <a class="sidebar__item {{#if (startsWith currentPath '/admin/audit-log')}}is-active{{/if}}"
         href="/admin/audit-log"
         aria-current="{{#if (startsWith currentPath '/admin/audit-log')}}page{{/if}}">
        <svg class="sidebar__icon" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M4 4h12a2 2 0 012 2v10a2 2 0 01-2 2H4a2 2 0 01-2-2V6a2 2 0 012-2z" stroke="currentColor" stroke-width="1.5"/>
          <path d="M6 8h8M6 11h8M6 14h5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        {{t "nav.auditLog"}}
      </a>
      {{/if}}
      {{/if}}
    </details>
    {{/if}}
  </div>

  <div class="sidebar__footer">
    {{#if orgContext}}
    {{#if orgContext.userOrgs.length}}
    <div class="sidebar__org-switcher">
      <span class="sidebar__section-label">{{t "common.organization"}}</span>
      <form method="POST" action="/orgs/switch" class="org-switch-form">
        <input type="hidden" name="_csrf" value="{{csrfToken}}">
        <select name="orgId" class="select select--sm" data-action-change="formAutoSubmit"
                aria-label="{{t "common.switchOrganization"}}">
          <option value="system" {{#unless orgContext.currentOrg}}selected{{/unless}}>{{t "common.systemNoOrg"}}</option>
          {{#each orgContext.userOrgs}}
          <option value="{{this.id}}" {{#if (eq this.id ../orgContext.currentOrg.id)}}selected{{/if}}>{{this.name}}</option>
          {{/each}}
        </select>
      </form>
    </div>
    {{/if}}
    {{/if}}

    <div class="sidebar__locale">
      <form method="POST" action="/account/locale">
        <input type="hidden" name="_csrf" value="{{csrfToken}}">
        <select name="locale" class="select select--sm" data-action-change="formAutoSubmit" aria-label="Language">
          {{#each locales}}
          <option value="{{this}}" {{#if (eq this ../locale)}}selected{{/if}}>{{lookup ../localeLabels this}}</option>
          {{/each}}
        </select>
        <button type="submit" class="sr-only">Save language</button>
      </form>
    </div>

    <div class="sidebar__footer-row">
      <a href="/account" class="sidebar__footer-user" title="{{t "nav.myProfile"}}">{{user.username}}</a>
      <button class="btn btn--ghost btn--sm" id="theme-toggle" data-action="toggleTheme"
              type="button" aria-label="Toggle dark mode">
        <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M10 2a8 8 0 100 16A8 8 0 0010 2zm0 14a6 6 0 010-12v12z" stroke="currentColor" stroke-width="1.5"/>
        </svg>
      </button>
      <form method="POST" action="/logout" class="sidebar__footer-logout">
        <input type="hidden" name="_csrf" value="{{csrfToken}}">
        <button type="submit" class="btn btn--ghost btn--sm">{{t "common.signOut"}}</button>
      </form>
    </div>
  </div>
</nav>
