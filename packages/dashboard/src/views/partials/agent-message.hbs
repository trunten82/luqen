{{#if (eq role "user")}}
  <div class="agent-msg agent-msg--user" data-message-id="{{id}}">
    <span class="agent-msg__role">{{t "agent.role.user"}}</span>
    <div class="agent-msg__body">{{content}}</div>
  </div>
{{else if (eq role "assistant")}}
  <div class="agent-msg agent-msg--assistant" data-message-id="{{id}}" lang="{{../locale}}"{{#if (eq status "streaming")}} aria-busy="true"{{/if}}>
    <span class="agent-msg__role">{{../agentDisplayName}}</span>
    <div class="agent-msg__body">{{content}}</div>
  </div>
{{else if (eq role "tool")}}
  {{#if (eq status "pending_confirmation")}}
    {{! Pending rows must stay in the DOM so agent.js can recover the dialog
        after a page reload (D-29 / SC#4). Everything else — resolved tool
        calls and their results — is hidden from the rehydrated panel: the
        user only cares about the assistant's final answer, and the
        streaming path never shows resolved tool bubbles either. }}
    <div class="agent-msg agent-msg--tool card card--muted" data-message-id="{{id}}" data-pending="true">
      <span class="agent-msg__role">{{t "agent.role.tool"}}</span>
      <span class="badge badge--warning">{{t "agent.confirm.pendingBadge"}}</span>
      <details>
        <summary>{{t "agent.tool.expand"}}</summary>
        {{#if toolCallJson}}<pre class="prompt-segment-content" aria-label="Tool call details">{{toolCallJson}}</pre>{{/if}}
      </details>
    </div>
  {{/if}}
{{/if}}
