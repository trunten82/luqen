{{! Completion banner — auto-refreshes content then restores button }}
<div id="rescore-region">
  <div class="alert alert--success">
    <strong>{{t "rescore.completeHeading"}}</strong>
    <p>{{t "rescore.completeBody" scored=scoredCount skipped=skippedCount warnings=warningCount}}</p>
  </div>
  {{! Refresh brand overview content (sparklines) after 3s }}
  <div hx-get="/brand-overview/content" hx-trigger="load delay:3s" hx-target="#brand-overview-content" hx-swap="innerHTML"></div>
  {{! Replace this banner with the rescore button after 5s }}
  <div hx-get="/brand-overview/rescore/button" hx-trigger="load delay:5s" hx-target="#rescore-region" hx-swap="outerHTML"></div>
</div>
