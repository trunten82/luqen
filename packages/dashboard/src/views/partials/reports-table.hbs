{{! Partial: reports table body + pagination — returned for HTMX requests }}
{{#if scans.length}}
<div class="table-responsive" role="region" aria-label="Reports table" tabindex="0">
  <table class="data-table" aria-label="Accessibility scan reports">
    <caption class="sr-only">Accessibility scan reports</caption>
    <thead>
      <tr>
        <th scope="col">Site URL</th>
        <th scope="col">Status</th>
        <th scope="col">Standard</th>
        <th scope="col">Pages</th>
        <th scope="col">Errors</th>
        <th scope="col">Warnings</th>
        <th scope="col">Notices</th>
        <th scope="col">Violations</th>
        <th scope="col">Date</th>
        <th scope="col">Actions</th>
      </tr>
    </thead>
    <tbody>
      {{#each scans}}
      <tr id="report-{{id}}">
        <td class="cell--url">
          <a href="/reports/{{id}}" aria-label="View report for {{siteUrl}}">{{siteUrl}}</a>
        </td>
        <td>
          <span class="badge badge--{{status}}" aria-label="Status: {{status}}">{{status}}</span>
        </td>
        <td>{{standard}}</td>
        <td>{{pagesScanned}}</td>
        <td class="text--error">{{errors}}</td>
        <td class="text--warning">{{warnings}}</td>
        <td>{{notices}}</td>
        <td>{{confirmedViolations}}</td>
        <td><time datetime="{{createdAt}}">{{createdAtDisplay}}</time></td>
        <td class="cell--actions">
          <a href="/reports/{{id}}" class="btn btn--sm btn--ghost" aria-label="View report for {{siteUrl}}">View</a>
          <button
            class="btn btn--sm btn--danger"
            hx-delete="/reports/{{id}}"
            hx-confirm="Delete the scan report for {{siteUrl}}? This cannot be undone."
            hx-target="#report-{{id}}"
            hx-swap="outerHTML swap:300ms"
            aria-label="Delete scan report for {{siteUrl}}"
          >Delete</button>
        </td>
      </tr>
      {{/each}}
    </tbody>
  </table>
</div>

<nav aria-label="Reports pagination" class="pagination">
  {{#if hasPrev}}
  <a
    href="/reports?offset={{prevOffset}}&limit={{limit}}"
    class="btn btn--ghost btn--sm"
    hx-get="/reports?offset={{prevOffset}}&limit={{limit}}"
    hx-target="#reports-table-body"
    hx-push-url="true"
    aria-label="Previous page"
  >&larr; Previous</a>
  {{/if}}
  <span class="pagination__info" aria-current="page">Page {{currentPage}}</span>
  {{#if hasNext}}
  <a
    href="/reports?offset={{nextOffset}}&limit={{limit}}"
    class="btn btn--ghost btn--sm"
    hx-get="/reports?offset={{nextOffset}}&limit={{limit}}"
    hx-target="#reports-table-body"
    hx-push-url="true"
    aria-label="Next page"
  >Next &rarr;</a>
  {{/if}}
</nav>
{{else}}
<div class="empty-state" role="status">
  <p>No reports found.</p>
</div>
{{/if}}
