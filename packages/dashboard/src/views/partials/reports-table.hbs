{{! Partial: reports table body + pagination — returned for HTMX requests }}
{{#if scans.length}}
<div class="table-responsive" role="region" aria-label="Reports table" tabindex="0">
  <table class="data-table" aria-label="Accessibility scan reports">
    <caption class="sr-only">Accessibility scan reports</caption>
    <thead>
      <tr>
        <th scope="col" class="cell--checkbox"><span class="sr-only">{{t "common.select"}}</span></th>
        <th scope="col">{{t "reports.siteUrl"}}</th>
        <th scope="col">{{t "common.status"}}</th>
        <th scope="col">{{t "reports.standard"}}</th>
        <th scope="col">{{t "reports.jurisdictions"}}</th>
        <th scope="col">{{t "reports.pages"}}</th>
        <th scope="col">{{t "reports.errors"}}</th>
        <th scope="col">{{t "reports.warnings"}}</th>
        <th scope="col">{{t "reports.notices"}}</th>
        <th scope="col">{{t "reports.compliance"}}</th>
        <th scope="col">{{t "common.date"}}</th>
        <th scope="col">{{t "common.actions"}}</th>
      </tr>
    </thead>
    <tbody>
      {{#each scans}}
      <tr id="report-{{id}}">
        <td class="cell--checkbox">
          {{#if (eq status 'completed')}}
          <input
            type="checkbox"
            class="cmp-check"
            value="{{id}}"
            data-action-change="cmpUpdateBtn"
            aria-label="Select report for {{siteUrl}} for comparison"
          >
          {{/if}}
        </td>
        <td class="cell--url">
          <a href="/reports/{{id}}" aria-label="View report for {{siteUrl}}">{{siteUrl}}</a>
        </td>
        <td>
          <span class="badge badge--{{status}}" aria-label="Status: {{status}}">{{status}}</span>
        </td>
        <td>{{formatStandard standard}}</td>
        <td>{{#if jurisdictions}}{{jurisdictions}}{{else}}&mdash;{{/if}}</td>
        <td>{{pagesScanned}}</td>
        <td class="text--error">{{errors}}</td>
        <td class="text--warning">{{warnings}}</td>
        <td>{{notices}}</td>
        <td data-label="Compliance">
          {{#if (eq complianceStatus 'fail')}}
          <span class="badge badge--error">{{t "reports.nonCompliant"}}</span>
          {{else if (eq complianceStatus 'review')}}
          <span class="badge badge--warning">{{t "reports.needsReview"}}</span>
          {{else if (eq complianceStatus 'pass')}}
          <span class="badge badge--success">{{t "reports.compliant"}}</span>
          {{else}}
          <span class="text-sm text-muted">&mdash;</span>
          {{/if}}
        </td>
        <td><time datetime="{{createdAt}}">{{createdAtDisplay}}</time></td>
        <td class="cell--actions">
          <a href="/reports/{{id}}" class="btn btn--sm btn--ghost" aria-label="View report for {{siteUrl}}">{{t "common.view"}}</a>
          {{#if previousScanId}}
          <a
            href="/reports/compare?a={{previousScanId}}&b={{id}}"
            class="btn btn--sm btn--ghost"
            aria-label="Compare with previous scan for {{siteUrl}}"
            title="Compare with previous scan"
          >{{t "reports.vsPrevious"}}</a>
          {{/if}}
          <button
            class="btn btn--sm btn--danger"
            hx-delete="/reports/{{id}}"
            hx-confirm="Delete the scan report for {{siteUrl}}? This cannot be undone."
            hx-target="#report-{{id}}"
            hx-swap="outerHTML swap:300ms"
            aria-label="Delete scan report for {{siteUrl}}"
          >{{t "common.delete"}}</button>
        </td>
      </tr>
      {{/each}}
    </tbody>
  </table>
</div>

<nav aria-label="Reports pagination" class="pagination">
  {{#if hasPrev}}
  <a
    href="/reports?offset={{prevOffset}}&limit={{limit}}"
    class="btn btn--ghost btn--sm"
    hx-get="/reports?offset={{prevOffset}}&limit={{limit}}"
    hx-target="#reports-table-body"
    hx-push-url="true"
    aria-label="Previous page"
  >&larr; {{t "common.previous"}}</a>
  {{/if}}
  <span class="pagination__info" aria-current="page">{{t "common.page"}} {{currentPage}}</span>
  {{#if hasNext}}
  <a
    href="/reports?offset={{nextOffset}}&limit={{limit}}"
    class="btn btn--ghost btn--sm"
    hx-get="/reports?offset={{nextOffset}}&limit={{limit}}"
    hx-target="#reports-table-body"
    hx-push-url="true"
    aria-label="Next page"
  >{{t "common.next"}} &rarr;</a>
  {{/if}}
</nav>
{{else}}
<div class="empty-state" role="status">
  <p>{{t "reports.noReports"}}</p>
</div>
{{/if}}
