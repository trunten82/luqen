{{!-- Phase 32 Plan 06 — Chat drawer + floating entry button (UI-SPEC Surface 1).
     Rendered once in the shared authenticated layout inside {{#if user}} so the
     DOM survives HTMX-boosted nav. localStorage.luqen.agent.panel controls
     visibility; agent.js hydrates open/closed state before first paint. --}}

<button type="button"
        id="agent-launch"
        class="agent-launch"
        aria-label="{{t "agent.launch.label" name=agentDisplayName}}"
        title="{{t "agent.launch.tooltip" name=agentDisplayName}}"
        aria-expanded="false"
        aria-controls="agent-drawer"
        data-action="toggleAgentDrawer">
  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
    <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"
          stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
</button>

<div class="agent-backdrop" id="agent-backdrop" data-action="closeAgentDrawer" hidden></div>

<aside id="agent-drawer"
       class="agent-drawer"
       aria-label="{{t "agent.drawer.title" name=agentDisplayName}}"
       hidden>
  <header class="agent-drawer__header">
    <h2 class="agent-drawer__title"><span id="agent-display-name">{{agentDisplayName}}</span></h2>
    <button type="button" class="agent-drawer__new-chat btn btn--ghost btn--sm"
            aria-label="{{t "agent.newChat.label"}}"
            title="{{t "agent.newChat.label"}}"
            data-action="newChat">{{t "agent.newChat.button"}}</button>
    <button type="button" class="agent-drawer__history-open btn btn--ghost btn--sm"
            aria-label="{{t "agent.history.openAria"}}"
            title="{{t "agent.history.open"}}"
            aria-expanded="false"
            aria-controls="agent-history-panel"
            data-action="openAgentHistory">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M3 12a9 9 0 1 0 3-6.7L3 8"/>
        <path d="M3 3v5h5"/>
        <path d="M12 7v5l3 2"/>
      </svg>
      <span class="sr-only">{{t "agent.history.open"}}</span>
    </button>
    <button type="button" class="agent-drawer__close"
            aria-label="{{t "agent.drawer.close"}}"
            data-action="closeAgentDrawer">&times;</button>
  </header>

  <div class="agent-drawer__messages"
       id="agent-messages"
       role="log"
       aria-live="polite"
       aria-atomic="false"
       aria-relevant="additions"
       tabindex="0">
    {{> agent-messages messages=messages agentDisplayName=agentDisplayName locale=locale}}
    <div class="agent-drawer__tool-chips" id="agent-tool-chips"
         role="status" aria-live="polite" aria-atomic="false"></div>
  </div>

  {{!-- Phase 36-04: tool chip i18n strings (CSP-strict; inert JSON, no executable script).
       Read once on load by agent.js for chip ARIA labels + cap-hit text. Templated with
       __NAME__ / __ERROR__ placeholders that the client substitutes per chip. --}}
  <script type="application/json" id="agent-tools-i18n">
  {
    "chip.runningAria": "{{t "agent.tools.chip.runningAria" name="__NAME__"}}",
    "chip.successAria": "{{t "agent.tools.chip.successAria" name="__NAME__"}}",
    "chip.errorAria":   "{{t "agent.tools.chip.errorAria" name="__NAME__" error="__ERROR__"}}",
    "cap.label":        "{{t "agent.tools.cap.label"}}",
    "cap.aria":         "{{t "agent.tools.cap.aria"}}"
  }
  </script>

  {{> agent-history-panel items=historyItems agentDisplayName=agentDisplayName}}

  <div class="agent-drawer__stream-status" id="agent-stream-status" role="status" aria-live="polite" hidden>
    <span class="agent-drawer__stream-indicator" aria-hidden="true"></span>
    <span class="sr-only">{{t "agent.stream.ariaLabel" name=agentDisplayName}}</span>
    <button type="button" class="btn btn--ghost btn--sm" id="agent-stop" hidden>
      {{t "agent.stream.stop"}}
    </button>
  </div>

  <form class="agent-drawer__input"
        id="agent-form"
        hx-post="/agent/message"
        hx-target="#agent-messages"
        hx-swap="beforeend"
        data-conversation-id="{{conversationId}}">
    <input type="hidden" name="_csrf" value="{{csrfToken}}">
    <input type="hidden" name="conversationId" value="{{conversationId}}" id="agent-conversation-id-field">
    <button type="button" class="chat-btn--icon btn btn--ghost" id="agent-speech"
            aria-label="{{t "agent.speech.start"}}"
            aria-pressed="false"
            hidden>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
        <path d="M19 10v2a7 7 0 0 1-14 0v-2M12 19v4M8 23h8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
    <label for="agent-input" class="sr-only">{{t "agent.input.placeholder" name=agentDisplayName}}</label>
    <textarea id="agent-input" name="content"
              placeholder="{{t "agent.input.placeholder" name=agentDisplayName}}"
              rows="1"
              lang="{{locale}}"
              maxlength="4000"
              required></textarea>
    <button type="submit" class="btn btn--primary chat-btn--icon" id="agent-send"
            aria-label="{{t "agent.input.sendAria"}}">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </form>

  {{> agent-confirm-dialog agentDisplayName=agentDisplayName}}
</aside>
