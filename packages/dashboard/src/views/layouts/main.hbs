<!DOCTYPE html>
<html lang="{{locale}}" data-density="{{density}}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Luqen — Accessibility Scanner">
  <title>{{#if pageTitle}}{{pageTitle}} — {{/if}}{{t "common.appName"}}</title>
  <link rel="stylesheet" href="/static/style.css?v=3.4.0">
  <script>
(function(){
  var s=localStorage.getItem('luqen-theme');
  if(s==='dark'||(s!=='light'&&matchMedia('(prefers-color-scheme:dark)').matches)){
    document.documentElement.setAttribute('data-theme','dark');
  }
})();
</script>
  <meta name="csrf-token" content="{{csrfToken}}">
  <link rel="icon" type="image/svg+xml" href="/static/favicon.svg">
</head>
<body>
  <a class="skip-link" href="#main-content">Skip to main content</a>

  {{#if user}}
  <!-- Sidebar backdrop -->
  <div class="sidebar-backdrop" id="sidebar-backdrop" data-action="closeSidebar"></div>

  {{> sidebar}}

  {{> agent-drawer agentDisplayName=(or user.orgAgentDisplayName "Luqen Assistant") csrfToken=csrfToken locale=locale conversationId=agentConversationId messages=agentMessages}}

  <!-- Top bar with burger menu (all screen sizes) -->
  <header class="app-header" role="banner">
    <button class="menu-toggle"
            aria-label="Open navigation menu"
            aria-expanded="false"
            id="mobile-menu-btn"
            type="button"
            data-action="toggleSidebar">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path d="M2 5h16M2 10h16M2 15h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
    <span class="app-header__brand">{{t "common.appName"}}</span>
    {{> density-toggle density=density}}
    <span class="app-header__user">{{user.username}}</span>
  </header>
  {{/if}}

  <main id="main-content" class="main-content" role="main" tabindex="-1">
    {{#if pageTitle}}
    <header class="page-header">
      <h1 class="page-header__title">{{pageTitle}}</h1>
      {{#if pageSubtitle}}
      <p class="page-header__subtitle">{{pageSubtitle}}</p>
      {{/if}}
    </header>
    {{/if}}
    <div class="page-body">
      {{{body}}}
    </div>
  </main>

  <div id="toast-container" role="region" aria-label="Notifications" aria-live="polite">{{#if flashToast}}<div class="toast toast--success" role="alert" aria-live="assertive">{{flashToast}}</div>{{/if}}</div>
  <div id="modal-container"></div>
  <div id="agent-aria-status" class="sr-only" aria-live="polite" aria-atomic="true"></div>

  <script src="/static/htmx.min.js?v=1.0.0"></script>
  <script src="/static/htmx-sse.js?v=1.0.0"></script>
  <script>
    /* Automatically include CSRF token on every HTMX request */
    document.body.addEventListener('htmx:configRequest', function(event) {
      var csrfMeta = document.querySelector('meta[name="csrf-token"]');
      if (csrfMeta) {
        event.detail.headers['x-csrf-token'] = csrfMeta.getAttribute('content');
      }
    });

    /* Process OOB swaps (toasts) from error responses — HTMX ignores 4xx/5xx by default */
    document.body.addEventListener('htmx:beforeOnLoad', function(event) {
      var xhr = event.detail.xhr;
      if (xhr.status >= 400 && xhr.responseText.indexOf('hx-swap-oob') !== -1) {
        event.detail.shouldSwap = true;
        // Keep isError true so afterRequest knows not to close modal
        // Redirect main swap to throwaway div — only OOB swaps processed
        event.detail.target = document.createElement('div');
      }
    });

    /* Glossary — Phase 58. Lazy-load on first hover/focus of any
       [data-glossary] element. Definitions rendered into a single
       singleton tooltip; semantic <dfn> still in DOM for screen
       readers. */
    (function() {
      var defs = null, pending = null, tip = null, currentEl = null;
      function loadDefs() {
        if (defs) return Promise.resolve(defs);
        if (pending) return pending;
        pending = fetch('/api/v1/glossary', { credentials: 'same-origin' })
          .then(function(r) { return r.ok ? r.json() : {}; })
          .then(function(json) { defs = json || {}; return defs; })
          .catch(function() { defs = {}; return defs; });
        return pending;
      }
      function ensureTip() {
        if (tip) return tip;
        tip = document.createElement('div');
        tip.className = 'glossary-tip';
        tip.setAttribute('role', 'tooltip');
        tip.hidden = true;
        document.body.appendChild(tip);
        return tip;
      }
      function show(el) {
        var key = el.getAttribute('data-glossary');
        if (!key) return;
        currentEl = el;
        loadDefs().then(function(d) {
          if (currentEl !== el) return;
          var entry = d && d[key];
          if (!entry) return;
          var t = ensureTip();
          while (t.firstChild) t.removeChild(t.firstChild);
          var label = document.createElement('strong');
          label.textContent = entry.label || key;
          var sep = document.createTextNode(' · ');
          var body = document.createTextNode(entry.definition || '');
          t.appendChild(label); t.appendChild(sep); t.appendChild(body);
          t.hidden = false;
          var rect = el.getBoundingClientRect();
          var top = rect.bottom + window.scrollY + 4;
          var left = Math.max(8, Math.min(window.innerWidth - 320 - 8, rect.left + window.scrollX));
          t.style.top = top + 'px';
          t.style.left = left + 'px';
        });
      }
      function hide() {
        currentEl = null;
        if (tip) tip.hidden = true;
      }
      document.addEventListener('mouseover', function(e) {
        var el = e.target.closest('[data-glossary]');
        if (el) show(el);
      });
      document.addEventListener('mouseout', function(e) {
        var el = e.target.closest('[data-glossary]');
        if (el && (!e.relatedTarget || !el.contains(e.relatedTarget))) hide();
      });
      document.addEventListener('focusin', function(e) {
        var el = e.target.closest('[data-glossary]');
        if (el) show(el);
      });
      document.addEventListener('focusout', function(e) {
        var el = e.target.closest('[data-glossary]');
        if (el) hide();
      });
      document.addEventListener('keydown', function(e) { if (e.key === 'Escape') hide(); });
    })();

    /* Density toggle — Phase 57. CSP-safe click handler. */
    document.addEventListener('click', function(e) {
      var db = e.target.closest('[data-action="setDensity"]');
      if (!db) return;
      var value = db.getAttribute('data-density');
      if (value !== 'plain' && value !== 'dense') return;
      document.documentElement.setAttribute('data-density', value);
      document.querySelectorAll('.density-toggle__btn').forEach(function(b) {
        b.setAttribute('aria-pressed', b.getAttribute('data-density') === value ? 'true' : 'false');
      });
      var csrfMeta = document.querySelector('meta[name="csrf-token"]');
      fetch('/account/density', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/x-www-form-urlencoded',
          'x-csrf-token': csrfMeta ? csrfMeta.getAttribute('content') : '',
        },
        body: 'density=' + encodeURIComponent(value),
        credentials: 'same-origin',
      }).catch(function() { /* non-fatal — DOM state stays in sync this session */ });
    });

    /* Toggle show/hide via data-action="toggle-edit" (CSP-safe) */
    document.addEventListener('click', function(e) {
      var btn = e.target.closest('[data-action="toggle-edit"]');
      if (!btn) return;
      var showId = btn.getAttribute('data-target-show');
      var hideId = btn.getAttribute('data-target-hide');
      if (showId) { var s = document.getElementById(showId); if (s) s.style.display = ''; }
      if (hideId) { var h = document.getElementById(hideId); if (h) h.style.display = 'none'; }
    });

    /* Tab switching via data-action="switch-tab" (CSP-safe event delegation)
       Supports space-separated IDs in data-target-hide and data-peer. */
    document.addEventListener('click', function(e) {
      var btn = e.target.closest('[data-action="switch-tab"]');
      if (!btn) return;
      var showId = btn.getAttribute('data-target-show');
      var hideIds = (btn.getAttribute('data-target-hide') || '').split(/\s+/);
      var peerIds = (btn.getAttribute('data-peer') || '').split(/\s+/);
      var showEl = document.getElementById(showId);
      if (showEl) showEl.classList.remove('rpt-tab-panel--hidden');
      hideIds.forEach(function(id) {
        var el = document.getElementById(id);
        if (el) el.classList.add('rpt-tab-panel--hidden');
      });
      btn.classList.add('rpt-tab--active');
      btn.setAttribute('aria-selected', 'true');
      peerIds.forEach(function(id) {
        var el = document.getElementById(id);
        if (el) {
          el.classList.remove('rpt-tab--active');
          el.setAttribute('aria-selected', 'false');
        }
      });
    });
  </script>
  <script src="/static/app.js?v=1.2.1"></script>
  <script src="/static/marked.umd.js?v=1.0.0" defer></script>
  <script src="/static/purify.min.js?v=1.0.0" defer></script>
  <script src="/static/mermaid.min.js?v=1.0.0" defer></script>
  <script src="/static/agent-speech.js?v=1.0.0" defer></script>
  <script src="/static/agent-tts.js?v=1.0.0" defer></script>
  <script src="/static/agent.js?v=1.2.6" defer></script>
  <script src="/static/agent-history.js?v=1.0.0" defer></script>
  <script src="/static/agent-tools.js?v=1.0.0" defer></script>
  <script src="/static/agent-actions.js?v=1.0.0" defer></script>
  <script src="/static/agent-org.js?v=1.0.0" defer></script>
  <script src="/static/agent-group.js?v=1.0.0" defer></script>
  <script src="/static/agent-tool-renderers.js?v=1.0.0" defer></script>
</body>
</html>
