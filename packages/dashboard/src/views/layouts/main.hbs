<!DOCTYPE html>
<html lang="{{locale}}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Luqen — Accessibility Scanner">
  <title>{{#if pageTitle}}{{pageTitle}} — {{/if}}{{t "common.appName"}}</title>
  <link rel="stylesheet" href="/static/style.css?v=0.21.0">
  <meta name="csrf-token" content="{{csrfToken}}">
  <link rel="icon" type="image/svg+xml" href="/static/favicon.svg">
</head>
<body>
  <a class="skip-link" href="#main-content">Skip to main content</a>

  {{#if user}}
  <!-- Sidebar backdrop -->
  <div class="sidebar-backdrop" id="sidebar-backdrop" data-action="closeSidebar"></div>

  {{> sidebar}}

  <!-- Top bar with burger menu (all screen sizes) -->
  <header class="app-header" role="banner">
    <button class="menu-toggle"
            aria-label="Open navigation menu"
            aria-expanded="false"
            id="mobile-menu-btn"
            type="button"
            data-action="toggleSidebar">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path d="M2 5h16M2 10h16M2 15h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
    <span style="font-size:1.125rem;font-weight:700;color:var(--accent)">{{t "common.appName"}}</span>
    <span class="app-header__user">{{user.username}}</span>
  </header>
  {{/if}}

  <main id="main-content" class="main-content" role="main" tabindex="-1">
    {{#if pageTitle}}
    <header class="page-header">
      <h1 class="page-header__title">{{pageTitle}}</h1>
      {{#if pageSubtitle}}
      <p class="page-header__subtitle">{{pageSubtitle}}</p>
      {{/if}}
    </header>
    {{/if}}
    <div class="page-body">
      {{{body}}}
    </div>
  </main>

  <div id="toast-container" role="region" aria-label="Notifications" aria-live="polite"></div>
  <div id="modal-container"></div>

  <script src="/static/htmx.min.js"></script>
  <script src="/static/htmx-sse.js"></script>
  <script src="/static/app.js"></script>
</body>
</html>
