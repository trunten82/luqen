{{! Home page — summary stats and recent scans }}

<section aria-labelledby="exec-summary-heading">
  <h2 id="exec-summary-heading" class="section-title">{{t "home.executiveSummary"}}</h2>
  <div class="exec-summary" role="list" aria-label="Executive summary statistics">
    {{> stat-card value=stats.totalScans label=(t "home.totalScans") accentColor="var(--accent)"}}
    {{> stat-card value=stats.sitesMonitored label=(t "home.sitesMonitored") accentColor="var(--status-info)"}}
    <article class="stat-card" role="listitem" style="border-left: 3px solid var(--accent)">
      <span class="stat-card__value {{stats.trendClass}}">{{stats.trendDirection}}</span>
      <span class="stat-card__label">{{t "home.overallTrend"}}</span>
    </article>
    <article class="stat-card" role="listitem" style="border-left: 3px solid var(--status-success)">
      <span class="stat-card__value" aria-label="{{stats.complianceRate}} percent {{t "home.complianceRate"}}">{{stats.complianceRate}}%</span>
      <span class="stat-card__label">{{t "home.complianceRate"}}</span>
    </article>
  </div>
</section>

{{#unless isExecutiveView}}
<section aria-labelledby="stats-heading">
  <h2 id="stats-heading" class="section-title">{{t "home.overview"}}</h2>
  <div class="stats-grid" role="list" aria-label="Summary statistics">
    {{> stat-card value=stats.totalScans label=(t "home.totalScans")}}
    {{> stat-card value=stats.scansThisWeek label=(t "home.scansThisWeek")}}
    {{> stat-card value=stats.pagesScanned label=(t "home.pagesScanned")}}
    {{> stat-card value=stats.issuesFound label=(t "home.issuesFound")}}
  </div>
</section>
{{/unless}}

{{#if perm.scansCreate}}
<div class="card mb-md">
  <div class="card__body" style="text-align:center; padding: var(--space-lg);">
    <h2 class="card__title mb-sm">{{t "home.startScan"}}</h2>
    <p class="text-muted mb-md">{{t "home.scanDescription"}}</p>
    <a href="/scan/new" class="btn btn--primary">{{t "nav.newScan"}}</a>
  </div>
</div>
{{/if}}

<section aria-labelledby="recent-scans-heading">
  <div class="section-header">
    <h2 id="recent-scans-heading" class="section-title">{{t "home.recentScans"}}</h2>
    <a href="/reports" class="btn btn--ghost btn--sm">{{t "home.viewAllReports"}}</a>
  </div>

  {{#if recentScans.length}}
  {{#if isExecutiveView}}
  {{! Executive view — simplified recent scans }}
  <div class="table-responsive" role="region" aria-label="Recent scans table" tabindex="0">
    <table class="data-table" aria-label="Recent scans">
      <caption class="sr-only">Most recent accessibility scans</caption>
      <thead>
        <tr>
          <th scope="col">{{t "home.siteUrl"}}</th>
          <th scope="col">{{t "common.status"}}</th>
          <th scope="col">{{t "home.issues"}}</th>
          <th scope="col">{{t "common.date"}}</th>
        </tr>
      </thead>
      <tbody>
        {{#each recentScans}}
        <tr id="scan-{{id}}">
          <td data-label="Site URL" class="cell--url">{{siteUrl}}</td>
          <td data-label="Status">
            <span class="badge badge--{{status}}" aria-label="Status: {{status}}">
              {{status}}
            </span>
          </td>
          <td data-label="Issues">
            {{#if totalIssues}}{{totalIssues}}{{else}}&mdash;{{/if}}
          </td>
          <td data-label="Date">
            <time datetime="{{createdAt}}">{{createdAtDisplay}}</time>
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{else}}
  {{! Full view — all columns and actions }}
  <div class="table-responsive" role="region" aria-label="Recent scans table" tabindex="0">
    <table class="data-table" aria-label="Recent scans">
      <caption class="sr-only">Most recent accessibility scans</caption>
      <thead>
        <tr>
          <th scope="col">{{t "home.siteUrl"}}</th>
          <th scope="col">{{t "common.status"}}</th>
          <th scope="col">{{t "home.standard"}}</th>
          <th scope="col">{{t "home.jurisdictions"}}</th>
          <th scope="col">{{t "home.pages"}}</th>
          <th scope="col">{{t "home.issues"}}</th>
          <th scope="col">{{t "common.date"}}</th>
          <th scope="col">{{t "common.actions"}}</th>
        </tr>
      </thead>
      <tbody>
        {{#each recentScans}}
        <tr id="scan-{{id}}">
          <td data-label="Site URL" class="cell--url">
            <a href="/reports/{{id}}" aria-label="View report for {{siteUrl}}">
              {{siteUrl}}
            </a>
          </td>
          <td data-label="Status">
            <span class="badge badge--{{status}}" aria-label="Status: {{status}}">
              {{status}}
            </span>
          </td>
          <td data-label="Standard">{{formatStandard standard}}</td>
          <td data-label="Jurisdictions">{{#if jurisdictions}}{{jurisdictions}}{{else}}&mdash;{{/if}}</td>
          <td data-label="Pages">{{pagesScanned}}</td>
          <td data-label="Issues">
            {{#if totalIssues}}
            <span>
              <span class="text--error">{{errors}} {{t "home.errors"}}</span>,
              <span class="text--warning">{{warnings}} {{t "home.warnings"}}</span>,
              {{notices}} {{t "home.notices"}}
            </span>
            {{else}}
            —
            {{/if}}
          </td>
          <td data-label="Date">
            <time datetime="{{createdAt}}">{{createdAtDisplay}}</time>
          </td>
          <td>
            {{#if (eq status 'completed')}}
            <a href="/reports/{{id}}" class="btn btn--sm btn--secondary">{{t "home.viewReport"}}</a>
            {{else if (eq status 'running')}}
            <a href="/scan/{{id}}/progress" class="btn btn--sm btn--secondary">{{t "home.viewProgress"}}</a>
            {{else if (eq status 'queued')}}
            <a href="/scan/{{id}}/progress" class="btn btn--sm btn--secondary">{{t "home.viewQueue"}}</a>
            {{/if}}
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{/if}}
  {{else}}
  <div class="empty-state" role="status">
    <p>{{t "home.noScans"}}</p>
  </div>
  {{/if}}
</section>
