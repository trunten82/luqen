{{! Home — two-column docket (Phase 57 / R2 Move D).
    Left rail: org posture as a typographic block.
    Right column: activity stream of recent scans.
    No cards. No icons. Citron 2px left-edge mark on rows needing attention. }}

<div class="docket">

  <aside class="docket__rail" aria-labelledby="docket-posture-heading">
    <h2 id="docket-posture-heading" class="docket__rail-eyebrow">{{t "common.appName"}} posture</h2>

    <p class="docket__rail-score" aria-label="{{stats.complianceRate}} percent compliance">
      <span class="docket__rail-score-value">{{stats.complianceRate}}</span><span class="docket__rail-score-unit">%</span>
    </p>

    <p class="docket__rail-verdict">
      {{#if (eq stats.sitesMonitored 0)}}
        {{t "home.docketVerdictNoScans"}}
      {{else}}
        {{t "home.docketVerdict" sites=stats.sitesMonitored trend=stats.trendDirection}}
      {{/if}}
    </p>

    <dl class="docket__rail-meta">
      <div class="docket__rail-meta-row">
        <dt>{{t "home.sitesMonitored"}}</dt>
        <dd>{{stats.sitesMonitored}}</dd>
      </div>
      <div class="docket__rail-meta-row">
        <dt>{{t "home.pagesScanned"}}</dt>
        <dd>{{stats.pagesScanned}}</dd>
      </div>
      <div class="docket__rail-meta-row">
        <dt>{{t "home.scansThisWeek"}}</dt>
        <dd>{{stats.scansThisWeek}}</dd>
      </div>
      <div class="docket__rail-meta-row">
        <dt>{{t "home.issuesFound"}}</dt>
        <dd>{{stats.issuesFound}}</dd>
      </div>
    </dl>

    {{#if perm.scansCreate}}
    <a href="/scan/new" class="docket__rail-cta btn btn--primary btn--sm">{{t "nav.newScan"}}</a>
    {{/if}}
  </aside>

  <section class="docket__stream" aria-labelledby="docket-stream-heading">
    <header class="docket__stream-header">
      <h2 id="docket-stream-heading" class="docket__stream-eyebrow">{{t "home.recentActivity"}}</h2>
      <a href="/reports" class="docket__stream-link">{{t "home.viewAllReports"}}</a>
    </header>

    {{#if recentScans.length}}
    <ol class="docket__rows" role="list">
      {{#each recentScans}}
      <li class="docket__row docket__row--flag" id="scan-{{id}}" data-scan-id="{{id}}">
        <time class="docket__row-time" datetime="{{createdAt}}">{{createdAtDisplay}}</time>
        <a class="docket__row-headline" href="/reports/{{id}}" aria-label="View report for {{siteUrl}}">
          {{siteUrl}}
        </a>
        <span class="docket__row-status docket__row-status--{{status}}">{{status}}</span>
        <span class="docket__row-detail">
          {{#if (eq status 'completed')}}
            {{#if totalIssues}}
              {{errors}} {{t "home.errors"}}, {{warnings}} {{t "home.warnings"}}, {{pagesScanned}} {{t "home.pages"}}
            {{else}}
              {{t "home.noIssues"}} · {{pagesScanned}} {{t "home.pages"}}
            {{/if}}
          {{else if (eq status 'running')}}
            <a href="/scan/{{id}}/progress">{{t "home.viewProgress"}}</a>
          {{else if (eq status 'queued')}}
            <a href="/scan/{{id}}/progress">{{t "home.viewQueue"}}</a>
          {{else if (eq status 'failed')}}
            {{t "home.scanFailed"}}
          {{/if}}
        </span>
      </li>
      {{/each}}
    </ol>
    {{else}}
    <div class="docket__empty" role="status">
      <p class="docket__empty-headline">{{t "home.noScans"}}</p>
      {{#if perm.scansCreate}}
      <a href="/scan/new" class="btn btn--primary">{{t "nav.newScan"}}</a>
      {{/if}}
    </div>
    {{/if}}
  </section>

</div>
