{{! Home page — summary stats and recent scans }}

<section aria-labelledby="exec-summary-heading">
  <h2 id="exec-summary-heading" class="section-title">{{t "home.executiveSummary"}}</h2>
  <div class="exec-summary" role="list" aria-label="Executive summary statistics">
    <article class="exec-summary__card" role="listitem">
      <span class="exec-summary__value" aria-label="{{stats.totalScans}} total scans completed">{{stats.totalScans}}</span>
      <span class="exec-summary__label">{{t "home.totalScans"}}</span>
    </article>
    <article class="exec-summary__card" role="listitem">
      <span class="exec-summary__value" aria-label="{{stats.sitesMonitored}} sites monitored">{{stats.sitesMonitored}}</span>
      <span class="exec-summary__label">{{t "home.sitesMonitored"}}</span>
    </article>
    <article class="exec-summary__card" role="listitem">
      <span class="exec-summary__value exec-summary__value--trend" aria-label="Overall trend: {{stats.trendDirection}}">{{stats.trendDirection}}</span>
      <span class="exec-summary__label">{{t "home.overallTrend"}}</span>
    </article>
    <article class="exec-summary__card" role="listitem">
      <span class="exec-summary__value" aria-label="{{stats.complianceRate}} percent compliance rate">{{stats.complianceRate}}%</span>
      <span class="exec-summary__label">{{t "home.complianceRate"}}</span>
    </article>
  </div>
</section>

{{#unless isExecutiveView}}
<section aria-labelledby="stats-heading">
  <h2 id="stats-heading" class="section-title">{{t "home.overview"}}</h2>
  <div class="stats-grid" role="list" aria-label="Summary statistics">
    <article class="stat-card" role="listitem">
      <span class="stat-card__value" aria-label="{{stats.totalScans}} total scans">{{stats.totalScans}}</span>
      <span class="stat-card__label">{{t "home.totalScans"}}</span>
    </article>
    <article class="stat-card" role="listitem">
      <span class="stat-card__value" aria-label="{{stats.scansThisWeek}} scans this week">{{stats.scansThisWeek}}</span>
      <span class="stat-card__label">{{t "home.scansThisWeek"}}</span>
    </article>
    <article class="stat-card" role="listitem">
      <span class="stat-card__value" aria-label="{{stats.pagesScanned}} pages scanned">{{stats.pagesScanned}}</span>
      <span class="stat-card__label">{{t "home.pagesScanned"}}</span>
    </article>
    <article class="stat-card" role="listitem">
      <span class="stat-card__value" aria-label="{{stats.issuesFound}} issues found">{{stats.issuesFound}}</span>
      <span class="stat-card__label">{{t "home.issuesFound"}}</span>
    </article>
  </div>
</section>
{{/unless}}

{{#if perm.scansCreate}}
<section aria-labelledby="quick-scan-heading">
  <h2 id="quick-scan-heading" class="section-title">{{t "home.newScan"}}</h2>
  <div class="card mb-lg">
    <form method="POST" action="/scan/new" novalidate>
      <input type="hidden" name="_csrf" value="{{csrfToken}}">
      <div class="form-group">
        <label for="quick-url">{{t "home.websiteUrl"}} <span class="required" aria-hidden="true">*</span></label>
        <input type="url" id="quick-url" name="siteUrl"
               placeholder="https://example.com"
               autocomplete="url" required aria-required="true"
               aria-describedby="quick-url-hint">
        <p id="quick-url-hint" class="form-hint">{{{t "home.urlHint"}}}</p>
      </div>

      <input type="hidden" name="standard" value="WCAG2AA">

      <div class="form-group">
        <label>{{t "home.scanMode"}}</label>
        <div class="radio-group radio-group--inline">
          <label class="radio-label">
            <input type="radio" name="scanMode" value="single" checked>
            <span>{{t "home.singlePage"}}</span>
          </label>
          <label class="radio-label">
            <input type="radio" name="scanMode" value="site">
            <span>{{t "home.fullSite"}}</span>
          </label>
        </div>
      </div>

      {{#if jurisdictions.length}}
      <div class="form-group">
        <label>{{t "home.complianceCheck"}} <span class="text-xs text-muted">(optional)</span></label>
        <p class="form-hint mb-sm">{{t "home.complianceHint"}}</p>

        <div class="picker" id="compliance-picker">
          <div class="picker__tabs">
            <button type="button" class="picker__tab picker__tab--active" data-action="pickerTab" data-tab="jurisdictions">{{t "home.jurisdictions"}}</button>
            <button type="button" class="picker__tab" data-action="pickerTab" data-tab="regulations">{{t "home.regulations"}}</button>
          </div>
          <input type="search" class="picker__search" placeholder="{{t "common.search"}}" data-action-input="pickerSearch" aria-label="Search jurisdictions or regulations">
          <div class="picker__list" id="picker-list">
            {{#each jurisdictions}}
            <label class="picker__item" data-tab="jurisdictions" data-name="{{name}}">
              <input type="checkbox" name="jurisdictions" value="{{id}}">
              <span>{{name}}</span>
              <span class="text-xs text-muted">{{id}}</span>
            </label>
            {{/each}}
            {{#each regulations}}
            <label class="picker__item" data-tab="regulations" data-name="{{name}} {{shortName}}" style="display:none">
              <input type="checkbox" name="jurisdictions" value="{{jurisdictionId}}">
              <span>{{shortName}}</span>
              <span class="text-xs text-muted">{{name}}</span>
            </label>
            {{/each}}
          </div>
          <div class="picker__selected" id="picker-selected"></div>
        </div>
      </div>
      {{/if}}

      <div class="form-group" style="display:flex;gap:1.5rem;">
        <label class="checkbox-label">
          <input type="checkbox" name="includeWarnings" value="true" checked>
          <span>{{t "scans.includeWarnings"}}</span>
        </label>
        <label class="checkbox-label">
          <input type="checkbox" name="includeNotices" value="true" checked>
          <span>{{t "scans.includeNotices"}}</span>
        </label>
      </div>

      <div class="page-actions">
        <button type="submit" class="btn btn--primary">{{t "home.startScan"}}</button>
        <a href="/scan/new" class="btn btn--ghost">{{t "home.advancedOptions"}}</a>
      </div>
    </form>
  </div>
</section>
{{/if}}

<section aria-labelledby="recent-scans-heading">
  <div class="section-header">
    <h2 id="recent-scans-heading" class="section-title">{{t "home.recentScans"}}</h2>
    <a href="/reports" class="btn btn--ghost btn--sm">{{t "home.viewAllReports"}}</a>
  </div>

  {{#if recentScans.length}}
  {{#if isExecutiveView}}
  {{! Executive view — simplified recent scans }}
  <div class="table-responsive" role="region" aria-label="Recent scans table" tabindex="0">
    <table class="data-table" aria-label="Recent scans">
      <caption class="sr-only">Most recent accessibility scans</caption>
      <thead>
        <tr>
          <th scope="col">{{t "home.siteUrl"}}</th>
          <th scope="col">{{t "common.status"}}</th>
          <th scope="col">{{t "home.issues"}}</th>
          <th scope="col">{{t "common.date"}}</th>
        </tr>
      </thead>
      <tbody>
        {{#each recentScans}}
        <tr id="scan-{{id}}">
          <td data-label="Site URL" class="cell--url">{{siteUrl}}</td>
          <td data-label="Status">
            <span class="badge badge--{{status}}" aria-label="Status: {{status}}">
              {{status}}
            </span>
          </td>
          <td data-label="Issues">
            {{#if totalIssues}}{{totalIssues}}{{else}}&mdash;{{/if}}
          </td>
          <td data-label="Date">
            <time datetime="{{createdAt}}">{{createdAtDisplay}}</time>
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{else}}
  {{! Full view — all columns and actions }}
  <div class="table-responsive" role="region" aria-label="Recent scans table" tabindex="0">
    <table class="data-table" aria-label="Recent scans">
      <caption class="sr-only">Most recent accessibility scans</caption>
      <thead>
        <tr>
          <th scope="col">{{t "home.siteUrl"}}</th>
          <th scope="col">{{t "common.status"}}</th>
          <th scope="col">{{t "home.standard"}}</th>
          <th scope="col">{{t "home.jurisdictions"}}</th>
          <th scope="col">{{t "home.pages"}}</th>
          <th scope="col">{{t "home.issues"}}</th>
          <th scope="col">{{t "common.date"}}</th>
          <th scope="col">{{t "common.actions"}}</th>
        </tr>
      </thead>
      <tbody>
        {{#each recentScans}}
        <tr id="scan-{{id}}">
          <td data-label="Site URL" class="cell--url">
            <a href="/reports/{{id}}" aria-label="View report for {{siteUrl}}">
              {{siteUrl}}
            </a>
          </td>
          <td data-label="Status">
            <span class="badge badge--{{status}}" aria-label="Status: {{status}}">
              {{status}}
            </span>
          </td>
          <td data-label="Standard">{{formatStandard standard}}</td>
          <td data-label="Jurisdictions">{{#if jurisdictions}}{{jurisdictions}}{{else}}&mdash;{{/if}}</td>
          <td data-label="Pages">{{pagesScanned}}</td>
          <td data-label="Issues">
            {{#if totalIssues}}
            <span>
              <span class="text--error">{{errors}} {{t "home.errors"}}</span>,
              <span class="text--warning">{{warnings}} {{t "home.warnings"}}</span>,
              {{notices}} {{t "home.notices"}}
            </span>
            {{else}}
            —
            {{/if}}
          </td>
          <td data-label="Date">
            <time datetime="{{createdAt}}">{{createdAtDisplay}}</time>
          </td>
          <td>
            {{#if (eq status 'completed')}}
            <a href="/reports/{{id}}" class="btn btn--sm btn--secondary">{{t "home.viewReport"}}</a>
            {{else if (eq status 'running')}}
            <a href="/scan/{{id}}/progress" class="btn btn--sm btn--secondary">{{t "home.viewProgress"}}</a>
            {{else if (eq status 'queued')}}
            <a href="/scan/{{id}}/progress" class="btn btn--sm btn--secondary">{{t "home.viewQueue"}}</a>
            {{/if}}
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{/if}}
  {{else}}
  <div class="empty-state" role="status">
    <p>{{t "home.noScans"}}</p>
  </div>
  {{/if}}
</section>
