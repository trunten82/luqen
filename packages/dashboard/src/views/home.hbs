{{! Home page — summary stats and recent scans }}

<section aria-labelledby="exec-summary-heading">
  <h2 id="exec-summary-heading" class="section-title">Executive Summary</h2>
  <div class="exec-summary" role="list" aria-label="Executive summary statistics">
    <article class="exec-summary__card" role="listitem">
      <span class="exec-summary__value" aria-label="{{stats.totalScans}} total scans completed">{{stats.totalScans}}</span>
      <span class="exec-summary__label">Total Scans</span>
    </article>
    <article class="exec-summary__card" role="listitem">
      <span class="exec-summary__value" aria-label="{{stats.sitesMonitored}} sites monitored">{{stats.sitesMonitored}}</span>
      <span class="exec-summary__label">Sites Monitored</span>
    </article>
    <article class="exec-summary__card" role="listitem">
      <span class="exec-summary__value exec-summary__value--trend" aria-label="Overall trend: {{stats.trendDirection}}">{{stats.trendDirection}}</span>
      <span class="exec-summary__label">Overall Trend</span>
    </article>
    <article class="exec-summary__card" role="listitem">
      <span class="exec-summary__value" aria-label="{{stats.complianceRate}} percent compliance rate">{{stats.complianceRate}}%</span>
      <span class="exec-summary__label">Compliance Rate</span>
    </article>
  </div>
</section>

{{#unless (isExecutive user.role)}}
<section aria-labelledby="stats-heading">
  <h2 id="stats-heading" class="section-title">Overview</h2>
  <div class="stats-grid" role="list" aria-label="Summary statistics">
    <article class="stat-card" role="listitem">
      <span class="stat-card__value" aria-label="{{stats.totalScans}} total scans">{{stats.totalScans}}</span>
      <span class="stat-card__label">Total Scans</span>
    </article>
    <article class="stat-card" role="listitem">
      <span class="stat-card__value" aria-label="{{stats.scansThisWeek}} scans this week">{{stats.scansThisWeek}}</span>
      <span class="stat-card__label">Scans This Week</span>
    </article>
    <article class="stat-card" role="listitem">
      <span class="stat-card__value" aria-label="{{stats.pagesScanned}} pages scanned">{{stats.pagesScanned}}</span>
      <span class="stat-card__label">Pages Scanned</span>
    </article>
    <article class="stat-card" role="listitem">
      <span class="stat-card__value" aria-label="{{stats.issuesFound}} issues found">{{stats.issuesFound}}</span>
      <span class="stat-card__label">Issues Found</span>
    </article>
  </div>
</section>
{{/unless}}

{{#if (canRunScans user.role)}}
<section aria-labelledby="quick-scan-heading">
  <h2 id="quick-scan-heading" class="section-title">New Scan</h2>
  <div class="card mb-lg">
    <form method="POST" action="/scan/new" novalidate>
      <input type="hidden" name="_csrf" value="{{csrfToken}}">
      <div class="form-group">
        <label for="quick-url">Website URL <span class="required" aria-hidden="true">*</span></label>
        <input type="url" id="quick-url" name="siteUrl"
               placeholder="https://example.com"
               autocomplete="url" required aria-required="true"
               aria-describedby="quick-url-hint">
        <p id="quick-url-hint" class="form-hint">Enter the full URL including <code>https://</code>.</p>
      </div>

      <input type="hidden" name="standard" value="WCAG2AA">

      <div class="form-group">
        <label>Scan Mode</label>
        <div class="radio-group radio-group--inline">
          <label class="radio-label">
            <input type="radio" name="scanMode" value="single" checked>
            <span>Single Page</span>
          </label>
          <label class="radio-label">
            <input type="radio" name="scanMode" value="site">
            <span>Full Site</span>
          </label>
        </div>
      </div>

      {{#if jurisdictions.length}}
      <div class="form-group">
        <label>Compliance Check <span class="text-xs text-muted">(optional)</span></label>
        <p class="form-hint mb-sm">Search and select jurisdictions or regulations to check against.</p>

        <div class="picker" id="compliance-picker">
          <div class="picker__tabs">
            <button type="button" class="picker__tab picker__tab--active" onclick="pickerTab('jurisdictions',this)">Jurisdictions</button>
            <button type="button" class="picker__tab" onclick="pickerTab('regulations',this)">Regulations</button>
          </div>
          <input type="search" class="picker__search" placeholder="Search..." oninput="pickerSearch(this.value)" aria-label="Search jurisdictions or regulations">
          <div class="picker__list" id="picker-list">
            {{#each jurisdictions}}
            <label class="picker__item" data-tab="jurisdictions" data-name="{{name}}">
              <input type="checkbox" name="jurisdictions" value="{{id}}">
              <span>{{name}}</span>
              <span class="text-xs text-muted">{{id}}</span>
            </label>
            {{/each}}
            {{#each regulations}}
            <label class="picker__item" data-tab="regulations" data-name="{{name}} {{shortName}}" style="display:none">
              <input type="checkbox" name="jurisdictions" value="{{jurisdictionId}}">
              <span>{{shortName}}</span>
              <span class="text-xs text-muted">{{name}}</span>
            </label>
            {{/each}}
          </div>
          <div class="picker__selected" id="picker-selected"></div>
        </div>
      </div>
      {{/if}}

      <div class="page-actions">
        <button type="submit" class="btn btn--primary">Start Scan</button>
        <a href="/scan/new" class="btn btn--ghost">Advanced Options</a>
      </div>
    </form>
  </div>
</section>
{{/if}}

<section aria-labelledby="recent-scans-heading">
  <div class="section-header">
    <h2 id="recent-scans-heading" class="section-title">Recent Scans</h2>
    <a href="/reports" class="btn btn--ghost btn--sm">View all reports</a>
  </div>

  {{#if recentScans.length}}
  {{#if (isExecutive user.role)}}
  {{! Executive view — simplified recent scans }}
  <div class="table-responsive" role="region" aria-label="Recent scans table" tabindex="0">
    <table class="data-table" aria-label="Recent scans">
      <caption class="sr-only">Most recent accessibility scans</caption>
      <thead>
        <tr>
          <th scope="col">Site URL</th>
          <th scope="col">Status</th>
          <th scope="col">Issues</th>
          <th scope="col">Date</th>
        </tr>
      </thead>
      <tbody>
        {{#each recentScans}}
        <tr id="scan-{{id}}">
          <td data-label="Site URL" class="cell--url">{{siteUrl}}</td>
          <td data-label="Status">
            <span class="badge badge--{{status}}" aria-label="Status: {{status}}">
              {{status}}
            </span>
          </td>
          <td data-label="Issues">
            {{#if totalIssues}}{{totalIssues}}{{else}}&mdash;{{/if}}
          </td>
          <td data-label="Date">
            <time datetime="{{createdAt}}">{{createdAtDisplay}}</time>
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{else}}
  {{! Full view — all columns and actions }}
  <div class="table-responsive" role="region" aria-label="Recent scans table" tabindex="0">
    <table class="data-table" aria-label="Recent scans">
      <caption class="sr-only">Most recent accessibility scans</caption>
      <thead>
        <tr>
          <th scope="col">Site URL</th>
          <th scope="col">Status</th>
          <th scope="col">Standard</th>
          <th scope="col">Jurisdictions</th>
          <th scope="col">Pages</th>
          <th scope="col">Issues</th>
          <th scope="col">Date</th>
          <th scope="col">Actions</th>
        </tr>
      </thead>
      <tbody>
        {{#each recentScans}}
        <tr id="scan-{{id}}">
          <td data-label="Site URL" class="cell--url">
            <a href="/reports/{{id}}" aria-label="View report for {{siteUrl}}">
              {{siteUrl}}
            </a>
          </td>
          <td data-label="Status">
            <span class="badge badge--{{status}}" aria-label="Status: {{status}}">
              {{status}}
            </span>
          </td>
          <td data-label="Standard">{{formatStandard standard}}</td>
          <td data-label="Jurisdictions">{{#if jurisdictions}}{{jurisdictions}}{{else}}&mdash;{{/if}}</td>
          <td data-label="Pages">{{pagesScanned}}</td>
          <td data-label="Issues">
            {{#if totalIssues}}
            <span>
              <span class="text--error">{{errors}} errors</span>,
              <span class="text--warning">{{warnings}} warnings</span>,
              {{notices}} notices
            </span>
            {{else}}
            —
            {{/if}}
          </td>
          <td data-label="Date">
            <time datetime="{{createdAt}}">{{createdAtDisplay}}</time>
          </td>
          <td>
            {{#if (eq status 'completed')}}
            <a href="/reports/{{id}}" class="btn btn--sm btn--secondary">View Report</a>
            {{else if (eq status 'running')}}
            <a href="/scan/{{id}}/progress" class="btn btn--sm btn--secondary">View Progress</a>
            {{else if (eq status 'queued')}}
            <a href="/scan/{{id}}/progress" class="btn btn--sm btn--secondary">View Queue</a>
            {{/if}}
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{/if}}
  {{else}}
  <div class="empty-state" role="status">
    <p>No scans yet. Start your first scan using the quick scan form above.</p>
  </div>
  {{/if}}
</section>
