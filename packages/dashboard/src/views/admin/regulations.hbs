<section aria-label="Regulations management">
  <div class="page-actions">
    <button hx-get="/admin/regulations/new{{#if jurisdictionId}}?jurisdictionId={{jurisdictionId}}{{/if}}"
            hx-target="#modal-container"
            hx-swap="innerHTML"
            class="btn btn--primary"
            aria-haspopup="dialog">
      {{t "admin.regulations.addRegulation"}}
    </button>
  </div>

  {{#if error}}
  <div class="alert alert--error" role="alert">
    <p>{{error}}</p>
  </div>
  {{/if}}

  <div class="filter-bar">
    <label for="jurisdiction-filter" class="form-label">{{t "admin.regulations.filterByJurisdiction"}}</label>
    <select id="jurisdiction-filter"
            name="jurisdictionId"
            hx-get="/admin/regulations"
            hx-trigger="change"
            hx-target="#regulations-table-body"
            hx-include="[name='q']"
            class="select"
            aria-label="Filter regulations by jurisdiction">
      <option value="">{{t "admin.regulations.allJurisdictions"}}</option>
      {{#each jurisdictions}}
      <option value="{{id}}" {{#if (eq id ../jurisdictionId)}}selected{{/if}}>{{name}}</option>
      {{/each}}
    </select>

    <label for="regulation-search" class="visually-hidden">{{t "admin.regulations.searchLabel"}}</label>
    <input id="regulation-search"
           type="search"
           name="q"
           value="{{q}}"
           placeholder="{{t "admin.regulations.searchPlaceholder"}}"
           hx-get="/admin/regulations"
           hx-trigger="input changed delay:300ms"
           hx-target="#regulations-table-body"
           hx-include="[name='jurisdictionId']"
           hx-indicator="#search-spinner"
           class="input"
           aria-label="Search regulations by name"
           role="searchbox">
    <span id="search-spinner" class="htmx-indicator" aria-hidden="true">{{t "common.searching"}}</span>
  </div>

  <div class="table-wrapper" aria-live="polite" aria-atomic="false">
    <table class="table" aria-label="Regulations">
      <thead>
        <tr>
          <th scope="col">{{t "admin.regulations.colId"}}</th>
          <th scope="col">{{t "admin.regulations.colName"}}</th>
          <th scope="col">{{t "admin.regulations.colShortName"}}</th>
          <th scope="col">{{t "admin.regulations.colJurisdiction"}}</th>
          <th scope="col">{{t "admin.regulations.colEnforcementDate"}}</th>
          <th scope="col">{{t "common.status"}}</th>
          <th scope="col">{{t "admin.regulations.colScope"}}</th>
          <th scope="col">{{t "common.actions"}}</th>
        </tr>
      </thead>
      <tbody id="regulations-table-body">
        {{#each regulations}}
        <tr id="regulation-{{id}}">
          <td data-label="ID">{{id}}</td>
          <td data-label="Name">{{name}}</td>
          <td data-label="Short Name">{{shortName}}</td>
          <td data-label="Jurisdiction">{{jurisdictionId}}</td>
          <td data-label="Enforcement Date">{{enforcementDate}}</td>
          <td data-label="Status">{{status}}</td>
          <td data-label="Scope">{{scope}}</td>
          <td>
            <button hx-get="/admin/regulations/{{id}}/view"
                    hx-target="#modal-container"
                    hx-swap="innerHTML"
                    class="btn btn--sm btn--secondary"
                    aria-label="View {{name}}">{{t "common.view"}}</button>
          </td>
        </tr>
        {{else}}
        <tr>
          <td colspan="8" class="table__empty">{{t "admin.regulations.noRegulations"}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>

  {{#if hasNext}}
  <div class="load-more" id="load-more-regulations">
    <button hx-get="/admin/regulations?offset={{nextOffset}}&limit={{limit}}&q={{q}}&jurisdictionId={{jurisdictionId}}&partial=rows"
            hx-target="#regulations-table-body"
            hx-swap="beforeend"
            class="btn btn--ghost btn--full"
            aria-label="Load more regulations"
>
      {{t "admin.regulations.loadMore" offset=nextOffset total=total}}
    </button>
  </div>
  {{/if}}
</section>
