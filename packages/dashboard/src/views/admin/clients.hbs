<section aria-label="OAuth clients management">
  {{#if isGlobalAdmin}}
  <div class="page-actions">
    <button hx-get="/admin/clients/new"
            hx-target="#modal-container"
            hx-swap="innerHTML"
            class="btn btn--primary"
            aria-haspopup="dialog">
      {{t "admin.clients.addClient"}}
    </button>
  </div>
  {{/if}}

  {{#if error}}
  <div class="alert alert--error" role="alert">
    <p>{{error}}</p>
  </div>
  {{/if}}

  <div class="table-wrapper" aria-live="polite" aria-atomic="false">
    <table class="table" aria-label="OAuth clients">
      <thead>
        <tr>
          <th scope="col">{{t "common.name"}}</th>
          <th scope="col">{{t "admin.clients.clientId"}}</th>
          <th scope="col">{{t "admin.clients.scope"}}</th>
          <th scope="col">{{t "common.service"}}</th>
          <th scope="col">Kind</th>
          <th scope="col">{{t "common.owner"}}</th>
          {{#if showOrgColumn}}
          <th scope="col">Org</th>
          {{/if}}
          <th scope="col">{{t "admin.clients.created"}}</th>
          <th scope="col">Revoked</th>
          <th scope="col">{{t "common.actions"}}</th>
        </tr>
      </thead>
      <tbody id="clients-table-body">
        {{#each clients}}
        <tr id="client-{{clientId}}">
          <td data-label="Name" class="cell--wrap">{{name}}</td>
          <td data-label="Client ID" class="cell--wrap"><code>{{clientId}}</code></td>
          <td data-label="Scope" class="cell--wrap">{{scopesDisplay}}</td>
          <td data-label="Service"><span class="badge badge--neutral">{{service}}</span></td>
          <td data-label="Kind">
            {{#if (eq kind 'DCR')}}
            <span class="badge badge--warning" title="Dynamically-registered via RFC 7591">DCR</span>
            {{else}}
            <span class="badge badge--info">Admin</span>
            {{/if}}
          </td>
          <td data-label="Owner">
            {{#if isSystem}}
            <span class="badge badge--neutral">{{t "admin.clients.systemOwner"}}</span>
            {{else}}
            <span class="badge badge--info">{{orgDisplayName}}</span>
            {{/if}}
          </td>
          {{#if @root.showOrgColumn}}
          <td data-label="Org">{{orgDisplayName}}</td>
          {{/if}}
          <td data-label="Created">{{createdAtDisplay}}</td>
          <td data-label="Revoked">
            {{#if revokedAtDisplay}}
            <span class="badge badge--danger">{{revokedAtDisplay}}</span>
            {{else}}
            —
            {{/if}}
          </td>
          <td>
            {{#unless revokedAtDisplay}}
              {{#if canRevoke}}
              {{#if (eq kind 'DCR')}}
              <button hx-post="/admin/clients/dcr/{{clientId}}/revoke"
                      hx-confirm="Revoke DCR client {{name}}? MCP sessions are blocked immediately on the next tool call."
                      hx-target="closest tr"
                      hx-swap="outerHTML swap:500ms"
                      hx-headers='{"X-CSRF-Token": "{{@root.csrfToken}}"}'
                      class="btn btn--sm btn--danger"
                      aria-label="Revoke DCR client {{name}}">{{t "admin.clients.revoke"}}</button>
              {{else}}
              <button hx-post="/admin/clients/{{clientId}}/{{#if (eq service 'Branding')}}revoke-branding{{else if (eq service 'LLM')}}revoke-llm{{else}}revoke{{/if}}"
                      hx-confirm="Revoke client {{name}}? This cannot be undone."
                      hx-target="closest tr"
                      hx-swap="outerHTML swap:500ms"
                      class="btn btn--sm btn--danger"
                      aria-label="Revoke {{name}}">{{t "admin.clients.revoke"}}</button>
              <input type="hidden" name="_csrf" value="{{@root.csrfToken}}">
              {{/if}}
              {{else}}
              <span class="text-xs text-muted">{{t "admin.clients.protected"}}</span>
              {{/if}}
            {{else}}
            <span class="text-xs text-muted">—</span>
            {{/unless}}
          </td>
        </tr>
        {{else}}
        <tr>
          <td colspan="{{#if showOrgColumn}}10{{else}}9{{/if}}" class="table__empty">{{t "admin.clients.noClients"}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</section>
