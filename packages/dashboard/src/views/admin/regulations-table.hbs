{{#each regulations}}
<tr id="regulation-{{id}}">
  <td data-label="ID">{{id}}</td>
  <td data-label="Name">{{name}}</td>
  <td data-label="Short Name">{{shortName}}</td>
  <td data-label="Jurisdiction">{{jurisdictionId}}</td>
  <td data-label="Enforcement Date">{{enforcementDate}}</td>
  <td data-label="Status">{{status}}</td>
  <td data-label="Scope">{{scope}}</td>
  <td data-label="Owner">
    {{#if (eq orgId "system")}}<span class="badge badge--neutral">System</span>{{else}}{{orgId}}{{/if}}
  </td>
  <td>
    <button hx-get="/admin/regulations/{{id}}/view"
            hx-target="#modal-container"
            hx-swap="innerHTML"
            class="btn btn--sm btn--secondary"
            aria-label="View {{name}}">{{t "common.view"}}</button>
  </td>
</tr>
{{else}}
<tr>
  <td colspan="9" class="table__empty">{{t "admin.regulations.noRegulations"}}</td>
</tr>
{{/each}}
{{#if hasNext}}
<tr id="load-more-row">
  <td colspan="9">
    <button hx-get="/admin/regulations?offset={{nextOffset}}&limit={{limit}}&q={{q}}&jurisdictionId={{jurisdictionId}}&partial=rows"
            hx-target="#regulations-table-body"
            hx-swap="beforeend"
            class="btn btn--ghost btn--full"
            aria-label="Load more regulations">
      {{t "admin.regulations.loadMore" offset=nextOffset total=total}}
    </button>
  </td>
</tr>
{{/if}}
