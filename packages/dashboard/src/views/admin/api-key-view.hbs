<div class="modal-overlay" role="dialog" aria-modal="true" aria-labelledby="modal-title">
  <div class="modal">
    <div class="modal__header">
      <h2 id="modal-title">{{t "admin.apiKeys.apiKeyTitle"}}: {{key.label}}</h2>
      <button class="modal__close close-modal-btn" aria-label="Close">&times;</button>
    </div>

    <dl class="detail-list">
      <div class="detail-list__item">
        <dt>{{t "admin.apiKeys.label"}}</dt>
        <dd>{{key.label}}</dd>
      </div>
      <div class="detail-list__item">
        <dt>{{t "common.status"}}</dt>
        <dd>
          {{#if key.active}}
          <span class="badge badge--completed">{{t "common.active"}}</span>
          {{else}}
          <span class="badge badge--failed">{{t "admin.apiKeys.revoked"}}</span>
          {{/if}}
        </dd>
      </div>
      <div class="detail-list__item">
        <dt>{{t "admin.apiKeys.created"}}</dt>
        <dd>{{key.createdDisplay}}</dd>
      </div>
      <div class="detail-list__item">
        <dt>{{t "admin.apiKeys.lastUsed"}}</dt>
        <dd>{{#if key.lastUsedDisplay}}{{key.lastUsedDisplay}}{{else}}{{t "admin.apiKeys.never"}}{{/if}}</dd>
      </div>
    </dl>

    <div class="modal__footer">
      {{#if key.active}}
      <button hx-post="/admin/api-keys/{{key.id}}/revoke"
              hx-confirm="Revoke API key &quot;{{key.label}}&quot;? This cannot be undone. Any client using this key will lose access."
              hx-target="#api-key-{{key.id}}"
              hx-swap="outerHTML"
              class="btn btn--danger"
              data-action="closeModalDelayed">
        {{t "admin.apiKeys.revokeKey"}}
      </button>
      {{else}}
      <p class="text-xs text-muted">{{t "admin.apiKeys.revokedNote"}}</p>
      {{/if}}
      <button type="button" class="btn btn--ghost close-modal-btn">{{t "admin.apiKeys.close"}}</button>
    </div>
  </div>
</div>
