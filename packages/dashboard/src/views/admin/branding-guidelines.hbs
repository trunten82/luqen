<section aria-label="{{t "admin.branding.title"}}">
  <nav class="tabs" role="tablist" aria-label="{{t "admin.branding.tabsLabel"}}">
    <a class="tab {{#unless systemLibraryActive}}tab--active{{/unless}}"
       href="/admin/branding-guidelines"
       role="tab"
       aria-selected="{{#unless systemLibraryActive}}true{{else}}false{{/unless}}">
      {{t "admin.branding.tabs.myGuidelines"}}
      <span class="badge badge--neutral">{{guidelines.length}}</span>
    </a>
    <a class="tab {{#if systemLibraryActive}}tab--active{{/if}}"
       href="/admin/branding-guidelines?tab=system"
       role="tab"
       aria-selected="{{#if systemLibraryActive}}true{{else}}false{{/if}}">
      {{t "admin.branding.tabs.systemLibrary"}}
      <span class="badge badge--info">{{systemGuidelines.length}}</span>
    </a>
  </nav>

  {{#if systemLibraryActive}}
  {{!-- System Library tab panel — read-only list of system guidelines --}}
  <div id="branding-guidelines-alert" aria-live="polite"></div>
  {{#if systemGuidelines.length}}
  <div class="table-wrapper">
    <table class="table" aria-label="{{t "admin.branding.tabs.systemLibrary"}}">
      <thead>
        <tr>
          <th scope="col">{{t "admin.branding.brandLogo"}}</th>
          <th scope="col">{{t "common.name"}}</th>
          <th scope="col">{{t "admin.branding.sites"}}</th>
          <th scope="col">{{t "admin.branding.version"}}</th>
          <th scope="col">{{t "common.actions"}}</th>
        </tr>
      </thead>
      <tbody id="system-library-table">
        {{#each systemGuidelines}}
        {{> system-library-row this}}
        {{/each}}
      </tbody>
    </table>
  </div>
  {{else}}
  <div class="empty-state">
    <h3>{{t "admin.systemBrand.library.emptyHeading"}}</h3>
    <p class="text-muted">{{t "admin.systemBrand.library.emptyBody"}}</p>
  </div>
  {{/if}}
  {{else}}
  <div class="page-actions">
    {{#if perm.brandingManage}}
    <button class="btn btn--primary"
            hx-get="/admin/branding-guidelines/new"
            hx-target="#modal-container"
            hx-swap="innerHTML"
            aria-haspopup="dialog">
      {{t "admin.branding.createGuideline"}}
    </button>
    {{/if}}
    <a href="/admin/branding-guidelines/templates/csv" class="btn btn--ghost btn--sm">{{t "admin.branding.downloadCsvTemplate"}}</a>
    <a href="/admin/branding-guidelines/templates/json" class="btn btn--ghost btn--sm">{{t "admin.branding.downloadJsonTemplate"}}</a>
  </div>

  <div id="branding-guidelines-alert" aria-live="polite"></div>

  {{#if guidelines.length}}
  <div class="table-wrapper">
    <table class="table" aria-label="{{t "admin.branding.title"}}">
      <thead>
        <tr>
          <th scope="col">{{t "admin.branding.brandLogo"}}</th>
          <th scope="col">{{t "common.name"}}</th>
          {{#if isGlobalAdmin}}
          <th scope="col">{{t "common.organization"}}</th>
          {{/if}}
          <th scope="col">{{t "admin.branding.sites"}}</th>
          <th scope="col">{{t "common.status"}}</th>
          <th scope="col">{{t "admin.branding.version"}}</th>
          <th scope="col">{{t "common.actions"}}</th>
        </tr>
      </thead>
      <tbody id="branding-guidelines-table">
        {{#each guidelines}}
        <tr id="branding-guideline-{{this.id}}">
          <td class="table__cell" data-label="Logo">
            {{#if this.imagePath}}
            <img src="{{this.imagePath}}"
                 alt="{{this.name}} brand logo"
                 width="40" height="40"
                 style="width:40px;height:40px;max-width:40px;max-height:40px;border-radius:var(--radius-sm);object-fit:contain;background:var(--bg-secondary);">
            {{else}}
            <div style="width:40px;height:40px;border-radius:var(--radius-sm);background:var(--bg-secondary);display:flex;align-items:center;justify-content:center;">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <rect x="3" y="3" width="14" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="7" cy="7" r="1.5" fill="currentColor"/>
                <path d="M3 13 L7 9 L11 13 L14 10 L17 13" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linejoin="round"/>
              </svg>
            </div>
            {{/if}}
          </td>
          <td data-label="Name">
            <a href="/admin/branding-guidelines/{{this.id}}">{{this.name}}</a>
            {{#if this.description}}
            <p class="text-sm text-muted">{{this.description}}</p>
            {{/if}}
          </td>
          {{#if ../isGlobalAdmin}}
          <td data-label="Organization">
            <span class="badge badge--neutral">{{this.orgDisplayName}}</span>
          </td>
          {{/if}}
          <td data-label="Sites">
            <span class="badge badge--neutral">{{this.siteCount}} site{{#unless (eq this.siteCount 1)}}s{{/unless}}</span>
          </td>
          <td data-label="Status">
            {{#if this.active}}
            <span class="badge badge--success">{{t "common.active"}}</span>
            {{else}}
            <span class="badge badge--neutral">{{t "common.inactive"}}</span>
            {{/if}}
          </td>
          <td data-label="Version">
            {{#if this.version}}
            <span class="badge badge--info">v{{this.version}}</span>
            {{else}}
            <span class="text-muted">—</span>
            {{/if}}
          </td>
          <td>
            <a href="/admin/branding-guidelines/{{this.id}}"
               class="btn btn--sm btn--secondary"
               aria-label="{{t "common.view"}} {{this.name}}">{{t "common.view"}}</a>
            {{#if ../perm.brandingManage}}
            <button hx-post="/admin/branding-guidelines/{{this.id}}/toggle-active"
                    hx-target="body"
                    class="btn btn--sm {{#if this.active}}btn--warning{{else}}btn--success{{/if}}"
                    aria-label="{{#if this.active}}{{t "admin.branding.deactivate"}}{{else}}{{t "admin.branding.activate"}}{{/if}} {{this.name}}">
              <input type="hidden" name="_csrf" value="{{csrfToken}}">
              {{#if this.active}}{{t "admin.branding.deactivate"}}{{else}}{{t "admin.branding.activate"}}{{/if}}
            </button>
            <button hx-post="/admin/branding-guidelines/{{this.id}}/delete"
                    hx-confirm="{{t "admin.branding.confirmDelete" name=this.name}}"
                    hx-target="#branding-guideline-{{this.id}}"
                    hx-swap="outerHTML"
                    class="btn btn--sm btn--danger"
                    aria-label="{{t "common.delete"}} {{this.name}}">
              <input type="hidden" name="_csrf" value="{{csrfToken}}">
              {{t "common.delete"}}
            </button>
            {{/if}}
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{else}}
  <p class="text-muted">{{t "admin.branding.noGuidelines"}}</p>
  {{/if}}

  {{!-- Upload / import form --}}
  {{#if perm.brandingManage}}
  <div class="card mt-lg">
    <h3>{{t "admin.branding.importGuidelines"}}</h3>
    <p class="text-muted mb-md">{{t "admin.branding.importDescription"}}</p>
    <form method="POST"
          action="/admin/branding-guidelines/upload"
          novalidate
          class="form-group">
      <input type="hidden" name="_csrf" value="{{csrfToken}}">
      <div class="form-group">
        <label class="form-label" for="import-content">{{t "admin.branding.importContent"}}</label>
        <textarea id="import-content"
                  name="content"
                  class="input"
                  rows="6"
                  placeholder="{{t "admin.branding.importContentPlaceholder"}}"
                  aria-describedby="import-format-hint"></textarea>
      </div>
      <div class="form-group">
        <label class="form-label" for="import-format">{{t "admin.branding.importFormat"}}</label>
        <select id="import-format" name="format" class="input">
          <option value="csv">CSV</option>
          <option value="json">JSON</option>
        </select>
        <p id="import-format-hint" class="text-sm text-muted mt-xs">{{t "admin.branding.importFormatHint"}}</p>
      </div>
      <div class="form-actions">
        <button type="submit" class="btn btn--primary">{{t "admin.branding.import"}}</button>
      </div>
    </form>
  </div>
  {{/if}}
  {{/if}}
</section>
