<section aria-label="Plugin management dashboard"
        hx-get="/admin/plugins" hx-trigger="pluginChanged from:body" hx-select="section[aria-label='Plugin management dashboard']" hx-swap="outerHTML">
  <p class="text-sm text-muted mb-md">
    <span class="badge badge--completed">{{counts.active}} {{t "admin.plugins.active"}}</span>
    <span class="badge badge--info">{{counts.installed}} {{t "admin.plugins.installed"}}</span>
    {{#if isAdmin}}
    <span class="badge badge--queued">{{counts.available}} {{t "admin.plugins.available"}}</span>
    {{/if}}
  </p>

  <div id="plugin-messages"></div>

  <section class="admin-section" aria-label="Installed plugins">
    <h2 class="section-title">{{t "admin.plugins.installedPlugins"}}</h2>

    {{#if installed.length}}
    <div class="plugin-grid">
      {{#each installed}}
      <div class="card" aria-label="Plugin {{packageName}}">
        <div class="card__header">
          <h3 class="card__title">{{packageName}}</h3>
          <span class="badge badge--info">{{type}}</span>
          {{#if isGlobalOnly}}<span class="badge badge--neutral">Global</span>{{/if}}
          {{#if isOrgInstance}}<span class="badge badge--completed">Org</span>{{/if}}
        </div>
        <div class="card__body">
          <dl class="stats-list">
            <div class="stats-list__item">
              <dt>{{t "admin.plugins.version"}}</dt>
              <dd>{{version}}</dd>
            </div>
            <div class="stats-list__item">
              <dt>{{t "common.status"}}</dt>
              <dd>
                <span class="badge {{#if (eq status 'active')}}badge--success{{else if (eq status 'inactive')}}badge--neutral{{else if (eq status 'error')}}badge--error{{else if (eq status 'unhealthy')}}badge--warning{{else}}badge--neutral{{/if}}">
                  {{#if isGlobalOnly}}
                    Not activated for org
                  {{else}}
                    {{status}}
                  {{/if}}
                </span>
              </dd>
            </div>
          </dl>

          <div class="card__actions mt-sm">
            {{#if ../isAdmin}}
              {{!-- Org usage info --}}
              {{#if orgUsageCount}}
              <div class="text-xs text-muted mb-sm">
                <strong>Org usage:</strong>
                {{#each orgUsage}}
                <span class="badge {{#if (eq status 'active')}}badge--success{{else}}badge--neutral{{/if}}" style="margin-right: 2px;">
                  {{orgName}}{{#if hasCustomConfig}} *{{/if}}
                </span>
                {{/each}}
                <p class="mt-xs">* = custom config</p>
              </div>
              {{else}}
              <p class="text-xs text-muted mb-sm">No organizations have activated this plugin yet.</p>
              {{/if}}

              {{!-- Global admin: full control --}}
              {{#if (eq status "active")}}
              <button class="btn btn--sm btn--secondary"
                      hx-post="/admin/plugins/{{id}}/deactivate"
                      hx-target="#plugin-messages" hx-swap="innerHTML">
                {{t "admin.plugins.deactivate"}}
              </button>
              {{else}}
              <button class="btn btn--sm btn--primary"
                      hx-post="/admin/plugins/{{id}}/activate"
                      hx-target="#plugin-messages" hx-swap="innerHTML">
                {{t "admin.plugins.activate"}}
              </button>
              {{/if}}
              <button class="btn btn--sm btn--ghost"
                      hx-get="/admin/plugins/{{id}}/configure"
                      hx-target="#plugin-config-area" hx-swap="innerHTML">
                {{t "admin.plugins.configure"}}
              </button>
              <button class="btn btn--sm btn--danger"
                      hx-delete="/admin/plugins/{{id}}"
                      hx-target="#plugin-messages" hx-swap="innerHTML"
                      hx-confirm="Remove this plugin globally? All org configurations will be lost.">
                {{t "admin.plugins.remove"}}
              </button>
            {{else}}
              {{!-- Org admin --}}
              {{#if isOrgInstance}}
                {{!-- Org has its own instance --}}
                {{#if (eq status "active")}}
                <button class="btn btn--sm btn--secondary"
                        hx-post="/admin/plugins/{{id}}/org/deactivate"
                        hx-target="#plugin-messages" hx-swap="innerHTML">
                  Deactivate
                </button>
                <button class="btn btn--sm btn--ghost"
                        hx-get="/admin/plugins/{{id}}/configure"
                        hx-target="#plugin-config-area" hx-swap="innerHTML">
                  Configure
                </button>
                {{else}}
                <button class="btn btn--sm btn--primary"
                        hx-post="/admin/plugins/{{id}}/org/activate"
                        hx-target="#plugin-messages" hx-swap="innerHTML">
                  Activate
                </button>
                {{/if}}
              {{else}}
                {{!-- Global plugin not yet activated for this org --}}
                <button class="btn btn--sm btn--primary"
                        hx-post="/admin/plugins/{{id}}/org/activate"
                        hx-target="#plugin-messages" hx-swap="innerHTML">
                  Activate for my organization
                </button>
                <p class="text-xs text-muted mt-xs">Uses global configuration. You can customize after activating.</p>
              {{/if}}
            {{/if}}
          </div>
        </div>
      </div>
      {{/each}}
    </div>
    {{else}}
    <p>{{t "admin.plugins.noInstalled"}}</p>
    {{/if}}
  </section>

  <div id="plugin-config-area"></div>

  {{#if isAdmin}}
  <section class="admin-section" aria-label="Available plugins from registry">
    <h2 class="section-title">{{t "admin.plugins.availablePlugins"}}</h2>

    {{#if available.length}}
    <div class="plugin-grid">
      {{#each available}}
      <div class="card" aria-label="Available plugin {{displayName}}">
        <div class="card__header">
          <h3 class="card__title">{{displayName}}</h3>
          <span class="badge badge--info">{{type}}</span>
        </div>
        <div class="card__body">
          <p>{{description}}</p>
          <dl class="stats-list">
            <div class="stats-list__item">
              <dt>{{t "admin.plugins.package"}}</dt>
              <dd><code>{{packageName}}</code></dd>
            </div>
            <div class="stats-list__item">
              <dt>{{t "admin.plugins.version"}}</dt>
              <dd>{{version}}</dd>
            </div>
          </dl>

          <button class="btn btn--sm btn--primary"
                  hx-post="/admin/plugins/install"
                  hx-vals='{"packageName": "{{packageName}}"}'
                  hx-target="#plugin-messages"
                  hx-swap="innerHTML">
            <input type="hidden" name="_csrf" value="{{csrfToken}}">
            {{t "admin.plugins.install"}}
          </button>
        </div>
      </div>
      {{/each}}
    </div>
    {{else}}
    <p>{{t "admin.plugins.allInstalled"}}</p>
    {{/if}}
  </section>
  {{else}}
  <p class="text-muted mt-lg">Need a plugin that's not installed? Contact your system administrator.</p>
  {{/if}}
</section>
