<section aria-label="{{t "admin.systemBrand.title"}}">
  <div class="page-header">
    <h1 class="page-header__title">{{t "admin.systemBrand.title"}}</h1>
    <p class="page-header__subtitle">{{t "admin.systemBrand.description"}}</p>
  </div>

  <div class="page-actions">
    <button class="btn btn--primary"
            hx-get="/admin/system-brand-guidelines/new"
            hx-target="#modal-container"
            hx-swap="innerHTML"
            aria-haspopup="dialog">
      {{t "admin.systemBrand.createGuideline"}}
    </button>
  </div>

  <div id="system-brand-toast" aria-live="polite" aria-atomic="true"></div>

  {{#if guidelines.length}}
  <div class="table-wrapper">
    <table class="table" aria-label="{{t "admin.systemBrand.title"}}">
      <thead>
        <tr>
          <th scope="col">{{t "admin.systemBrand.column.logo"}}</th>
          <th scope="col">{{t "admin.systemBrand.column.name"}}</th>
          <th scope="col">{{t "admin.systemBrand.column.usage"}}</th>
          <th scope="col">{{t "admin.systemBrand.column.status"}}</th>
          <th scope="col">{{t "admin.systemBrand.column.version"}}</th>
          <th scope="col">{{t "admin.systemBrand.column.actions"}}</th>
        </tr>
      </thead>
      <tbody id="system-brand-table-body">
        {{#each guidelines}}
        {{> system-brand-guideline-row this}}
        {{/each}}
      </tbody>
    </table>
  </div>
  {{else}}
  <div class="empty-state">
    <h2 class="empty-state__title">{{t "admin.systemBrand.empty.heading"}}</h2>
    <p class="empty-state__desc">{{t "admin.systemBrand.empty.body"}}</p>
    <button class="btn btn--primary"
            hx-get="/admin/system-brand-guidelines/new"
            hx-target="#modal-container"
            hx-swap="innerHTML"
            aria-haspopup="dialog">
      {{t "admin.systemBrand.empty.cta"}}
    </button>
  </div>
  {{/if}}
</section>
