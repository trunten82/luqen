<section>
  {{#if configs.length}}
  <div class="data-table-wrapper">
    <table class="data-table">
      <thead>
        <tr>
          <th scope="col">Display Name</th>
          <th scope="col">Type</th>
          <th scope="col">Host URL</th>
          <th scope="col">Actions</th>
        </tr>
      </thead>
      <tbody>
        {{#each configs}}
        <tr>
          <td>{{displayName}}</td>
          <td><span class="badge badge--info">{{pluginType}}</span></td>
          <td class="text-sm text-muted">{{hostUrl}}</td>
          <td>
            <button class="btn btn--sm btn--danger"
                    hx-delete="/admin/git-hosts/{{id}}"
                    hx-target="#git-host-messages"
                    hx-swap="innerHTML"
                    hx-confirm="Remove this git host? Developer credentials for it will also be deleted.">
              Remove
            </button>
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{else}}
  <div class="empty-state">
    <p>No git hosts configured. Add one below to enable repository integration.</p>
  </div>
  {{/if}}

  <div id="git-host-messages"></div>

  <div class="card mt-lg">
    <h3 class="card__title mb-md">Add Git Host</h3>
    <form method="POST" action="/admin/git-hosts">
      <input type="hidden" name="_csrf" value="{{csrfToken}}">
      <div class="form-group">
        <label for="pluginType">Platform</label>
        <select id="pluginType" name="pluginType" class="select" required>
          {{#each pluginTypes}}
          <option value="{{this}}">{{this}}</option>
          {{/each}}
        </select>
      </div>
      <div class="form-group">
        <label for="hostUrl">Host URL</label>
        <input type="url" id="hostUrl" name="hostUrl" class="input" required
               placeholder="https://api.github.com"
               aria-describedby="hostUrl-hint">
        <p id="hostUrl-hint" class="form-hint">API base URL. Use https://api.github.com for GitHub, https://gitlab.com/api/v4 for GitLab, https://dev.azure.com for Azure DevOps.</p>
      </div>
      <div class="form-group">
        <label for="displayName">Display Name</label>
        <input type="text" id="displayName" name="displayName" class="input" required
               placeholder="Company GitHub">
      </div>
      <button type="submit" class="btn btn--primary">Add Git Host</button>
    </form>
  </div>
</section>
