<section>
  {{#if configs.length}}
  <div class="data-table-wrapper">
    <table class="data-table">
      <thead>
        <tr>
          <th scope="col">{{t "admin.gitHosts.displayName"}}</th>
          <th scope="col">{{t "admin.gitHosts.type"}}</th>
          <th scope="col">{{t "admin.gitHosts.hostUrl"}}</th>
          <th scope="col">{{t "common.actions"}}</th>
        </tr>
      </thead>
      <tbody>
        {{#each configs}}
        <tr>
          <td>{{displayName}}</td>
          <td><span class="badge badge--info">{{pluginType}}</span></td>
          <td class="text-sm text-muted">{{hostUrl}}</td>
          <td>
            <button class="btn btn--sm btn--danger"
                    hx-delete="/admin/git-hosts/{{id}}"
                    hx-target="#git-host-messages"
                    hx-swap="innerHTML"
                    hx-confirm="{{t "admin.gitHosts.removeConfirm"}}">
              {{t "admin.gitHosts.remove"}}
            </button>
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{else}}
  <div class="empty-state">
    <p>{{t "admin.gitHosts.noHosts"}}</p>
  </div>
  {{/if}}

  <div id="git-host-messages"></div>

  <div class="card mt-lg">
    <h3 class="card__title mb-md">{{t "admin.gitHosts.addTitle"}}</h3>
    <form method="POST" action="/admin/git-hosts">
      <input type="hidden" name="_csrf" value="{{csrfToken}}">
      <div class="form-group">
        <label for="pluginType">{{t "admin.gitHosts.platform"}}</label>
        <select id="pluginType" name="pluginType" class="select" required>
          {{#each pluginTypes}}
          <option value="{{this}}">{{this}}</option>
          {{/each}}
        </select>
      </div>
      <div class="form-group">
        <label for="hostUrl">{{t "admin.gitHosts.hostUrl"}}</label>
        <input type="url" id="hostUrl" name="hostUrl" class="input" required
               placeholder="https://api.github.com"
               aria-describedby="hostUrl-hint">
        <p id="hostUrl-hint" class="form-hint">{{t "admin.gitHosts.hostUrlHint"}}</p>
      </div>
      <div class="form-group">
        <label for="displayName">{{t "admin.gitHosts.displayName"}}</label>
        <input type="text" id="displayName" name="displayName" class="input" required
               placeholder="{{t "admin.gitHosts.displayNamePlaceholder"}}">
      </div>
      <button type="submit" class="btn btn--primary">{{t "admin.gitHosts.addButton"}}</button>
    </form>
  </div>
</section>
