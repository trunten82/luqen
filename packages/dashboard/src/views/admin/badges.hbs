{{!--
  Admin oversight for public badges (Phase 64.1).
  Three lists: system (dogfood), static (per scan), live (per site).
  admin.system sees all orgs; admin.org sees just their own.
--}}
<section aria-label="Public badges">
  <header class="admin-badges__head">
    <h1 class="section-title">Public badges</h1>
    <p class="text-muted">
      Static badges are pinned to a single scan. Live badges resolve the
      latest completed scan for a site on every request. Revoking flips the
      badge off — the URL keeps returning the SVG for the cache TTL (5 min
      static, 1 min live), then 404s. Re-enabling a live badge keeps the
      same URL so existing embeds resume.
    </p>
  </header>

  <form method="GET" action="/admin/badges" class="admin-section" aria-label="Public badge filters">
    <div class="filter-bar filter-bar--wrap">
      {{#if isAdminSystem}}
      <div class="form-group">
        <label for="filter-org" class="form-label">Organization</label>
        <select id="filter-org" name="org" class="select select--sm">
          <option value="">All organizations</option>
          {{#each orgOptions}}
          <option value="{{id}}" {{#if (eq id ../filters.org)}}selected{{/if}}>{{name}}</option>
          {{/each}}
        </select>
      </div>
      {{/if}}
      <div class="form-group">
        <label class="admin-badges__check">
          <input type="checkbox" name="showDisabled" value="1" {{#if filters.showDisabled}}checked{{/if}}>
          <span>Show disabled live badges</span>
        </label>
      </div>
      <div class="form-group">
        <button type="submit" class="btn btn--primary btn--sm">Apply</button>
        <a href="/admin/badges" class="btn btn--ghost btn--sm">Reset</a>
      </div>
    </div>
  </form>

  {{#if systemBadge}}
  <section class="admin-badges__section" aria-labelledby="system-heading">
    <h2 id="system-heading" class="section-subtitle">
      System &mdash; dogfood
      <span class="badge badge--neutral admin-badges__pill" title="Driven by config.selfScanId — change via dashboard.config.json">Read-only · config-driven</span>
    </h2>
    <div class="table-responsive" role="region" aria-label="System badges" tabindex="0">
      <table class="data-table">
        <thead>
          <tr>
            <th scope="col">Preview</th>
            <th scope="col">Site</th>
            <th scope="col">Source</th>
            <th scope="col">Scan</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="cell--badge-preview">
              <img src="{{systemBadge.badgeUrl}}" alt="System badge preview" width="180" height="32" loading="lazy">
            </td>
            <td><a href="{{systemBadge.publicUrl}}" target="_blank" rel="noopener">{{systemBadge.siteUrl}}</a></td>
            <td><code>config.selfScanId</code> &middot; <span class="text-muted">edit via dashboard.config.json</span></td>
            <td><a href="{{systemBadge.reportUrl}}">View report &rarr;</a></td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>
  {{/if}}

  <section class="admin-badges__section" aria-labelledby="static-heading">
    <h2 id="static-heading" class="section-subtitle">Static &mdash; {{staticBadges.length}}</h2>
    {{#if staticBadges.length}}
    <div class="table-responsive" role="region" aria-label="Static badges" tabindex="0">
      <table class="data-table">
        <thead>
          <tr>
            <th scope="col">Preview</th>
            <th scope="col">Site</th>
            {{#if isAdminSystem}}<th scope="col">Org</th>{{/if}}
            <th scope="col">Enabled by</th>
            <th scope="col">Enabled at</th>
            <th scope="col">Scan</th>
            <th scope="col"><span class="screen-reader-text">Actions</span></th>
          </tr>
        </thead>
        <tbody>
          {{#each staticBadges}}
          <tr>
            <td class="cell--badge-preview">
              <img src="{{badgeUrl}}" alt="Badge preview for {{siteUrl}}" width="180" height="32" loading="lazy">
            </td>
            <td><a href="{{publicUrl}}" target="_blank" rel="noopener">{{siteUrl}}</a></td>
            {{#if @root.isAdminSystem}}<td><code>{{orgId}}</code></td>{{/if}}
            <td>{{#if enabledBy}}<code>{{enabledBy}}</code>{{else}}&mdash;{{/if}}</td>
            <td>{{#if enabledAt}}<time datetime="{{enabledAt}}">{{enabledAt}}</time>{{else}}&mdash;{{/if}}</td>
            <td><a href="{{reportUrl}}">View report &rarr;</a></td>
            <td class="cell--actions">
              <form method="POST" action="/admin/badges/static/{{scanId}}/revoke" style="display:inline">
                <input type="hidden" name="_csrf" value="{{@root.csrfToken}}">
                <button type="submit" class="btn btn--sm btn--danger" data-confirm="Revoke the static badge for {{siteUrl}}? The embedded image will start returning 404 once the cache expires.">Revoke</button>
              </form>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
    {{else}}
    <p class="empty-state__text">No static badges enabled yet.</p>
    {{/if}}
  </section>

  <section class="admin-badges__section" aria-labelledby="live-heading">
    <h2 id="live-heading" class="section-subtitle">
      Live &mdash; {{liveBadges.length}}
      {{#if hiddenDisabledCount}}<span class="text-muted admin-badges__hint"> · {{hiddenDisabledCount}} disabled hidden</span>{{/if}}
    </h2>
    {{#if liveBadges.length}}
    <div class="table-responsive" role="region" aria-label="Live badges" tabindex="0">
      <table class="data-table">
        <thead>
          <tr>
            <th scope="col">Preview</th>
            <th scope="col">Site</th>
            {{#if isAdminSystem}}<th scope="col">Org</th>{{/if}}
            <th scope="col">Status</th>
            <th scope="col">Created by</th>
            <th scope="col">Created at</th>
            <th scope="col"><span class="screen-reader-text">Actions</span></th>
          </tr>
        </thead>
        <tbody>
          {{#each liveBadges}}
          <tr>
            <td class="cell--badge-preview">
              {{#if enabled}}
              <img src="{{badgeUrl}}" alt="Badge preview for {{siteUrl}}" width="180" height="32" loading="lazy">
              {{else}}
              <span class="text-muted">disabled</span>
              {{/if}}
            </td>
            <td>
              {{siteUrl}}
              {{#if enabled}}<br><a href="{{reportUrl}}" target="_blank" rel="noopener" class="text-muted admin-badges__hint">View report &rarr;</a>{{/if}}
            </td>
            {{#if @root.isAdminSystem}}<td><code>{{orgId}}</code></td>{{/if}}
            <td>
              {{#if enabled}}
              <span class="badge badge--success">Enabled</span>
              {{else}}
              <span class="badge badge--neutral">Disabled</span>
              {{/if}}
            </td>
            <td>{{#if createdBy}}<code>{{createdBy}}</code>{{else}}&mdash;{{/if}}</td>
            <td><time datetime="{{createdAt}}">{{createdAt}}</time></td>
            <td class="cell--actions">
              {{#if enabled}}
              <form method="POST" action="/admin/badges/live/{{id}}/revoke" style="display:inline">
                <input type="hidden" name="_csrf" value="{{@root.csrfToken}}">
                <button type="submit" class="btn btn--sm btn--danger" data-confirm="Revoke the live badge for {{siteUrl}}? The embedded image will start returning 404 once the cache expires.">Revoke</button>
              </form>
              {{else}}
              <form method="POST" action="/admin/badges/live/{{id}}/enable" style="display:inline">
                <input type="hidden" name="_csrf" value="{{@root.csrfToken}}">
                <button type="submit" class="btn btn--sm btn--ghost">Enable</button>
              </form>
              {{/if}}
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
    {{else}}
    <p class="empty-state__text">No live badges enabled yet.</p>
    {{/if}}
  </section>
</section>
