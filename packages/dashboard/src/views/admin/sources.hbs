<section aria-label="Monitored sources management">
  <div class="page-actions">
    <button hx-get="/admin/sources/new"
            hx-target="#modal-container"
            hx-swap="innerHTML"
            class="btn btn--primary"
            aria-haspopup="dialog">
      {{t "admin.sources.addSource"}}
    </button>
    <button hx-post="/admin/sources/scan"
            hx-target="#scan-results"
            hx-swap="outerHTML"
            hx-indicator="#scan-spinner"
            class="btn btn--secondary"
            aria-label="Trigger scan of all monitored sources now">
      {{t "admin.sources.scanNow"}}
    </button>
    <span id="scan-spinner" class="htmx-indicator" aria-hidden="true">{{t "admin.sources.scanning"}}</span>
  </div>

  <div id="scan-results" aria-live="polite"></div>

  {{#if error}}
  <div class="alert alert--error" role="alert">
    <p>{{error}}</p>
  </div>
  {{/if}}

  <div class="table-wrapper" aria-live="polite" aria-atomic="false">
    <table aria-label="Monitored sources">
      <thead>
        <tr>
          <th scope="col">{{t "admin.sources.colName"}}</th>
          <th scope="col">{{t "admin.sources.colType"}}</th>
          <th scope="col">{{t "admin.sources.colSchedule"}}</th>
          <th scope="col">{{t "admin.sources.colLastChecked"}}</th>
          <th scope="col">{{t "common.actions"}}</th>
        </tr>
      </thead>
      <tbody id="sources-table-body">
        {{#each sources}}
        <tr id="source-{{id}}">
          <td data-label="Name">{{name}}</td>
          <td data-label="Type"><span class="badge badge--info">{{type}}</span></td>
          <td data-label="Schedule">{{schedule}}</td>
          <td data-label="Last Checked">{{#if lastChecked}}{{lastChecked}}{{else}}{{t "admin.sources.never"}}{{/if}}</td>
          <td>
            <button hx-get="/admin/sources/{{id}}/view"
                    hx-target="#modal-container"
                    hx-swap="innerHTML"
                    class="btn btn--sm btn--secondary"
                    aria-label="View {{name}}">{{t "common.view"}}</button>
          </td>
        </tr>
        {{else}}
        <tr>
          <td colspan="5">{{t "admin.sources.noSources"}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</section>
