<section aria-label="Monitored sources management">
  <div class="page-actions">
    <button hx-get="/admin/sources/new"
            hx-target="#modal-container"
            hx-swap="innerHTML"
            class="btn btn--primary"
            aria-haspopup="dialog">
      {{t "admin.sources.addSource"}}
    </button>
    <button data-action="triggerSourceScan"
            class="btn btn--secondary"
            aria-label="Trigger scan of all monitored sources now">
      {{t "admin.sources.scanNow"}}
    </button>
    <button data-action="toggleUploadForm"
            class="btn btn--secondary"
            aria-expanded="false"
            aria-controls="upload-regulation-form">
      Upload Regulation
    </button>
    {{#if llmConnected}}
    <button hx-post="/admin/sources/bulk-switch"
            hx-vals='{"mode":"llm"}'
            hx-confirm="Switch all government sources to LLM mode? They will use AI extraction on next scan."
            hx-target="#scan-results"
            hx-swap="innerHTML"
            class="btn btn--secondary"
            type="button">
      Switch All Gov &rarr; LLM
    </button>
    {{/if}}
  </div>

  <div id="upload-regulation-form" class="card mt-sm" hidden>
    <form hx-post="/admin/sources/upload"
          hx-target="#plugin-messages" hx-swap="innerHTML"
          class="card__body">
      <h3 class="card__title">Upload Regulation Document</h3>
      <p class="form-hint">Paste the text content of a regulatory document. The LLM service will extract WCAG requirements and create a proposal for review.</p>
      {{#if llmConnected}}
      <div class="alert alert--success" role="status" aria-label="LLM service status">
        LLM Service: <strong>Connected</strong>
      </div>
      {{else}}
      <div class="alert alert--warning" role="status" aria-label="LLM service status">
        LLM Service: <strong>Not configured</strong> &mdash;
        set <code>DASHBOARD_LLM_URL</code> and configure a provider in
        <a href="/admin/llm">LLM Config</a>.
      </div>
      {{/if}}
      <div class="form-group">
        <label for="upload-name">Document Name</label>
        <input type="text" id="upload-name" name="name" class="input" required placeholder="e.g. Section 508 ICT Standards" />
      </div>
      <div class="form-group">
        <label for="upload-reg">Regulation ID (optional)</label>
        <input type="text" id="upload-reg" name="regulationId" class="input" placeholder="e.g. US-508" />
        <small class="form-hint">Links extracted requirements to an existing regulation</small>
      </div>
      <div class="form-group">
        <label for="upload-jurisdiction">Jurisdiction (optional)</label>
        <input type="text" id="upload-jurisdiction" name="jurisdictionId" class="input" placeholder="e.g. US" />
      </div>
      <div class="form-group">
        <label for="upload-content">Document Content</label>
        <textarea id="upload-content" name="content" class="input" rows="10" required
                  placeholder="Paste the regulation text here..."></textarea>
      </div>
      <div class="form-actions">
        <button type="submit" class="btn btn--primary" {{#unless llmConnected}}disabled{{/unless}}>Extract Requirements</button>
      </div>
    </form>
  </div>

  <div id="scan-results" aria-live="polite"></div>

  {{#if error}}
  <div class="alert alert--error" role="alert">
    <p>{{error}}</p>
  </div>
  {{/if}}

  <div class="table-wrapper" aria-live="polite" aria-atomic="false">
    <table class="table" aria-label="Monitored sources">
      <thead>
        <tr>
          <th scope="col">{{t "admin.sources.colName"}}</th>
          <th scope="col">Parser</th>
          <th scope="col">{{t "admin.sources.colSchedule"}}</th>
          <th scope="col">{{t "admin.sources.colLastChecked"}}</th>
          <th scope="col">{{t "common.owner"}}</th>
          <th scope="col">Status</th>
          <th scope="col">{{t "common.actions"}}</th>
        </tr>
      </thead>
      <tbody id="sources-table-body">
        {{#each sources}}
        <tr id="source-{{id}}">
          <td data-label="Name" class="cell--wrap">{{name}}</td>
          <td data-label="Parser">
            {{#if (eq sourceCategory "government")}}
              {{#if (eq managementMode "llm")}}
              <span class="badge badge--info">LLM</span>
              <button hx-post="/admin/sources/{{id}}/mode"
                      hx-vals='{"mode":"manual"}'
                      hx-target="#scan-results"
                      hx-swap="innerHTML"
                      class="btn btn--xs btn--ghost"
                      type="button"
                      title="Switch to manual">&rarr; Manual</button>
              {{else}}
              <span class="badge badge--neutral">Manual</span>
              <button hx-post="/admin/sources/{{id}}/mode"
                      hx-vals='{"mode":"llm"}'
                      hx-target="#scan-results"
                      hx-swap="innerHTML"
                      class="btn btn--xs btn--ghost"
                      type="button"
                      title="Switch to LLM"
                      {{#unless ../llmConnected}}disabled{{/unless}}>&rarr; LLM</button>
              {{/if}}
            {{else if (eq sourceCategory "w3c-policy")}}<span class="badge badge--success">W3C</span>
            {{else if (eq sourceCategory "wcag-upstream")}}<span class="badge badge--success">WCAG</span>
            {{else}}<span class="badge badge--neutral">Generic</span>
            {{/if}}
          </td>
          <td data-label="Schedule">{{schedule}}</td>
          <td data-label="Last Checked">{{#if lastCheckedAt}}{{lastCheckedAt}}{{else}}{{t "admin.sources.never"}}{{/if}}</td>
          <td data-label="Owner">
            {{#if (eq orgId "system")}}<span class="badge badge--neutral">System</span>{{else}}{{orgId}}{{/if}}
          </td>
          <td data-label="Status">
            {{#if (eq status "degraded")}}
            <span class="badge badge--warning">Degraded</span>
            {{else}}
            <span class="badge badge--success">Active</span>
            {{/if}}
          </td>
          <td>
            <button hx-get="/admin/sources/{{id}}/view"
                    hx-target="#modal-container"
                    hx-swap="innerHTML"
                    class="btn btn--sm btn--secondary"
                    aria-label="View {{name}}">{{t "common.view"}}</button>
          </td>
        </tr>
        {{else}}
        <tr>
          <td colspan="7">{{t "admin.sources.noSources"}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</section>
