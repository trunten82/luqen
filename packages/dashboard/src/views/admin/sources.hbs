<section aria-label="Monitored sources management">
  <div class="page-actions">
    <button hx-get="/admin/sources/new"
            hx-target="#modal-container"
            hx-swap="innerHTML"
            class="btn btn--primary"
            aria-haspopup="dialog">
      {{t "admin.sources.addSource"}}
    </button>
    <button data-action="triggerSourceScan"
            class="btn btn--secondary"
            aria-label="Trigger scan of all monitored sources now">
      {{t "admin.sources.scanNow"}}
    </button>
    <button data-action="toggleUploadForm"
            class="btn btn--secondary"
            aria-expanded="false"
            aria-controls="upload-regulation-form">
      Upload Regulation
    </button>
  </div>

  <div id="upload-regulation-form" class="card mt-sm" hidden>
    <form hx-post="/admin/sources/upload"
          hx-target="#plugin-messages" hx-swap="innerHTML"
          class="card__body">
      <h3 class="card__title">Upload Regulation Document</h3>
      <p class="form-hint">Paste the text content of a regulatory document. The selected LLM will extract WCAG requirements and create a proposal for review.</p>
      {{#if hasLlm}}
      <div class="form-group">
        <label for="upload-llm">LLM Provider</label>
        <select id="upload-llm" name="pluginId" class="input" required>
          {{#each llmPlugins}}
          <option value="{{id}}">{{name}}</option>
          {{/each}}
        </select>
        <small class="form-hint">Choose which LLM processes this document</small>
      </div>
      {{else}}
      <div class="alert alert--warning">No active LLM plugin. Activate one in Plugins first.</div>
      {{/if}}
      <div class="form-group">
        <label for="upload-name">Document Name</label>
        <input type="text" id="upload-name" name="name" class="input" required placeholder="e.g. Section 508 ICT Standards" />
      </div>
      <div class="form-group">
        <label for="upload-reg">Regulation ID (optional)</label>
        <input type="text" id="upload-reg" name="regulationId" class="input" placeholder="e.g. US-508" />
        <small class="form-hint">Links extracted requirements to an existing regulation</small>
      </div>
      <div class="form-group">
        <label for="upload-jurisdiction">Jurisdiction (optional)</label>
        <input type="text" id="upload-jurisdiction" name="jurisdictionId" class="input" placeholder="e.g. US" />
      </div>
      <div class="form-group">
        <label for="upload-content">Document Content</label>
        <textarea id="upload-content" name="content" class="input" rows="10" required
                  placeholder="Paste the regulation text here..."></textarea>
      </div>
      <div class="form-actions">
        <button type="submit" class="btn btn--primary" {{#unless hasLlm}}disabled{{/unless}}>Extract Requirements</button>
      </div>
    </form>
  </div>

  <div id="scan-results" aria-live="polite"></div>

  {{#if error}}
  <div class="alert alert--error" role="alert">
    <p>{{error}}</p>
  </div>
  {{/if}}

  <div class="table-wrapper" aria-live="polite" aria-atomic="false">
    <table class="table" aria-label="Monitored sources">
      <thead>
        <tr>
          <th scope="col">{{t "admin.sources.colName"}}</th>
          <th scope="col">{{t "admin.sources.colType"}}</th>
          <th scope="col">{{t "admin.sources.colSchedule"}}</th>
          <th scope="col">{{t "admin.sources.colLastChecked"}}</th>
          <th scope="col">{{t "common.owner"}}</th>
          <th scope="col">{{t "common.actions"}}</th>
        </tr>
      </thead>
      <tbody id="sources-table-body">
        {{#each sources}}
        <tr id="source-{{id}}">
          <td data-label="Name">{{name}}</td>
          <td data-label="Type"><span class="badge badge--info">{{type}}</span></td>
          <td data-label="Schedule">{{schedule}}</td>
          <td data-label="Last Checked">{{#if lastCheckedAt}}{{lastCheckedAt}}{{else}}{{t "admin.sources.never"}}{{/if}}</td>
          <td data-label="Owner">
            {{#if (eq orgId "system")}}<span class="badge badge--neutral">System</span>{{else}}{{orgId}}{{/if}}
          </td>
          <td>
            <button hx-get="/admin/sources/{{id}}/view"
                    hx-target="#modal-container"
                    hx-swap="innerHTML"
                    class="btn btn--sm btn--secondary"
                    aria-label="View {{name}}">{{t "common.view"}}</button>
          </td>
        </tr>
        {{else}}
        <tr>
          <td colspan="6">{{t "admin.sources.noSources"}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</section>
