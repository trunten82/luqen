<section aria-label="Webhooks management">
  <div class="page-actions">
    <button hx-get="/admin/webhooks/new"
            hx-target="#modal-container"
            hx-swap="innerHTML"
            class="btn btn--primary"
            aria-haspopup="dialog">
      {{t "admin.webhooks.addWebhook"}}
    </button>
  </div>

  {{#if error}}
  <div class="alert alert--error" role="alert">
    <p>{{error}}</p>
  </div>
  {{/if}}

  <div class="table-wrapper" aria-live="polite" aria-atomic="false">
    <table class="table" aria-label="Webhooks">
      <thead>
        <tr>
          <th scope="col">{{t "admin.webhooks.url"}}</th>
          <th scope="col">{{t "admin.webhooks.events"}}</th>
          <th scope="col">{{t "common.status"}}</th>
          <th scope="col">{{t "admin.webhooks.created"}}</th>
          <th scope="col">{{t "common.actions"}}</th>
        </tr>
      </thead>
      <tbody id="webhooks-table-body">
        {{#each webhooks}}
        <tr id="webhook-{{id}}">
          <td data-label="URL"><a href="{{url}}" target="_blank" rel="noopener noreferrer">{{url}}</a></td>
          <td data-label="Events">{{eventsDisplay}}</td>
          <td data-label="Status">
            <span class="badge {{#if active}}badge--success{{else}}badge--neutral{{/if}}">
              {{#if active}}{{t "common.active"}}{{else}}{{t "common.inactive"}}{{/if}}
            </span>
          </td>
          <td data-label="Created">{{createdAtDisplay}}</td>
          <td>
            <button hx-post="/admin/webhooks/{{id}}/test"
                    hx-target="#toast-container"
                    hx-swap="innerHTML"
                    class="btn btn--sm btn--secondary"
                    aria-label="Send test delivery to {{url}}">{{t "admin.webhooks.test"}}</button>
            <button hx-delete="/admin/webhooks/{{id}}"
                    hx-confirm="Delete this webhook?"
                    hx-target="closest tr"
                    hx-swap="outerHTML swap:500ms"
                    class="btn btn--sm btn--danger"
                    aria-label="Delete webhook {{url}}">{{t "common.delete"}}</button>
          </td>
        </tr>
        {{else}}
        <tr>
          <td colspan="5" class="table__empty">{{t "admin.webhooks.noWebhooks"}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</section>
