<div class="modal-overlay" role="dialog" aria-modal="true" aria-labelledby="modal-title">
  <div class="modal">
    <h2 id="modal-title">{{t "admin.orgApiKeys.createButton"}}</h2>

    <form hx-post="/admin/org-api-keys"
          hx-target="#org-api-keys-body"
          hx-swap="beforeend"
          novalidate>
      <input type="hidden" name="_csrf" value="{{csrfToken}}">

      <div class="form-group">
        <label for="oak-label" class="form-label">{{t "admin.orgApiKeys.label"}} <span aria-hidden="true">*</span></label>
        <input id="oak-label" name="label" type="text" class="input"
               required aria-required="true" value="default"
               placeholder="e.g. CI pipeline, monitoring">
      </div>

      <div class="form-group">
        <label for="oak-role" class="form-label">{{t "admin.orgApiKeys.role"}}</label>
        <select id="oak-role" name="role" class="select">
          <option value="admin">Admin (200 req/min)</option>
          <option value="read-only" selected>Read Only (100 req/min)</option>
          <option value="scan-only">Scan Only (50 req/min)</option>
        </select>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn--primary">{{t "admin.orgApiKeys.createButton"}}</button>
        <button type="button" class="btn btn--ghost close-modal-btn"
                aria-label="Cancel and close dialog">{{t "common.cancel"}}</button>
      </div>
    </form>
  </div>
</div>
