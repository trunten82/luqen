<section aria-label="Organization members management">
  <div class="admin-header">
    <h1 class="page-title">{{t "admin.organizations.membersTitle"}} &mdash; {{org.name}}</h1>
    <a href="/admin/organizations" class="btn btn--ghost" aria-label="Back to organizations list">
      &larr; {{t "admin.organizations.backToOrganizations"}}
    </a>
  </div>

  <table class="table" aria-label="Organization members list"{{#unless members.length}} style="display:none"{{/unless}} id="org-members-wrapper">
    <thead>
      <tr>
        <th scope="col">{{t "admin.organizations.username"}}</th>
        <th scope="col">{{t "admin.organizations.role"}}</th>
        <th scope="col">{{t "admin.organizations.joined"}}</th>
        <th scope="col">{{t "common.actions"}}</th>
      </tr>
    </thead>
    <tbody id="org-members-table">
      {{#each members}}
      <tr id="member-{{this.userId}}">
        <td data-label="Username">{{this.username}}</td>
        <td data-label="Role"><span class="badge badge--neutral">{{this.role}}</span></td>
        <td data-label="Joined">{{this.joinedAt}}</td>
        <td>
          <button hx-post="/admin/organizations/{{../org.id}}/members/{{this.userId}}/remove"
                  hx-confirm="Remove {{this.username}} from this organization?"
                  hx-target="closest tr"
                  hx-swap="outerHTML"
                  class="btn btn--sm btn--warning"
                  aria-label="Remove {{this.username}}">
            {{t "admin.organizations.remove"}}
          </button>
        </td>
      </tr>
      {{/each}}
    </tbody>
  </table>
  {{#unless members.length}}
  <div class="empty-state" role="status" id="org-no-members">
    <p>{{t "admin.organizations.noMembers"}}</p>
  </div>
  {{/unless}}

  {{#if availableUsers.length}}
  <div class="card" style="margin-top: 1.5rem;">
    <h2 class="card__title">{{t "admin.organizations.addMember"}}</h2>
    <form hx-post="/admin/organizations/{{org.id}}/members"
          hx-target="#org-members-table"
          hx-swap="beforeend"
          class="form-inline">
      <input type="hidden" name="_csrf" value="{{csrfToken}}">

      <div class="form-group">
        <label for="add-member-user" class="form-label">{{t "admin.organizations.user"}}</label>
        <select id="add-member-user" name="userId" class="select" required aria-required="true">
          <option value="">{{t "admin.organizations.selectUser"}}</option>
          {{#each availableUsers}}
          <option value="{{this.id}}">{{this.username}}</option>
          {{/each}}
        </select>
      </div>

      <div class="form-group">
        <label for="add-member-role" class="form-label">{{t "admin.organizations.role"}}</label>
        <select id="add-member-role" name="role" class="select" required aria-required="true">
          {{#each roles}}
          <option value="{{this}}">{{this}}</option>
          {{/each}}
        </select>
      </div>

      <button type="submit" class="btn btn--primary">{{t "admin.organizations.addMember"}}</button>
    </form>
  </div>
  {{/if}}

  <div id="toast"></div>
</section>
