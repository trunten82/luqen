<section aria-label="Organization members management">
  <div class="admin-header">
    <h1 class="page-title">{{t "admin.organizations.membersTitle"}} &mdash; {{org.name}}</h1>
    <a href="/admin/organizations" class="btn btn--ghost" aria-label="Back to organizations list">
      &larr; {{t "admin.organizations.backToOrganizations"}}
    </a>
  </div>

  {{! ---- Manage via Teams notice ---- }}
  <div class="alert alert--info mt-md" role="alert">
    <strong>Manage via Teams:</strong> Organization membership is managed through teams.
    Add users to a team linked to this organization to grant access.
    <a href="/admin/teams" class="btn btn--sm btn--ghost ml-sm">Go to Teams</a>
  </div>

  {{! ---- Organization Members (via teams) ---- }}
  <h2 class="mt-lg">{{t "admin.organizations.orgMembers"}}</h2>
  <p class="text-muted mb-md">{{t "admin.organizations.orgMembersDescription"}}</p>

  {{#if members.length}}
  <table class="table" aria-label="Organization members" id="org-members-wrapper"
         hx-get="/admin/organizations/{{org.id}}/members" hx-trigger="memberChanged from:body" hx-select="#org-members-wrapper" hx-swap="outerHTML">
    <thead>
      <tr>
        <th scope="col">{{t "admin.organizations.username"}}</th>
        <th scope="col">{{t "admin.organizations.role"}}</th>
        <th scope="col">{{t "admin.organizations.team"}}</th>
        <th scope="col">{{t "common.actions"}}</th>
      </tr>
    </thead>
    <tbody id="org-members-table">
      {{#each members}}
      <tr id="member-{{this.userId}}">
        <td data-label="Username">{{this.username}}</td>
        <td data-label="Role"><span class="badge badge--neutral">{{this.role}}</span></td>
        <td data-label="Team">
          {{#if this.teamName}}<span class="badge badge--info">{{this.teamName}}</span>{{else}}<span class="badge badge--neutral">{{t "admin.organizations.directMember"}}</span>{{/if}}
        </td>
        <td>
          <button hx-post="/admin/organizations/{{../org.id}}/members/{{this.userId}}/remove"
                  hx-confirm="{{t 'admin.organizations.confirmRemove'}} {{this.username}}?"
                  hx-target="closest tr"
                  hx-swap="outerHTML"
                  class="btn btn--sm btn--warning"
                  aria-label="Remove {{this.username}}">
            {{t "admin.organizations.remove"}}
          </button>
        </td>
      </tr>
      {{/each}}
    </tbody>
  </table>
  {{else}}
  <div class="empty-state" role="status" id="org-no-members">
    <p>{{t "admin.organizations.noMembers"}}</p>
  </div>
  {{/if}}

  {{! ---- Add Member to Team ---- }}
  {{#if linkedTeams.length}}
  {{#if availableUsers.length}}
  <div class="card mt-lg">
    <h2 class="card__title">{{t "admin.organizations.addMemberToTeam"}}</h2>
    <form hx-post="/admin/organizations/{{org.id}}/members/add-to-team"
          hx-target="#toast"
          hx-swap="innerHTML">
      <input type="hidden" name="_csrf" value="{{csrfToken}}">

      <div class="form-group">
        <label for="add-member-user" class="form-label">{{t "admin.organizations.user"}}</label>
        <select id="add-member-user" name="userId" class="select" required aria-required="true">
          <option value="">{{t "admin.organizations.selectUser"}}</option>
          {{#each availableUsers}}
          <option value="{{this.id}}">{{this.username}}</option>
          {{/each}}
        </select>
      </div>

      <div class="form-group">
        <label for="add-member-team" class="form-label">{{t "admin.organizations.team"}}</label>
        <select id="add-member-team" name="teamId" class="select" required aria-required="true">
          <option value="">{{t "admin.organizations.selectTeam"}}</option>
          {{#each linkedTeams}}
          <option value="{{this.id}}">{{this.name}} ({{this.roleName}})</option>
          {{/each}}
        </select>
      </div>

      <button type="submit" class="btn btn--primary">{{t "admin.organizations.addMemberToTeam"}}</button>
    </form>
  </div>
  {{/if}}
  {{/if}}

  {{! ---- Linked Teams with Roles ---- }}
  <h2 class="mt-xl">{{t "admin.organizations.linkedTeams"}}</h2>

  {{#if linkedTeams.length}}
  <table class="table" aria-label="Teams linked to this organization">
    <thead>
      <tr>
        <th scope="col">{{t "admin.organizations.team"}}</th>
        <th scope="col">{{t "admin.organizations.orgRole"}}</th>
        <th scope="col">{{t "admin.teams.members"}}</th>
      </tr>
    </thead>
    <tbody>
      {{#each linkedTeams}}
      <tr>
        <td data-label="Team"><a href="/admin/teams/{{this.id}}">{{this.name}}</a></td>
        <td data-label="Role"><span class="badge badge--neutral">{{this.roleName}}</span></td>
        <td data-label="Members"><span class="badge badge--neutral">{{this.memberCount}}</span></td>
      </tr>
      {{/each}}
    </tbody>
  </table>
  {{else}}
  <div class="empty-state" role="status">
    <p>{{t "admin.organizations.noLinkedTeams"}}</p>
  </div>
  {{/if}}

  <div class="mt-md">
    <a href="/admin/teams" class="btn btn--ghost">{{t "admin.organizations.manageTeams"}}</a>
  </div>

  {{! ---- Org-Scoped Roles ---- }}
  <h2 class="mt-xl">{{t "admin.organizations.orgRoles"}}</h2>
  <p class="text-muted mb-md">{{t "admin.organizations.orgRolesDescription"}}</p>

  {{#if orgRoles.length}}
  <table class="table" aria-label="Organization roles">
    <thead>
      <tr>
        <th scope="col">{{t "admin.organizations.roleName"}}</th>
        <th scope="col">{{t "admin.organizations.roleDescription"}}</th>
        <th scope="col">{{t "admin.organizations.rolePermissions"}}</th>
      </tr>
    </thead>
    <tbody>
      {{#each orgRoles}}
      <tr>
        <td data-label="Name"><strong>{{this.name}}</strong></td>
        <td data-label="Description">{{this.description}}</td>
        <td data-label="Permissions"><span class="badge badge--neutral">{{this.permissions.length}}</span></td>
      </tr>
      {{/each}}
    </tbody>
  </table>
  {{else}}
  <div class="empty-state" role="status">
    <p>{{t "admin.organizations.noOrgRoles"}}</p>
  </div>
  {{/if}}

  <div id="toast"></div>
</section>
