<section aria-label="Organization members management">
  <div class="admin-header">
    <h1 class="page-title">{{t "admin.organizations.membersTitle"}} &mdash; {{org.name}}</h1>
    <a href="/admin/organizations" class="btn btn--ghost" aria-label="Back to organizations list">
      &larr; {{t "admin.organizations.backToOrganizations"}}
    </a>
  </div>

  {{! ---- Direct Members ---- }}
  <h2 style="margin-top:1.5rem;">Direct Members</h2>

  <table class="table" aria-label="Direct organization members"{{#unless members.length}} style="display:none"{{/unless}} id="org-members-wrapper">
    <thead>
      <tr>
        <th scope="col">{{t "admin.organizations.username"}}</th>
        <th scope="col">{{t "admin.organizations.role"}}</th>
        <th scope="col">{{t "admin.organizations.joined"}}</th>
        <th scope="col">{{t "common.actions"}}</th>
      </tr>
    </thead>
    <tbody id="org-members-table">
      {{#each members}}
      <tr id="member-{{this.userId}}">
        <td data-label="Username">{{this.username}}</td>
        <td data-label="Role"><span class="badge badge--neutral">{{this.role}}</span></td>
        <td data-label="Joined">{{this.joinedAt}}</td>
        <td>
          <button hx-post="/admin/organizations/{{../org.id}}/members/{{this.userId}}/remove"
                  hx-confirm="Remove {{this.username}} from this organization?"
                  hx-target="closest tr"
                  hx-swap="outerHTML"
                  class="btn btn--sm btn--warning"
                  aria-label="Remove {{this.username}}">
            {{t "admin.organizations.remove"}}
          </button>
        </td>
      </tr>
      {{/each}}
    </tbody>
  </table>
  {{#unless members.length}}
  <div class="empty-state" role="status" id="org-no-members">
    <p>{{t "admin.organizations.noMembers"}}</p>
  </div>
  {{/unless}}

  {{#if availableUsers.length}}
  <div class="card" style="margin-top: 1.5rem;">
    <h2 class="card__title">{{t "admin.organizations.addMember"}}</h2>
    <form hx-post="/admin/organizations/{{org.id}}/members"
          hx-target="#org-members-table"
          hx-swap="beforeend"
          class="form-inline">
      <input type="hidden" name="_csrf" value="{{csrfToken}}">

      <div class="form-group">
        <label for="add-member-user" class="form-label">{{t "admin.organizations.user"}}</label>
        <select id="add-member-user" name="userId" class="select" required aria-required="true">
          <option value="">{{t "admin.organizations.selectUser"}}</option>
          {{#each availableUsers}}
          <option value="{{this.id}}">{{this.username}}</option>
          {{/each}}
        </select>
      </div>

      <div class="form-group">
        <label for="add-member-role" class="form-label">{{t "admin.organizations.role"}}</label>
        <select id="add-member-role" name="role" class="select" required aria-required="true">
          {{#each roles}}
          <option value="{{this}}">{{this}}</option>
          {{/each}}
        </select>
      </div>

      <button type="submit" class="btn btn--primary">{{t "admin.organizations.addMember"}}</button>
    </form>
  </div>
  {{/if}}

  {{! ---- Team Members (inherited) ---- }}
  <h2 style="margin-top:2rem;">Team Members (inherited)</h2>
  <p class="text-muted" style="margin-bottom:0.75rem;">These users are members of this organization through their team membership. Direct member roles take priority.</p>

  {{#if inheritedMembers.length}}
  <table class="table" aria-label="Team-inherited organization members">
    <thead>
      <tr>
        <th scope="col">{{t "admin.organizations.username"}}</th>
        <th scope="col">{{t "admin.organizations.role"}}</th>
        <th scope="col">Via Team</th>
        <th scope="col">Source</th>
      </tr>
    </thead>
    <tbody>
      {{#each inheritedMembers}}
      <tr>
        <td data-label="Username">{{this.username}}</td>
        <td data-label="Role"><span class="badge badge--neutral">{{this.role}}</span></td>
        <td data-label="Via Team">{{this.teamName}}</td>
        <td data-label="Source"><span class="badge badge--info">team</span></td>
      </tr>
      {{/each}}
    </tbody>
  </table>
  {{else}}
  <div class="empty-state" role="status">
    <p>No team-inherited members. Link teams to this organization to see inherited members here.</p>
  </div>
  {{/if}}

  {{! ---- Linked Teams ---- }}
  <h2 style="margin-top:2rem;">Linked Teams</h2>

  {{#if linkedTeams.length}}
  <table class="table" aria-label="Teams linked to this organization">
    <thead>
      <tr>
        <th scope="col">Team</th>
        <th scope="col">{{t "admin.teams.members"}}</th>
      </tr>
    </thead>
    <tbody>
      {{#each linkedTeams}}
      <tr>
        <td data-label="Team"><a href="/admin/teams/{{this.id}}">{{this.name}}</a></td>
        <td data-label="Members"><span class="badge badge--neutral">{{this.memberCount}}</span></td>
      </tr>
      {{/each}}
    </tbody>
  </table>
  {{else}}
  <div class="empty-state" role="status">
    <p>No teams linked to this organization. Assign teams from the <a href="/admin/teams">Teams</a> page.</p>
  </div>
  {{/if}}

  <div id="toast"></div>
</section>
