<div class="modal-overlay" role="dialog" aria-modal="true" aria-labelledby="modal-title">
  <div class="modal">
    <h2 id="modal-title">{{t "admin.webhooks.addWebhook"}}</h2>

    <form hx-post="/admin/webhooks"
          hx-target="#webhooks-table-body"
          hx-swap="beforeend"
          novalidate>
      <input type="hidden" name="_csrf" value="{{csrfToken}}">

      <div class="form-group">
        <label for="wh-url" class="form-label">{{t "admin.webhooks.endpointUrl"}} <span aria-hidden="true">*</span></label>
        <input id="wh-url" name="url" type="url" class="input"
               required aria-required="true"
               placeholder="https://example.com/webhook">
      </div>

      <fieldset class="form-group">
        <legend class="form-label">{{t "admin.webhooks.events"}}</legend>
        {{#each availableEvents}}
        <label class="checkbox-label">
          <input type="checkbox" name="events" value="{{this}}">
          {{this}}
        </label>
        {{/each}}
      </fieldset>

      <div class="form-group">
        <label for="wh-secret" class="form-label">{{t "admin.webhooks.secret"}}</label>
        <input id="wh-secret" name="secret" type="password" class="input"
               autocomplete="new-password"
               aria-describedby="wh-secret-hint">
        <span id="wh-secret-hint" class="form-hint">{{t "admin.webhooks.secretHint"}}</span>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn--primary">{{t "admin.webhooks.addWebhook"}}</button>
        <button type="button" class="btn btn--ghost close-modal-btn"
                aria-label="Cancel and close dialog">{{t "common.cancel"}}</button>
      </div>
    </form>
  </div>
</div>
