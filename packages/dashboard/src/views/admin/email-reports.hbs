<section aria-label="Email Reports management">
  <h2>{{t "admin.emailReports.title"}}</h2>

  {{!-- Email Plugin Status --}}
  <div class="card mb-lg">
    <h3>{{t "admin.emailReports.emailSendingConfig"}}</h3>
    {{#if emailPluginActive}}
    <div class="alert alert--success mb-md">
      <strong>{{t "admin.emailReports.pluginActive"}}</strong>
      {{{t "admin.emailReports.pluginActiveNote"}}}
    </div>
    {{else}}
    <div class="alert alert--warning mb-md">
      {{{t "admin.emailReports.pluginInactiveNote"}}}
    </div>
    {{/if}}
  </div>

  {{!-- Legacy SMTP Configuration (shown only when plugin is NOT active) --}}
  {{#unless emailPluginActive}}
  <div class="card mb-lg">
    <h3>{{t "admin.emailReports.smtpLegacy"}}</h3>
    <p class="text-muted text-sm mb-md">
      {{t "admin.emailReports.smtpDescription"}}
      {{#unless smtpConfigured}}<strong>{{t "admin.emailReports.smtpNotConfigured"}}</strong>{{/unless}}
    </p>

    <form hx-post="/admin/email-reports/smtp"
          hx-target="#toast-container"
          hx-swap="innerHTML"
          class="form-grid">
      <input type="hidden" name="_csrf" value="{{csrfToken}}">

      <div class="form-group">
        <label for="smtp-host">{{t "admin.emailReports.smtpHost"}}</label>
        <input type="text" id="smtp-host" name="host" class="input"
               value="{{smtpConfig.host}}" placeholder="smtp.example.com" required
               aria-required="true">
      </div>

      <div class="form-group">
        <label for="smtp-port">{{t "admin.emailReports.smtpPort"}}</label>
        <input type="number" id="smtp-port" name="port" class="input"
               value="{{smtpConfig.port}}" placeholder="587" min="1" max="65535" required
               aria-required="true">
      </div>

      <div class="form-group">
        <label for="smtp-username">{{t "admin.emailReports.smtpUsername"}}</label>
        <input type="text" id="smtp-username" name="username" class="input"
               value="{{smtpConfig.username}}" placeholder="user@example.com" required
               aria-required="true">
      </div>

      <div class="form-group">
        <label for="smtp-password">{{t "admin.emailReports.smtpPassword"}}</label>
        <input type="password" id="smtp-password" name="password" class="input"
               value="{{smtpConfig.password}}" placeholder="••••••••" required
               aria-required="true">
      </div>

      <div class="form-group">
        <label for="smtp-from-address">{{t "admin.emailReports.smtpFromAddress"}}</label>
        <input type="email" id="smtp-from-address" name="fromAddress" class="input"
               value="{{smtpConfig.fromAddress}}" placeholder="noreply@example.com" required
               aria-required="true">
      </div>

      <div class="form-group">
        <label for="smtp-from-name">{{t "admin.emailReports.smtpFromName"}}</label>
        <input type="text" id="smtp-from-name" name="fromName" class="input"
               value="{{smtpConfig.fromName}}" placeholder="{{t "admin.emailReports.smtpFromNamePlaceholder"}}">
      </div>

      <div class="form-group">
        <label class="checkbox-label">
          <input type="checkbox" id="smtp-secure" name="secure"
                 {{#if smtpConfig.secure}}checked{{/if}}>
          {{t "admin.emailReports.smtpUseTls"}}
        </label>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn--primary">{{t "admin.emailReports.saveSmtp"}}</button>
        <button type="button"
                hx-post="/admin/email-reports/smtp/test"
                hx-target="#toast-container"
                hx-swap="innerHTML"
                hx-include="[name='_csrf']"
                class="btn btn--secondary">{{t "admin.emailReports.testConnection"}}</button>
      </div>
    </form>
  </div>
  {{/unless}}

  {{!-- Create Email Report --}}
  <div class="card mb-lg">
    <h3>{{t "admin.emailReports.createSchedule"}}</h3>

    <form hx-post="/admin/email-reports"
          hx-target="#email-reports-table-body"
          hx-swap="beforeend"
          class="form-grid">
      <input type="hidden" name="_csrf" value="{{csrfToken}}">

      <div class="form-group">
        <label for="report-name">{{t "admin.emailReports.reportName"}}</label>
        <input type="text" id="report-name" name="name" class="input"
               placeholder="{{t "admin.emailReports.reportNamePlaceholder"}}" required
               aria-required="true">
      </div>

      <div class="form-group">
        <label for="report-site-url">{{t "admin.emailReports.siteUrl"}}</label>
        <input type="url" id="report-site-url" name="siteUrl" class="input"
               placeholder="https://example.com" required
               aria-required="true">
      </div>

      <div class="form-group form-group--full">
        <label for="report-recipients" class="form-label">{{t "admin.emailReports.recipients"}}</label>
        <input type="text" id="report-recipients" name="recipients" class="input"
               placeholder="{{t "admin.emailReports.recipientsPlaceholder"}}" required
               aria-required="true">
      </div>

      <div class="form-group">
        <label for="report-frequency">{{t "admin.emailReports.frequency"}}</label>
        <select id="report-frequency" name="frequency" class="select">
          <option value="daily">{{t "admin.emailReports.daily"}}</option>
          <option value="weekly" selected>{{t "admin.emailReports.weekly"}}</option>
          <option value="monthly">{{t "admin.emailReports.monthly"}}</option>
        </select>
      </div>

      <div class="form-group">
        <label for="report-format">{{t "admin.emailReports.attachmentFormat"}}</label>
        <select id="report-format" name="format" class="select">
          <option value="pdf" selected>{{t "admin.emailReports.htmlReport"}}</option>
          <option value="csv">{{t "admin.emailReports.csvOnly"}}</option>
          <option value="both">{{t "admin.emailReports.htmlAndCsv"}}</option>
        </select>
      </div>

      <div class="form-group">
        <label class="checkbox-label">
          <input type="checkbox" id="report-include-csv" name="includeCsv">
          {{t "admin.emailReports.includeCsv"}}
        </label>
      </div>

      <div class="form-group">
        <label class="checkbox-label">
          <input type="checkbox" id="report-include-warnings" name="includeWarnings" checked>
          {{t "admin.emailReports.includeWarnings"}}
        </label>
      </div>

      <div class="form-group">
        <label class="checkbox-label">
          <input type="checkbox" id="report-include-notices" name="includeNotices" checked>
          {{t "admin.emailReports.includeNotices"}}
        </label>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn--primary">{{t "admin.emailReports.createScheduleBtn"}}</button>
      </div>
    </form>
  </div>

  {{!-- Email Report Schedules Table --}}
  <div class="card">
    <h3>{{t "admin.emailReports.scheduledReports"}}</h3>
    <div class="table-wrapper" aria-live="polite" aria-atomic="false">
      <table class="table" aria-label="Email report schedules">
        <thead>
          <tr>
            <th scope="col">{{t "common.name"}}</th>
            <th scope="col">{{t "admin.emailReports.siteUrl"}}</th>
            <th scope="col">{{t "admin.emailReports.recipients"}}</th>
            <th scope="col">{{t "admin.emailReports.frequency"}}</th>
            <th scope="col">{{t "admin.emailReports.format"}}</th>
            <th scope="col">{{t "admin.emailReports.nextSend"}}</th>
            <th scope="col">{{t "admin.emailReports.lastSent"}}</th>
            <th scope="col">{{t "common.status"}}</th>
            <th scope="col">{{t "common.actions"}}</th>
          </tr>
        </thead>
        <tbody id="email-reports-table-body">
          {{#each reports}}
          <tr id="report-row-{{id}}">
            <td data-label="Name">{{name}}</td>
            <td data-label="Site URL">{{siteUrl}}</td>
            <td data-label="Recipients">{{recipients}}</td>
            <td data-label="Frequency">{{frequency}}</td>
            <td data-label="Format">{{format}}</td>
            <td data-label="Next Send">{{nextSendAtDisplay}}</td>
            <td data-label="Last Sent">{{lastSentAtDisplay}}</td>
            <td data-label="Status" id="status-{{id}}">
              <span class="badge {{enabledClass}}">{{enabledLabel}}</span>
            </td>
            <td>
              <button hx-patch="/admin/email-reports/{{id}}/toggle"
                      hx-target="#report-row-{{id}}"
                      hx-swap="outerHTML"
                      hx-include="[name='_csrf']"
                      class="btn btn--sm btn--secondary"
                      id="toggle-btn-{{id}}">{{#if enabled}}{{t "admin.emailReports.disable"}}{{else}}{{t "admin.emailReports.enable"}}{{/if}}</button>
              <button hx-post="/admin/email-reports/{{id}}/send-now"
                      hx-target="#toast-container"
                      hx-swap="innerHTML"
                      hx-include="[name='_csrf']"
                      class="btn btn--sm btn--secondary"
                      aria-label="Send report now">{{t "admin.emailReports.sendNow"}}</button>
              <button hx-delete="/admin/email-reports/{{id}}"
                      hx-confirm="Delete this email report?"
                      hx-target="closest tr"
                      hx-swap="outerHTML swap:500ms"
                      hx-include="[name='_csrf']"
                      class="btn btn--sm btn--danger"
                      aria-label="Delete email report">{{t "common.delete"}}</button>
            </td>
          </tr>
          {{else}}
          <tr>
            <td colspan="9" class="table__empty">{{t "admin.emailReports.noReports"}}</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>
</section>
