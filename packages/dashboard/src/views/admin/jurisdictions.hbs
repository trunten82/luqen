<section aria-label="Jurisdictions management">
  <div class="page-actions">
    <button hx-get="/admin/jurisdictions/new"
            hx-target="#modal-container"
            hx-swap="innerHTML"
            class="btn btn--primary"
            aria-haspopup="dialog">
      {{t "admin.jurisdictions.addJurisdiction"}}
    </button>
  </div>

  {{#if error}}
  <div class="alert alert--error" role="alert">
    <p>{{error}}</p>
  </div>
  {{/if}}

  <p class="text-sm text-muted mb-md"><span id="jurisdictions-counter">{{t "admin.jurisdictions.showing" count=jurisdictions.length total=total}}</span></p>

  <div class="search-bar">
    <label for="jurisdiction-search" class="sr-only">{{t "admin.jurisdictions.searchLabel"}}</label>
    <input id="jurisdiction-search"
           type="search"
           name="q"
           value="{{q}}"
           placeholder="{{t "admin.jurisdictions.searchPlaceholder"}}"
           hx-get="/admin/jurisdictions"
           hx-trigger="input changed delay:300ms"
           hx-target="#jurisdictions-list"
           hx-swap="innerHTML"
           hx-indicator="#search-spinner"
           aria-label="{{t "admin.jurisdictions.searchAriaLabel"}}"
           role="searchbox">
    <span id="search-spinner" class="htmx-indicator" aria-hidden="true">{{t "common.searching"}}</span>
  </div>

  <div id="jurisdictions-list" aria-live="polite">
    <div class="table-wrapper">
      <table class="table" aria-label="Jurisdictions">
        <thead>
          <tr>
            <th scope="col">{{t "admin.jurisdictions.colId"}}</th>
            <th scope="col">{{t "admin.jurisdictions.colName"}}</th>
            <th scope="col">{{t "admin.jurisdictions.colType"}}</th>
            <th scope="col">{{t "admin.jurisdictions.colParent"}}</th>
            <th scope="col">{{t "common.actions"}}</th>
          </tr>
        </thead>
        <tbody id="jurisdictions-table-body">
          {{#each jurisdictions}}
          <tr id="jurisdiction-{{id}}">
            <td data-label="ID">{{id}}</td>
            <td data-label="Name">{{name}}</td>
            <td data-label="Type">{{type}}</td>
            <td data-label="Parent">{{parentId}}</td>
            <td>
              <button hx-get="/admin/jurisdictions/{{id}}/view"
                      hx-target="#modal-container"
                      hx-swap="innerHTML"
                      class="btn btn--sm btn--secondary"
                      aria-label="View {{name}}">{{t "common.view"}}</button>
            </td>
          </tr>
          {{else}}
          <tr>
            <td colspan="5">{{t "admin.jurisdictions.noJurisdictions"}}</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>

    {{#if hasNext}}
    <div class="load-more" id="load-more-jurisdictions">
      <button hx-get="/admin/jurisdictions?offset={{nextOffset}}&limit={{limit}}&q={{q}}&partial=rows"
              hx-target="#jurisdictions-table-body"
              hx-swap="beforeend"
              class="btn btn--ghost btn--full"
              aria-label="Load more jurisdictions"
>
        {{t "admin.jurisdictions.loadMore" offset=nextOffset total=total}}
      </button>
    </div>
    {{/if}}
  </div>
</section>
