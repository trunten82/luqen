{{! Teams administration }}

<div class="admin-header">
  <h2>{{t "admin.teams.title"}}</h2>
  <p class="text-muted">{{t "admin.teams.description"}}</p>
</div>

{{! Create team form }}
<form hx-post="/admin/teams"
      hx-target="#teams-table-body"
      data-reset-on-success
      hx-swap="beforeend"

      class="card mb-lg">
  <input type="hidden" name="_csrf" value="{{csrfToken}}">
  <div class="flex flex-wrap items-center gap-sm">
    <label class="form-group form-group--inline">
      <span class="form-label">{{t "admin.teams.teamName"}}</span>
      <input type="text" name="name" class="input" placeholder="{{t "admin.teams.teamNamePlaceholder"}}" required>
    </label>
    <label class="form-group form-group--inline" style="flex:2">
      <span class="form-label">{{t "admin.teams.teamDescription"}}</span>
      <input type="text" name="description" class="input" placeholder="{{t "admin.teams.teamDescriptionPlaceholder"}}">
    </label>
    <label class="form-group form-group--inline">
      <span class="form-label">Organization</span>
      <select name="organizationId" class="input">
        <option value="">None (global)</option>
        {{#each organizations}}
        <option value="{{id}}">{{name}}</option>
        {{/each}}
      </select>
    </label>
    <label class="form-group form-group--inline">
      <span class="form-label">{{t "admin.teams.teamRole"}}</span>
      <select name="roleId" class="input">
        <option value="">None</option>
        {{#each availableRoles}}
        <option value="{{id}}">{{name}}{{#if (eq orgId "system")}} (global){{/if}}</option>
        {{/each}}
      </select>
    </label>
    <button type="submit" class="btn btn--primary">{{t "admin.teams.createTeam"}}</button>
  </div>
</form>

{{! Teams table }}
<div class="table-container">
  <table class="table">
    <thead>
      <tr>
        <th>{{t "common.name"}}</th>
        <th>{{t "admin.teams.teamDescription"}}</th>
        <th>Organization</th>
        <th>{{t "admin.teams.members"}}</th>
        <th>{{t "admin.teams.created"}}</th>
        <th>{{t "common.actions"}}</th>
      </tr>
    </thead>
    <tbody id="teams-table-body">
      {{#each teams}}
      <tr id="team-row-{{id}}">
        <td data-label="Name"><a href="/admin/teams/{{id}}">{{name}}</a></td>
        <td data-label="Description">{{description}}</td>
        <td data-label="Organization">{{#if organizationName}}<span class="badge badge--neutral">{{organizationName}}</span>{{else}}<span class="text-muted">--</span>{{/if}}</td>
        <td data-label="Members"><span class="badge badge--neutral">{{memberCount}}</span></td>
        <td data-label="Created">{{createdAt}}</td>
        <td>
          <button hx-delete="/admin/teams/{{id}}"
                  hx-confirm="Delete team {{name}}? This cannot be undone."
                  hx-target="#team-row-{{id}}"
                  hx-swap="outerHTML"
                  class="btn btn--sm btn--warning"
                  aria-label="Delete {{name}}">{{t "common.delete"}}</button>
        </td>
      </tr>
      {{/each}}

      {{#unless teams.length}}
      <tr id="teams-empty-row">
        <td colspan="6" class="empty-state">
          {{t "admin.teams.noTeams"}}
        </td>
      </tr>
      {{/unless}}
    </tbody>
  </table>
</div>
