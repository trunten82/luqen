{{! Teams administration }}

<div class="admin-header">
  <h2>Teams</h2>
  <p class="text-muted">Manage teams for issue assignment. Teams appear in the assignee picker alongside individual users.</p>
</div>

{{! Create team form }}
<form hx-post="/admin/teams"
      hx-target="#teams-table-body"
      hx-swap="beforeend"
      hx-on::after-request="if(event.detail.successful) this.reset()"
      class="card" style="margin-bottom:1.5rem; padding:1rem;">
  <input type="hidden" name="_csrf" value="{{csrfToken}}">
  <div style="display:flex; gap:0.75rem; align-items:flex-end; flex-wrap:wrap;">
    <label class="form-group" style="flex:1; min-width:200px; margin-bottom:0;">
      <span class="form-label">Team Name</span>
      <input type="text" name="name" class="input" placeholder="e.g. Frontend Team" required>
    </label>
    <label class="form-group" style="flex:2; min-width:200px; margin-bottom:0;">
      <span class="form-label">Description</span>
      <input type="text" name="description" class="input" placeholder="Optional description">
    </label>
    <button type="submit" class="btn btn--primary">Create Team</button>
  </div>
</form>

{{! Teams table }}
<div class="table-container">
  <table class="table">
    <thead>
      <tr>
        <th>Name</th>
        <th>Description</th>
        <th>Members</th>
        <th>Created</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody id="teams-table-body">
      {{#each teams}}
      <tr id="team-row-{{id}}">
        <td data-label="Name"><a href="/admin/teams/{{id}}">{{name}}</a></td>
        <td data-label="Description">{{description}}</td>
        <td data-label="Members"><span class="badge badge--neutral">{{memberCount}}</span></td>
        <td data-label="Created">{{createdAt}}</td>
        <td>
          <button hx-delete="/admin/teams/{{id}}"
                  hx-confirm="Delete team {{name}}? This cannot be undone."
                  hx-target="#team-row-{{id}}"
                  hx-swap="outerHTML"
                  class="btn btn--sm btn--warning"
                  aria-label="Delete {{name}}">Delete</button>
        </td>
      </tr>
      {{/each}}

      {{#unless teams.length}}
      <tr id="teams-empty-row">
        <td colspan="5" style="text-align:center; padding:2rem;">
          No teams yet. Create one above.
        </td>
      </tr>
      {{/unless}}
    </tbody>
  </table>
</div>
