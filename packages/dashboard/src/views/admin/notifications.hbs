{{!-- Phase 48 Plan 02 — admin notification template editor.
     Phase 69 polish: dropped the duplicate in-body page-header (the
     layout already renders one from pageTitle/pageSubtitle); the
     channel tab strip and section bodies now line up consistently
     with the identity-access surfaces. --}}
<section aria-label="Notification templates editor">
  <p class="text-muted mb-md">
    Each event-channel pair renders from a template. System templates are
    the platform-wide defaults that ship out of the box; org overrides win
    over them whenever present. Every save is versioned and audited.
  </p>

  <nav class="ia-tabs" aria-label="Notification channel">
    {{#each channels}}
    <a class="ia-tabs__tab {{#if (eq this ../channel)}}is-active{{/if}}"
       href="/admin/notifications?channel={{this}}"
       hx-get="/admin/notifications?channel={{this}}"
       hx-target="#notifications-tab-body"
       hx-push-url="true"
       aria-current="{{#if (eq this ../channel)}}page{{/if}}">
      {{this}}
    </a>
    {{/each}}
  </nav>

  <div id="notifications-tab-body">
    {{> notifications-tab}}
  </div>

  <div id="modal-container" aria-live="polite"></div>

  {{#if currentOrgId}}
  <section class="card" style="margin-top: 1.5rem;" aria-labelledby="unsubscribes-heading">
    <div class="card__header">
      <h2 id="unsubscribes-heading" class="card__title">Unsubscribed recipients</h2>
      <p class="card__sub">Recipients who clicked an unsubscribe link in a report email. They will be skipped on future sends until re-subscribed.</p>
    </div>
    <div class="table-wrap">
      <table class="table">
        <thead>
          <tr>
            <th>Recipient</th>
            <th>Channel</th>
            <th>Unsubscribed at</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {{#each unsubscribes}}
          <tr>
            <td data-label="Recipient">{{recipientAddress}}</td>
            <td data-label="Channel"><code>{{channel}}</code></td>
            <td data-label="Unsubscribed at">{{unsubscribedAt}}</td>
            <td>
              <button class="btn btn--sm btn--secondary"
                      hx-post="/admin/notifications/unsubscribes/resubscribe"
                      hx-vals='{"recipient":"{{recipientAddress}}","channel":"{{channel}}"}'
                      hx-target="closest tr"
                      hx-swap="outerHTML swap:300ms"
                      hx-confirm="Re-subscribe {{recipientAddress}}?">
                Re-subscribe
              </button>
            </td>
          </tr>
          {{else}}
          <tr><td colspan="4" class="table__empty">No recipients have unsubscribed.</td></tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </section>
  {{/if}}
</section>
