<div class="modal-overlay" role="dialog" aria-modal="true" aria-labelledby="modal-title">
  <div class="modal">
    <h2 id="modal-title">Add User</h2>

    <form hx-post="/admin/users"
          hx-target="#users-table-body"
          hx-swap="beforeend"
          hx-on::after-request="if(event.detail.successful) document.getElementById('modal-container').replaceChildren()"
          novalidate>

      <div class="form-group">
        <label for="usr-username" class="form-label">Username <span aria-hidden="true">*</span></label>
        <input id="usr-username" name="username" type="text" class="input"
               required aria-required="true" autocomplete="username">
      </div>

      <div class="form-group">
        <label for="usr-password" class="form-label">Password <span aria-hidden="true">*</span></label>
        <input id="usr-password" name="password" type="password" class="input"
               required aria-required="true" autocomplete="new-password"
               aria-describedby="usr-password-hint">
        <span id="usr-password-hint" class="form-hint">Minimum 8 characters</span>
      </div>

      <div class="form-group">
        <label for="usr-role" class="form-label">Role <span aria-hidden="true">*</span></label>
        <select id="usr-role" name="role" class="select"
                required aria-required="true">
          {{#each roles}}
          <option value="{{this}}">{{this}}</option>
          {{/each}}
        </select>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn--primary">Create User</button>
        <button type="button" class="btn btn--ghost close-modal-btn"
                aria-label="Cancel and close dialog">Cancel</button>
      </div>
    </form>
  </div>
</div>
