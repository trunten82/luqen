<div class="modal-overlay" role="dialog" aria-modal="true" aria-labelledby="modal-title">
  <div class="modal">
    <h2 id="modal-title">{{t "admin.users.addUser"}}</h2>

    <form hx-post="/admin/users"
          hx-target="#users-table-body"
          hx-swap="beforeend"
          novalidate>

      <div class="form-group">
        <label for="usr-username" class="form-label">{{t "admin.users.username"}} <span aria-hidden="true">*</span></label>
        <input id="usr-username" name="username" type="text" class="input"
               required aria-required="true" autocomplete="username">
      </div>

      <div class="form-group">
        <label for="usr-password" class="form-label">{{t "admin.users.password"}} <span aria-hidden="true">*</span></label>
        <input id="usr-password" name="password" type="password" class="input"
               required aria-required="true" autocomplete="new-password"
               aria-describedby="usr-password-hint">
        <span id="usr-password-hint" class="form-hint">{{t "admin.users.passwordHint"}}</span>
      </div>

      <div class="form-group">
        <label for="usr-role" class="form-label">{{t "admin.users.role"}} <span aria-hidden="true">*</span></label>
        <select id="usr-role" name="role" class="select"
                required aria-required="true">
          {{#each roles}}
          <option value="{{this}}">{{this}}</option>
          {{/each}}
        </select>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn--primary">{{t "admin.users.createUser"}}</button>
        <button type="button" class="btn btn--ghost close-modal-btn"
                aria-label="Cancel and close dialog">{{t "common.cancel"}}</button>
      </div>
    </form>
  </div>
</div>
