<section aria-label="Monitor dashboard">
  {{#if error}}
  <div class="alert alert--error mb-md" role="alert">
    <p>{{error}}</p>
  </div>
  {{/if}}

  {{! ── KPI Cards ──────────────────────────────────────────────────────────── }}
  <div class="stats-grid">
    <div class="card">
      <div class="card__header">
        <h2 class="card__title">{{t "admin.monitor.sources"}}</h2>
      </div>
      <div class="card__body">
        <div class="card__value">{{sourcesCount}}</div>
        <div class="card__label">{{t "admin.monitor.monitoredSources"}}</div>
      </div>
    </div>

    <div class="card">
      <div class="card__header">
        <h2 class="card__title">{{t "admin.monitor.lastScan"}}</h2>
      </div>
      <div class="card__body">
        <div class="card__value" style="font-size: var(--font-size-lg)">{{lastScanTime}}</div>
      </div>
    </div>

    <div class="card">
      <div class="card__header">
        <h2 class="card__title">{{t "admin.monitor.pendingProposals"}}</h2>
      </div>
      <div class="card__body">
        <div class="card__value {{#if pendingProposalsCount}}text--warning{{else}}text--success{{/if}}">{{pendingProposalsCount}}</div>
        <div class="card__label">{{t "admin.monitor.awaitingReview"}}</div>
      </div>
    </div>
  </div>

  {{! ── Trigger Scan ───────────────────────────────────────────────────────── }}
  <section class="admin-section" aria-label="Trigger scan">
    <h2 class="section-title">{{t "admin.monitor.scan"}}</h2>
    <div class="mb-md">
      <p class="text-sm text-muted mb-sm">{{t "admin.monitor.scanDescription"}}</p>
      <form>
        <input type="hidden" name="_csrf" value="{{csrfToken}}">
        <button type="button" class="btn btn--primary btn--sm"
                hx-post="/admin/monitor/trigger"
                hx-target="#scan-results"
                hx-swap="innerHTML"
                hx-include="[name=_csrf]"
                hx-indicator="#scan-spinner"
                aria-label="Trigger source scan">
          {{t "admin.monitor.triggerScan"}}
        </button>
        <span id="scan-spinner" class="htmx-indicator" aria-hidden="true">{{t "admin.sources.scanning"}}</span>
      </form>
    </div>
    <div id="scan-results" aria-live="polite"></div>
  </section>

  {{! ── Monitored Sources ──────────────────────────────────────────────────── }}
  <section class="admin-section" aria-label="Monitored sources">
    <h2 class="section-title">{{t "admin.monitor.monitoredSources"}}</h2>
    {{#if sources.length}}
    <div class="table-wrapper">
      <table class="data-table" aria-label="Monitored sources">
        <thead>
          <tr>
            <th scope="col">{{t "admin.sources.colName"}}</th>
            <th scope="col">{{t "admin.monitor.colUrl"}}</th>
            <th scope="col">{{t "admin.sources.colType"}}</th>
            <th scope="col">{{t "admin.sources.colSchedule"}}</th>
            <th scope="col">{{t "admin.sources.colLastChecked"}}</th>
            <th scope="col">{{t "common.status"}}</th>
          </tr>
        </thead>
        <tbody>
          {{#each sources}}
          <tr>
            <td data-label="Name">{{name}}</td>
            <td data-label="URL" class="cell--url"><a href="{{url}}" target="_blank" rel="noopener noreferrer">{{url}}</a></td>
            <td data-label="Type"><span class="badge badge--info">{{type}}</span></td>
            <td data-label="Schedule">{{schedule}}</td>
            <td data-label="Last Checked">{{lastCheckedDisplay}}</td>
            <td data-label="Status">
              {{#if stale}}
              <span class="badge badge--warning">{{t "admin.monitor.stale"}}</span>
              {{else}}
              <span class="badge badge--success">{{t "admin.monitor.ok"}}</span>
              {{/if}}
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
    {{else}}
    <div class="empty-state" role="status">
      <div class="empty-state__title">{{t "admin.monitor.noSources"}}</div>
      <div class="empty-state__desc">{{t "admin.monitor.noSourcesDesc"}}</div>
    </div>
    {{/if}}
  </section>

  {{! ── Recent Proposals ───────────────────────────────────────────────────── }}
  <section class="admin-section" aria-label="Recent proposals">
    <h2 class="section-title">{{t "admin.monitor.recentProposals"}}</h2>
    {{#if proposals.length}}
    <div class="table-wrapper">
      <table class="data-table" aria-label="Recent proposals">
        <thead>
          <tr>
            <th scope="col">{{t "admin.proposals.colSummary"}}</th>
            <th scope="col">{{t "admin.proposals.colSource"}}</th>
            <th scope="col">{{t "admin.monitor.colCreated"}}</th>
            <th scope="col">{{t "common.status"}}</th>
            <th scope="col">{{t "common.actions"}}</th>
          </tr>
        </thead>
        <tbody>
          {{#each proposals}}
          <tr>
            <td data-label="Summary">{{summary}}</td>
            <td data-label="Source">{{source}}</td>
            <td data-label="Created">{{detectedAtDisplay}}</td>
            <td data-label="Status">
              <span class="badge {{#if (eq status 'pending')}}badge--warning{{else if (eq status 'approved')}}badge--success{{else}}badge--neutral{{/if}}">
                {{status}}
              </span>
            </td>
            <td>
              <a href="/admin/proposals/{{id}}" class="btn btn--sm btn--ghost">{{t "common.view"}}</a>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
    {{else}}
    <div class="empty-state" role="status">
      <div class="empty-state__title">{{t "admin.monitor.noProposals"}}</div>
      <div class="empty-state__desc">{{t "admin.monitor.noProposalsDesc"}}</div>
    </div>
    {{/if}}
  </section>
</section>
