<section aria-label="Monitor dashboard" id="monitor-dashboard"
        hx-get="/admin/monitor" hx-trigger="monitorScanDone from:body" hx-select="#monitor-dashboard" hx-swap="outerHTML"
        hx-disinherit="hx-select">
  {{#if error}}
  <div class="alert alert--error mb-md" role="alert">
    <p>{{error}}</p>
  </div>
  {{/if}}

  {{! ── KPI Cards ──────────────────────────────────────────────────────────── }}
  <div class="stats-grid">
    <div class="card">
      <div class="card__header">
        <h2 class="card__title">{{t "admin.monitor.sources"}}</h2>
      </div>
      <div class="card__body">
        <div class="card__value">{{sourcesCount}}</div>
        <div class="card__label">{{t "admin.monitor.monitoredSources"}}</div>
      </div>
    </div>

    <div class="card">
      <div class="card__header">
        <h2 class="card__title">{{t "admin.monitor.lastScan"}}</h2>
      </div>
      <div class="card__body">
        <div class="card__value" style="font-size: var(--font-size-lg, 1.1rem)">{{lastScanTime}}</div>
      </div>
    </div>

    <div class="card">
      <div class="card__header">
        <h2 class="card__title">{{t "admin.monitor.pendingProposals"}}</h2>
      </div>
      <div class="card__body">
        <div class="card__value {{#if pendingProposalsCount}}text--warning{{else}}text--success{{/if}}">{{pendingProposalsCount}}</div>
        <div class="card__label">{{t "admin.monitor.awaitingReview"}}</div>
      </div>
    </div>

    <div class="card">
      <div class="card__header">
        <h2 class="card__title">{{t "admin.monitor.upToDate"}}</h2>
      </div>
      <div class="card__body">
        <div class="card__value text--success">{{upToDateCount}}</div>
        <div class="card__label">{{t "admin.monitor.sourcesAligned"}}</div>
      </div>
    </div>
  </div>

  {{! ── Trigger Scan ───────────────────────────────────────────────────────── }}
  <section class="admin-section" aria-label="Trigger scan">
    <h2 class="section-title">{{t "admin.monitor.scan"}}</h2>
    <div class="mb-md">
      <p class="text-sm text-muted mb-sm">{{t "admin.monitor.scanDescription"}}</p>
      <button type="button" id="monitor-trigger-btn" class="btn btn--primary btn--sm"
              data-action="triggerMonitorScan"
              aria-label="Trigger source scan">
        {{t "admin.monitor.triggerScan"}}
      </button>
    </div>
    <div id="scan-results" aria-live="polite"></div>
  </section>

  {{! ── Monitored Sources ──────────────────────────────────────────────────── }}
  <section class="admin-section" aria-label="Monitored sources">
    <h2 class="section-title">{{t "admin.monitor.monitoredSources"}}</h2>
    {{#if sources.length}}
    <div class="table-wrapper">
      <table class="data-table" aria-label="Monitored sources">
        <thead>
          <tr>
            <th scope="col">{{t "admin.sources.colName"}}</th>
            <th scope="col">{{t "admin.monitor.colUrl"}}</th>
            <th scope="col">{{t "admin.sources.colType"}}</th>
            <th scope="col">{{t "admin.sources.colSchedule"}}</th>
            <th scope="col">{{t "admin.sources.colLastChecked"}}</th>
            <th scope="col">{{t "admin.monitor.lastDbUpdate"}}</th>
            <th scope="col">{{t "common.status"}}</th>
          </tr>
        </thead>
        <tbody>
          {{#each sources}}
          <tr>
            <td data-label="Name">{{name}}</td>
            <td data-label="URL" class="cell--url cell--wrap"><a href="{{url}}" target="_blank" rel="noopener noreferrer">{{url}}</a></td>
            <td data-label="Type"><span class="badge badge--info">{{type}}</span></td>
            <td data-label="Schedule">{{schedule}}</td>
            <td data-label="Last Checked">{{lastCheckedDisplay}}</td>
            <td data-label="Last DB Update">{{lastDbUpdateDisplay}}</td>
            <td data-label="Status">
              {{#if (eq status 'stale')}}
              <span class="badge badge--error">{{t "admin.monitor.stale"}}</span>
              {{else if (eq status 'change_pending')}}
              <span class="badge badge--warning">{{t "admin.monitor.changePending"}}</span>
              {{else}}
              <span class="badge badge--success">{{t "admin.monitor.upToDate"}}</span>
              {{/if}}
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
    {{else}}
    <div class="empty-state" role="status">
      <div class="empty-state__title">{{t "admin.monitor.noSources"}}</div>
      <div class="empty-state__desc">{{t "admin.monitor.noSourcesDesc"}}</div>
    </div>
    {{/if}}
  </section>

  {{! ── Pending Changes Summary ─────────────────────────────────────────── }}
  {{#if pendingProposalsCount}}
  <section class="admin-section" aria-label="Pending changes">
    <h2 class="section-title">{{t "admin.monitor.pendingProposals"}}</h2>
    <div class="alert alert--warning">
      <p>{{pendingProposalsCount}} {{t "admin.monitor.pendingChangesMsg"}}</p>
      <a href="/admin/proposals" class="btn btn--sm btn--primary mt-sm">{{t "admin.monitor.viewProposals"}}</a>
    </div>
  </section>
  {{/if}}
</section>
