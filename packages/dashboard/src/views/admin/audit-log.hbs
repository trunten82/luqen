<section aria-label="Audit log">
  <h1 class="section-title">{{t "audit.title"}}</h1>
  <p class="text-muted">{{total}} entries found</p>

  <form method="GET" action="/admin/audit-log" class="admin-section" aria-label="Audit log filters">
    <div style="display:flex;flex-wrap:wrap;gap:var(--space-sm,0.5rem);align-items:flex-end">
      <div class="form-group" style="flex:1;min-width:140px">
        <label for="filter-actor">{{t "audit.actor"}}</label>
        <input type="text" id="filter-actor" name="actor" class="input input--sm" value="{{filters.actor}}" placeholder="Username">
      </div>
      <div class="form-group" style="flex:1;min-width:140px">
        <label for="filter-action">{{t "audit.action"}}</label>
        <select id="filter-action" name="action" class="select select--sm">
          <option value="">{{t "audit.allActions"}}</option>
          <option value="login.success" {{#if (eq filters.action 'login.success')}}selected{{/if}}>Login success</option>
          <option value="login.failure" {{#if (eq filters.action 'login.failure')}}selected{{/if}}>Login failure</option>
          <option value="user.create" {{#if (eq filters.action 'user.create')}}selected{{/if}}>User create</option>
          <option value="user.delete" {{#if (eq filters.action 'user.delete')}}selected{{/if}}>User delete</option>
          <option value="user.activate" {{#if (eq filters.action 'user.activate')}}selected{{/if}}>User activate</option>
          <option value="user.deactivate" {{#if (eq filters.action 'user.deactivate')}}selected{{/if}}>User deactivate</option>
          <option value="user.role_change" {{#if (eq filters.action 'user.role_change')}}selected{{/if}}>User role change</option>
          <option value="api_key.create" {{#if (eq filters.action 'api_key.create')}}selected{{/if}}>API key create</option>
          <option value="api_key.delete" {{#if (eq filters.action 'api_key.delete')}}selected{{/if}}>API key delete</option>
          <option value="plugin.install" {{#if (eq filters.action 'plugin.install')}}selected{{/if}}>Plugin install</option>
          <option value="plugin.activate" {{#if (eq filters.action 'plugin.activate')}}selected{{/if}}>Plugin activate</option>
          <option value="plugin.deactivate" {{#if (eq filters.action 'plugin.deactivate')}}selected{{/if}}>Plugin deactivate</option>
        </select>
      </div>
      <div class="form-group" style="flex:1;min-width:140px">
        <label for="filter-resource-type">{{t "audit.resourceType"}}</label>
        <select id="filter-resource-type" name="resourceType" class="select select--sm">
          <option value="">{{t "audit.allResources"}}</option>
          <option value="session" {{#if (eq filters.resourceType 'session')}}selected{{/if}}>Session</option>
          <option value="user" {{#if (eq filters.resourceType 'user')}}selected{{/if}}>User</option>
          <option value="api_key" {{#if (eq filters.resourceType 'api_key')}}selected{{/if}}>API key</option>
          <option value="plugin" {{#if (eq filters.resourceType 'plugin')}}selected{{/if}}>Plugin</option>
        </select>
      </div>
      <div class="form-group" style="flex:1;min-width:140px">
        <label for="filter-from">{{t "common.from"}}</label>
        <input type="date" id="filter-from" name="from" class="input input--sm" value="{{filters.from}}">
      </div>
      <div class="form-group" style="flex:1;min-width:140px">
        <label for="filter-to">{{t "common.to"}}</label>
        <input type="date" id="filter-to" name="to" class="input input--sm" value="{{filters.to}}">
      </div>
      <div class="form-group">
        <button type="submit" class="btn btn--primary btn--sm">{{t "common.filter"}}</button>
        <a href="/admin/audit-log" class="btn btn--ghost btn--sm">{{t "common.reset"}}</a>
      </div>
    </div>
  </form>

  <div class="table-wrap" role="region" aria-label="Audit log entries" tabindex="0">
    <table class="table">
      <thead>
        <tr>
          <th>{{t "audit.timestamp"}}</th>
          <th>{{t "audit.actor"}}</th>
          <th>{{t "audit.action"}}</th>
          <th>{{t "audit.resourceType"}}</th>
          <th>{{t "audit.resourceId"}}</th>
          <th>{{t "audit.details"}}</th>
          <th>{{t "audit.ipAddress"}}</th>
        </tr>
      </thead>
      <tbody>
        {{#each entries}}
        <tr>
          <td data-label="Timestamp"><code>{{this.timestamp}}</code></td>
          <td data-label="Actor">{{this.actor}}</td>
          <td data-label="Action"><span class="badge badge--neutral">{{this.action}}</span></td>
          <td data-label="Resource Type">{{this.resourceType}}</td>
          <td data-label="Resource ID">{{this.resourceId}}</td>
          <td data-label="Details">{{this.details}}</td>
          <td data-label="IP Address"><code>{{this.ipAddress}}</code></td>
        </tr>
        {{else}}
        <tr>
          <td colspan="7" class="text-center text-muted">{{t "audit.noEntries"}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>

  {{#if hasMore}}
  <div style="margin-top:var(--space-md,1rem);text-align:center">
    <a href="/admin/audit-log?actor={{filters.actor}}&action={{filters.action}}&resourceType={{filters.resourceType}}&from={{filters.from}}&to={{filters.to}}&limit={{limit}}&offset={{nextOffset}}"
       class="btn btn--ghost">
      {{t "audit.loadMore"}}
    </a>
  </div>
  {{/if}}
</section>
