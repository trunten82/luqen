<div class="modal-overlay" role="dialog" aria-modal="true" aria-labelledby="modal-title">
  <div class="modal modal--lg">
    <div class="modal__header">
      <h2 id="modal-title">{{regulation.name}}</h2>
      <button class="modal__close close-modal-btn" aria-label="Close">&times;</button>
    </div>

    {{#if regulation.url}}
    <a href="{{regulation.url}}" target="_blank" rel="noopener noreferrer" class="detail-source-link">
      {{regulation.reference}} — {{t "admin.regulations.viewOfficialSource"}}
    </a>
    {{/if}}

    <dl class="detail-list">
      <div class="detail-list__item">
        <dt>{{t "admin.regulations.colShortName"}}</dt>
        <dd>{{regulation.shortName}}</dd>
      </div>
      <div class="detail-list__item">
        <dt>{{t "admin.regulations.colJurisdiction"}}</dt>
        <dd>{{jurisdictionName}}</dd>
      </div>
      <div class="detail-list__item">
        <dt>{{t "common.status"}}</dt>
        <dd><span class="badge badge--{{#if (eq regulation.status 'active')}}completed{{else}}{{#if (eq regulation.status 'draft')}}queued{{else}}failed{{/if}}{{/if}}">{{regulation.status}}</span></dd>
      </div>
      <div class="detail-list__item">
        <dt>{{t "admin.regulations.enforcement"}}</dt>
        <dd>{{regulation.enforcementDate}}</dd>
      </div>
      <div class="detail-list__item">
        <dt>{{t "admin.regulations.colScope"}}</dt>
        <dd>{{regulation.scope}}</dd>
      </div>
      {{#if regulation.description}}
      <div class="detail-list__item">
        <dt>{{t "admin.regulations.description"}}</dt>
        <dd>{{regulation.description}}</dd>
      </div>
      {{/if}}
    </dl>

    {{#if requirements.length}}
    <h3 class="detail-section-title">{{t "admin.regulations.wcagRequirementsCount" count=requirements.length}}</h3>
    <div class="detail-cards">
      {{#each requirements}}
      <div class="detail-card detail-card--compact">
        <div class="detail-card__header">
          <strong>WCAG {{wcagVersion}} Level {{wcagLevel}}</strong>
          <span class="badge {{#if (eq obligation 'mandatory')}}badge--failed{{else}}{{#if (eq obligation 'recommended')}}badge--warning{{else}}badge--info{{/if}}{{/if}}">{{obligation}}</span>
        </div>
        <div class="detail-card__body">
          <span class="text-sm">{{t "admin.regulations.criterion"}}: <code>{{wcagCriterion}}</code></span>
          {{#if notes}}
          <p class="text-xs text-muted mt-sm">{{notes}}</p>
          {{/if}}
        </div>
      </div>
      {{/each}}
    </div>
    {{else}}
    <p class="text-muted mt-md">{{t "admin.regulations.noWcagRequirements"}}</p>
    {{/if}}

    <div class="modal__footer">
      {{#unless isSystem}}
      <button hx-get="/admin/regulations/{{regulation.id}}/edit"
              hx-target="#modal-container"
              hx-swap="innerHTML"
              class="btn btn--primary">{{t "common.edit"}}</button>
      {{/unless}}
      <button type="button" class="btn btn--ghost close-modal-btn">{{t "common.close"}}</button>
    </div>
  </div>
</div>
