{{! Team detail — view and manage members }}

<div class="admin-header">
  <h2>{{team.name}}</h2>
  <p class="text-muted">{{team.description}}</p>
  <div class="mt-sm">
    <a href="/admin/teams" class="btn btn--ghost btn--sm">&larr; {{t "admin.teams.backToTeams"}}</a>
  </div>
</div>

{{! Organization assignment }}
<div class="card mb-lg">
  <h3>{{t "common.organization"}}</h3>
  <p class="text-muted mb-md">
    {{t "admin.teams.orgLinkDesc"}}
    {{t "admin.teams.current"}} <strong><span id="team-org-label">{{#if linkedOrgName}}{{linkedOrgName}}{{else}}{{t "admin.teams.noneGlobal"}}{{/if}}</span></strong>
  </p>
  <form hx-post="/admin/teams/{{team.id}}/org"
        hx-target="#team-org-label"
        hx-swap="outerHTML"
        class="flex flex-wrap items-center gap-sm">
    <input type="hidden" name="_csrf" value="{{csrfToken}}">
    <label class="form-group form-group--inline">
      <span class="form-label">{{t "common.organization"}}</span>
      <select name="organizationId" class="input">
        <option value="">{{t "admin.teams.noneGlobal"}}</option>
        {{#each organizations}}
        <option value="{{id}}"{{#if (eq id ../team.orgId)}} selected{{/if}}>{{name}}</option>
        {{/each}}
      </select>
    </label>
    <button type="submit" class="btn btn--primary btn--sm">{{t "admin.teams.updateOrganization"}}</button>
  </form>
</div>

{{! Role assignment }}
<div class="card mb-lg">
  <h3>{{t "admin.teams.teamRole"}}</h3>
  <p class="text-muted mb-md">
    {{t "admin.teams.roleLinkDesc"}}
    {{t "admin.teams.current"}} <strong><span id="team-role-label">{{#if currentRoleName}}{{currentRoleName}}{{else}}{{t "admin.teams.noneRole"}}{{/if}}</span></strong>
  </p>
  <form hx-post="/admin/teams/{{team.id}}/role"
        hx-target="#team-role-label"
        hx-swap="outerHTML"
        class="flex flex-wrap items-center gap-sm">
    <input type="hidden" name="_csrf" value="{{csrfToken}}">
    <label class="form-group form-group--inline">
      <span class="form-label">{{t "admin.roles.roleName"}}</span>
      <select name="roleId" class="input">
        <option value="">{{t "admin.teams.noneRole"}}</option>
        {{#each availableRoles}}
        <option value="{{id}}"{{#if (eq id ../team.roleId)}} selected{{/if}}>{{name}}{{#if (eq orgId "system")}} (global){{/if}}</option>
        {{/each}}
      </select>
    </label>
    <button type="submit" class="btn btn--primary btn--sm">{{t "admin.teams.updateRole"}}</button>
  </form>
</div>

{{! Add member form }}
<form hx-post="/admin/teams/{{team.id}}/members"
      hx-target="#members-table-body"
      data-reset-on-success
      hx-swap="beforeend"

      class="card mb-lg">
  <input type="hidden" name="_csrf" value="{{csrfToken}}">
  <div class="flex flex-wrap items-center gap-sm">
    <label class="form-group form-group--inline">
      <span class="form-label">{{t "admin.teams.addMember"}}</span>
      <select name="userId" class="input" required>
        <option value="">{{t "admin.teams.selectUser"}}</option>
        {{#each availableUsers}}
        <option value="{{id}}">{{username}} ({{role}})</option>
        {{/each}}
      </select>
    </label>
    <button type="submit" class="btn btn--primary">{{t "admin.teams.addMember"}}</button>
  </div>
</form>

{{! Members table }}
<div class="table-wrapper">
  <table class="table" aria-label="Team members">
    <thead>
      <tr>
        <th scope="col">{{t "admin.teams.username"}}</th>
        <th scope="col">{{t "admin.teams.teamRole"}}</th>
        <th scope="col">{{t "common.actions"}}</th>
      </tr>
    </thead>
    <tbody id="members-table-body">
      {{#each team.members}}
      <tr id="member-row-{{userId}}">
        <td data-label="Username">{{username}}</td>
        <td data-label="Role"><span class="badge badge--neutral">{{role}}</span></td>
        <td>
          <button hx-delete="/admin/teams/{{../team.id}}/members/{{userId}}"
                  hx-confirm="Remove {{username}} from this team?"
                  hx-target="#member-row-{{userId}}"
                  hx-swap="outerHTML"
                  class="btn btn--sm btn--warning"
                  aria-label="Remove {{username}}">{{t "admin.teams.remove"}}</button>
        </td>
      </tr>
      {{/each}}

      {{#unless team.members.length}}
      <tr id="members-empty-row">
        <td colspan="3" class="empty-state">
          {{t "admin.teams.noMembers"}}
        </td>
      </tr>
      {{/unless}}
    </tbody>
  </table>
</div>

{{! ─────────────────────────────────────────────────────────────────────── }}
{{! Phase 62.1 — Multi-team RBAC overlay: linked orgs, invites, pending.   }}
{{! ─────────────────────────────────────────────────────────────────────── }}

<section class="card mb-lg" aria-labelledby="linked-orgs-heading">
  <h3 id="linked-orgs-heading">{{t "admin.teams.linkedOrgs"}}</h3>
  <p class="text-muted mb-md">{{t "admin.teams.linkedOrgsDesc"}}</p>
  <div class="table-wrapper">
    <table class="data-table" aria-label="Linked organizations">
      <thead>
        <tr>
          <th scope="col">{{t "common.organization"}}</th>
          <th scope="col">{{t "admin.teams.linkedAt"}}</th>
          <th scope="col">{{t "admin.teams.linkedBy"}}</th>
          <th scope="col"><span class="screen-reader-text">{{t "common.actions"}}</span></th>
        </tr>
      </thead>
      <tbody id="linked-orgs-body">
        {{#each activeLinks}}
        <tr id="linked-org-row-{{orgId}}">
          <td data-label="Organization">{{orgName}} <code class="text-muted">{{orgId}}</code></td>
          <td data-label="Linked at"><time datetime="{{linkedAt}}">{{linkedAt}}</time></td>
          <td data-label="Linked by">{{#if linkedBy}}<code>{{linkedBy}}</code>{{else}}&mdash;{{/if}}</td>
          <td>
            <button hx-post="/admin/teams/{{../team.id}}/org-links/{{orgId}}/sever"
                    hx-headers='{"X-CSRF-Token": "{{../csrfToken}}"}'
                    hx-confirm="{{t "admin.teams.severLinkConfirm"}}"
                    hx-target="#linked-org-row-{{orgId}}"
                    hx-swap="outerHTML"
                    class="btn btn--sm btn--danger"
                    aria-label="Sever link with {{orgName}}">{{t "admin.teams.severLink"}}</button>
          </td>
        </tr>
        {{/each}}
        {{#unless activeLinks.length}}
        <tr><td colspan="4" class="empty-state">{{t "admin.teams.noLinkedOrgs"}}</td></tr>
        {{/unless}}
      </tbody>
    </table>
  </div>
</section>

<section class="card mb-lg" aria-labelledby="invite-org-heading">
  <h3 id="invite-org-heading">{{t "admin.teams.inviteAnOrg"}}</h3>
  <p class="text-muted mb-md">{{t "admin.teams.inviteAnOrgDesc"}}</p>
  {{#if invitableOrgs.length}}
  <form hx-post="/admin/teams/{{team.id}}/org-links/invite"
        class="flex flex-wrap items-center gap-sm">
    <input type="hidden" name="_csrf" value="{{csrfToken}}">
    <label class="form-group form-group--inline">
      <span class="form-label">{{t "admin.teams.targetOrg"}}</span>
      <select name="targetOrgId" class="input" required>
        <option value="">{{t "admin.teams.selectOrg"}}</option>
        {{#each invitableOrgs}}
        <option value="{{id}}">{{name}}</option>
        {{/each}}
      </select>
    </label>
    <button type="submit" class="btn btn--primary">{{t "admin.teams.sendInvite"}}</button>
  </form>
  {{else}}
  <p class="empty-state">{{t "admin.teams.noLinkedOrgs"}}</p>
  {{/if}}
</section>

<section class="card mb-lg" aria-labelledby="pending-invites-heading">
  <h3 id="pending-invites-heading">{{t "admin.teams.pendingInvites"}}</h3>
  <p class="text-muted mb-md">{{t "admin.teams.outgoingInvitesDesc"}}</p>
  <div class="table-wrapper">
    <table class="data-table" aria-label="Pending outgoing invites">
      <thead>
        <tr>
          <th scope="col">{{t "admin.teams.targetOrg"}}</th>
          <th scope="col">{{t "admin.teams.invitedBy"}}</th>
          <th scope="col">{{t "admin.teams.invitedAt"}}</th>
        </tr>
      </thead>
      <tbody>
        {{#each pendingInvites}}
        <tr>
          <td data-label="Target">{{targetOrgName}} <code class="text-muted">{{targetOrgId}}</code></td>
          <td data-label="Invited by"><code>{{invitedBy}}</code></td>
          <td data-label="Invited at"><time datetime="{{createdAt}}">{{createdAt}}</time></td>
        </tr>
        {{/each}}
        {{#unless pendingInvites.length}}
        <tr><td colspan="3" class="empty-state">{{t "admin.teams.noPendingInvites"}}</td></tr>
        {{/unless}}
      </tbody>
    </table>
  </div>
</section>
