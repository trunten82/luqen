<div class="modal-overlay" role="dialog" aria-modal="true" aria-labelledby="modal-title">
  <div class="modal">
    <h2 id="modal-title">{{t "admin.clients.addClient"}}</h2>

    <form hx-post="/admin/clients"
          hx-target="#clients-table-body"
          hx-swap="beforeend"
          novalidate>
      <input type="hidden" name="_csrf" value="{{csrfToken}}">

      <div class="form-group">
        <label for="cl-name" class="form-label">{{t "admin.clients.clientName"}} <span aria-hidden="true">*</span></label>
        <input id="cl-name" name="name" type="text" class="input"
               required aria-required="true"
               aria-describedby="cl-name-hint">
        <span id="cl-name-hint" class="form-hint">{{t "admin.clients.clientNameHint"}}</span>
      </div>

      <div class="form-group">
        <label for="cl-scopes" class="form-label">{{t "admin.clients.scopes"}}</label>
        <input id="cl-scopes" name="scopes" type="text" class="input"
               placeholder="{{t "admin.clients.scopesPlaceholder"}}"
               aria-describedby="cl-scopes-hint">
        <span id="cl-scopes-hint" class="form-hint">{{t "admin.clients.scopesHint"}}</span>
      </div>

      {{#if availableServices}}
      <div class="form-group">
        <label for="cl-service" class="form-label">{{t "common.service"}}</label>
        <select id="cl-service" name="service" class="input">
          {{#each availableServices}}
          <option value="{{value}}">{{label}}</option>
          {{/each}}
        </select>
      </div>
      {{/if}}

      <fieldset class="form-group">
        <legend class="form-label">{{t "admin.clients.grantTypes"}}</legend>
        {{#each availableGrantTypes}}
        <label class="checkbox-label">
          <input type="checkbox" name="grantTypes" value="{{this}}"
                 {{#if (eq this 'client_credentials')}}checked{{/if}}>
          {{this}}
        </label>
        {{/each}}
      </fieldset>

      <div class="form-actions">
        <button type="submit" class="btn btn--primary">{{t "admin.clients.createClient"}}</button>
        <button type="button" class="btn btn--ghost close-modal-btn"
                aria-label="Cancel and close dialog">{{t "common.cancel"}}</button>
      </div>
    </form>
  </div>
</div>
