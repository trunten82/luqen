<section aria-label="{{#if isNew}}Create{{else}}Edit{{/if}} role">
  <div class="page-actions">
    <a href="/admin/roles" class="btn btn--ghost btn--sm">&larr; Back to Roles</a>
  </div>

  <div class="card">
    <form
      {{#if isNew}}
        method="POST"
        action="/admin/roles"
      {{else}}
        method="POST"
        action="/admin/roles/{{role.id}}"
      {{/if}}
    >
      <input type="hidden" name="_csrf" value="{{csrfToken}}">

      <div class="form-group">
        <label for="role-name">Role Name <span class="required" aria-hidden="true">*</span></label>
        {{#if isSystem}}
        <input
          type="text"
          id="role-name"
          name="name"
          value="{{role.name}}"
          disabled
          class="form-control"
          aria-describedby="role-name-hint"
        >
        <p id="role-name-hint" class="form-hint">System role names cannot be changed.</p>
        {{else}}
        <input
          type="text"
          id="role-name"
          name="name"
          value="{{role.name}}"
          required
          pattern="[a-zA-Z0-9_\-]+"
          class="form-control"
          placeholder="e.g. content-editor"
          aria-describedby="role-name-hint"
          aria-required="true"
        >
        <p id="role-name-hint" class="form-hint">Letters, numbers, hyphens and underscores only.</p>
        {{/if}}
      </div>

      <div class="form-group">
        <label for="role-description">Description</label>
        <textarea
          id="role-description"
          name="description"
          rows="2"
          class="form-control"
          placeholder="Describe what this role is for..."
        >{{role.description}}</textarea>
      </div>

      <fieldset class="form-group">
        <legend><strong>Permissions</strong></legend>
        <p class="form-hint" style="margin-bottom:1rem;">Select the permissions this role should have.</p>

        {{#each permissionGroups}}
        <div class="perm-group" style="margin-bottom:1.25rem;">
          <div class="perm-group__label" style="font-weight:600;margin-bottom:0.5rem;color:var(--text-heading, #333);">{{this.group}}</div>
          {{#each this.permissions}}
          <label class="perm-checkbox" style="display:flex;align-items:center;gap:0.5rem;padding:0.25rem 0;">
            <input
              type="checkbox"
              name="permissions"
              value="{{this.id}}"
              {{#if (lookup ../../selectedPermissions this.id)}}checked{{/if}}
            >
            <span>{{this.label}}</span>
            <code style="font-size:0.75rem;color:var(--text-muted, #888);">{{this.id}}</code>
          </label>
          {{/each}}
        </div>
        {{/each}}
      </fieldset>

      <div class="page-actions">
        <button type="submit" class="btn btn--primary">
          {{#if isNew}}Create Role{{else}}Save Changes{{/if}}
        </button>
        <a href="/admin/roles" class="btn btn--ghost">Cancel</a>
      </div>
    </form>
  </div>
</section>
