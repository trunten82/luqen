<section aria-label="Change History">
  <div class="page-actions">
    <a href="/admin/change-history/export?from={{filters.from}}&to={{filters.to}}&action={{filters.action}}&search={{filters.search}}"
       class="btn btn--secondary btn--sm">Export CSV</a>
  </div>

  <form class="admin-section" method="GET" action="/admin/change-history" aria-label="Change history filters">
    <div class="filter-bar filter-bar--wrap">
      <div class="form-group">
        <label for="filter-from" class="form-label">From</label>
        <input type="date" id="filter-from" name="from" value="{{filters.from}}" class="input input--sm">
      </div>
      <div class="form-group">
        <label for="filter-to" class="form-label">To</label>
        <input type="date" id="filter-to" name="to" value="{{filters.to}}" class="input input--sm">
      </div>
      <div class="form-group">
        <label for="filter-action" class="form-label">Action</label>
        <select id="filter-action" name="action" class="select select--sm">
          <option value="">All Actions</option>
          <option value="acknowledged" {{#if (eq filters.action 'acknowledged')}}selected{{/if}}>Acknowledged</option>
          <option value="reviewed" {{#if (eq filters.action 'reviewed')}}selected{{/if}}>Reviewed</option>
          <option value="dismissed" {{#if (eq filters.action 'dismissed')}}selected{{/if}}>Dismissed</option>
          <option value="approved" {{#if (eq filters.action 'approved')}}selected{{/if}}>Approved</option>
          <option value="rejected" {{#if (eq filters.action 'rejected')}}selected{{/if}}>Rejected</option>
        </select>
      </div>
      <div class="form-group">
        <label for="filter-search" class="form-label">Search</label>
        <input type="text" id="filter-search" name="search" value="{{filters.search}}" class="input input--sm" placeholder="Source or summary...">
      </div>
      <div class="form-group">
        <button type="submit" class="btn btn--primary btn--sm">Filter</button>
        <a href="/admin/change-history" class="btn btn--ghost btn--sm">Reset</a>
      </div>
    </div>
  </form>

  {{#if error}}
  <div class="alert alert--error mb-md" role="alert"><p>{{error}}</p></div>
  {{/if}}

  <p class="text-muted">{{total}} result(s)</p>

  <div class="table-wrapper" role="region" aria-label="Change history entries" tabindex="0">
    <table class="table">
      <thead>
        <tr>
          <th scope="col">Date</th>
          <th scope="col">Source</th>
          <th scope="col">Summary</th>
          <th scope="col">Type</th>
          <th scope="col">Action</th>
          <th scope="col">By</th>
          <th scope="col">Notes</th>
        </tr>
      </thead>
      <tbody>
        {{#each entries}}
        <tr>
          <td data-label="Date"><code>{{this.date}}</code></td>
          <td data-label="Source">{{this.source}}</td>
          <td data-label="Summary">{{this.summary}}</td>
          <td data-label="Type">
            <span class="badge {{#if (eq this.type 'Official')}}badge--info{{else}}badge--neutral{{/if}}">{{this.type}}</span>
          </td>
          <td data-label="Action">
            <span class="badge {{#if (eq this.action 'dismissed')}}badge--error{{else if (eq this.action 'rejected')}}badge--error{{else}}badge--success{{/if}}">{{this.action}}</span>
          </td>
          <td data-label="By">{{this.by}}</td>
          <td data-label="Notes">{{this.notes}}</td>
        </tr>
        {{else}}
        <tr>
          <td colspan="7" class="text-center text-muted">No change history records found.</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>

  {{#if prevPage}}
  <nav class="pagination mt-md" aria-label="Pages">
    <a href="/admin/change-history?page={{prevPage}}&from={{filters.from}}&to={{filters.to}}&action={{filters.action}}&search={{filters.search}}"
       class="btn btn--sm btn--ghost">&laquo; Prev</a>
    <span class="text-muted">Page {{page}} of {{totalPages}}</span>
    {{#if nextPage}}
    <a href="/admin/change-history?page={{nextPage}}&from={{filters.from}}&to={{filters.to}}&action={{filters.action}}&search={{filters.search}}"
       class="btn btn--sm btn--ghost">Next &raquo;</a>
    {{/if}}
  </nav>
  {{else}}
  {{#if nextPage}}
  <nav class="pagination mt-md" aria-label="Pages">
    <span class="text-muted">Page {{page}} of {{totalPages}}</span>
    <a href="/admin/change-history?page={{nextPage}}&from={{filters.from}}&to={{filters.to}}&action={{filters.action}}&search={{filters.search}}"
       class="btn btn--sm btn--ghost">Next &raquo;</a>
  </nav>
  {{/if}}
  {{/if}}
</section>
