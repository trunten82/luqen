<section aria-label="LLM configuration">
  <div class="page-actions">
    <h1 class="page-title">LLM Configuration</h1>
  </div>

  <div id="toast-container" aria-live="polite" role="region" aria-label="Notifications"></div>
  <div id="llm-messages" aria-live="polite"></div>

  {{!-- Global CSRF token for HTMX buttons outside forms --}}
  <input type="hidden" name="_csrf" id="global-csrf" value="{{csrfToken}}">

  {{#if error}}
  <div class="alert alert--error" role="alert">{{error}}</div>
  {{/if}}

  {{#unless llmConnected}}
  <div class="alert alert--warning" role="status">
    LLM service not reachable. Set <code>DASHBOARD_LLM_URL</code> and ensure the service is running.
  </div>
  {{else}}

  {{!-- Tab navigation (server-side, same pattern as proposals) --}}
  <div class="tabs" role="tablist" aria-label="LLM management sections">
    <a href="/admin/llm?tab=providers"
       class="tab {{#if (eq activeTab 'providers')}}tab--active{{/if}}"
       aria-current="{{#if (eq activeTab 'providers')}}page{{/if}}">
      Providers
    </a>
    <a href="/admin/llm?tab=models"
       class="tab {{#if (eq activeTab 'models')}}tab--active{{/if}}"
       aria-current="{{#if (eq activeTab 'models')}}page{{/if}}">
      Models
    </a>
    <a href="/admin/llm?tab=capabilities"
       class="tab {{#if (eq activeTab 'capabilities')}}tab--active{{/if}}"
       aria-current="{{#if (eq activeTab 'capabilities')}}page{{/if}}">
      Capabilities
    </a>
    <a href="/admin/llm?tab=prompts"
       class="tab {{#if (eq activeTab 'prompts')}}tab--active{{/if}}"
       aria-current="{{#if (eq activeTab 'prompts')}}page{{/if}}">
      Prompts
    </a>
  </div>

  {{!-- ── PROVIDERS TAB ──────────────────────────────────────────────────── --}}
  {{#if (eq activeTab 'providers')}}
  <div id="tab-providers" class="tab-content" role="tabpanel">

    <div class="table-responsive mt-sm" role="region" aria-label="LLM providers table" tabindex="0">
      <table class="table" aria-label="LLM providers">
        <thead>
          <tr>
            <th scope="col">Name</th>
            <th scope="col">Type</th>
            <th scope="col">Base URL</th>
            <th scope="col">Status</th>
            <th scope="col">{{t "common.actions"}}</th>
          </tr>
        </thead>
        <tbody>
          {{#each providers}}
          <tr id="provider-{{id}}">
            <td data-label="Name">{{name}}</td>
            <td data-label="Type"><span class="badge badge--neutral">{{type}}</span></td>
            <td data-label="Base URL">{{#if baseUrl}}<code style="word-break: break-all">{{baseUrl}}</code>{{else}}&mdash;{{/if}}</td>
            <td data-label="Status">
              <span class="badge {{statusClass}}">{{statusLabel}}</span>
            </td>
            <td data-label="Actions">
              <div class="btn-group">
                <form hx-post="/admin/llm/providers/{{id}}/test"
                      hx-target="#llm-messages"
                      hx-swap="innerHTML"
                      style="display:inline">
                  <input type="hidden" name="_csrf" value="{{../csrfToken}}">
                  <button type="submit" class="btn btn--sm btn--secondary">Test</button>
                </form>
                <form hx-delete="/admin/llm/providers/{{id}}"
                      hx-confirm="Delete provider {{name}}? All associated models will also be removed."
                      hx-target="#llm-messages"
                      hx-swap="innerHTML"
                      style="display:inline">
                  <input type="hidden" name="_csrf" value="{{../csrfToken}}">
                  <button type="submit" class="btn btn--sm btn--danger">Delete</button>
                </form>
              </div>
            </td>
          </tr>
          {{else}}
          <tr>
            <td colspan="5">No providers configured. Add one below.</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>

    {{!-- Add provider form --}}
    <div class="card mt-md">
      <div class="card__header">
        <h2 class="card__title">Add Provider</h2>
      </div>
      <form class="card__body"
            hx-post="/admin/llm/providers"
            hx-target="#llm-messages"
            hx-swap="innerHTML"
            data-reset-on-success>
        <input type="hidden" name="_csrf" value="{{csrfToken}}">
        <div class="form-row" style="flex-wrap: wrap">
          <div class="form-group">
            <label for="prov-name">Name <span aria-hidden="true">*</span></label>
            <input type="text" id="prov-name" name="name" class="input" required
                   placeholder="e.g. OpenAI Production" />
          </div>
          <div class="form-group">
            <label for="prov-type">Type <span aria-hidden="true">*</span></label>
            <select id="prov-type" name="type" class="input" required>
              <option value="openai">OpenAI</option>
              <option value="anthropic">Anthropic</option>
              <option value="ollama">Ollama</option>
              <option value="openai-compatible">OpenAI Compatible</option>
            </select>
          </div>
        </div>
        <div class="form-row" style="flex-wrap: wrap">
          <div class="form-group">
            <label for="prov-apikey">API Key</label>
            <input type="password" id="prov-apikey" name="apiKey" class="input"
                   placeholder="sk-..." autocomplete="new-password" />
            <small class="form-hint">Leave blank for local providers (Ollama)</small>
          </div>
          <div class="form-group">
            <label for="prov-baseurl">Base URL</label>
            <input type="url" id="prov-baseurl" name="baseUrl" class="input"
                   placeholder="http://localhost:11434" />
            <small class="form-hint">Required for Ollama / OpenAI-compatible endpoints</small>
          </div>
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn--primary">Add Provider</button>
        </div>
      </form>
    </div>
  </div>
  {{/if}}

  {{!-- ── MODELS TAB ───────────────────────────────────────────────────────── --}}
  {{#if (eq activeTab 'models')}}
  <div id="tab-models" class="tab-content" role="tabpanel">

    {{#if providers}}
    {{#each modelsByProvider}}
    <div class="card mt-sm">
      <div class="card__header">
        <h2 class="card__title">{{name}}</h2>
        <span class="badge badge--neutral">{{type}}</span>
      </div>
      <div class="card__body">
        {{#if models.length}}
        <div class="table-responsive" role="region" aria-label="Models for {{name}}" tabindex="0">
          <table class="table" aria-label="Models for {{name}}">
            <thead>
              <tr>
                <th scope="col">Model ID</th>
                <th scope="col">Display Name</th>
                <th scope="col">Status</th>
                <th scope="col">{{t "common.actions"}}</th>
              </tr>
            </thead>
            <tbody>
              {{#each models}}
              <tr id="model-{{id}}">
                <td data-label="Model ID"><code style="word-break: break-all">{{modelId}}</code></td>
                <td data-label="Display Name">{{displayName}}</td>
                <td data-label="Status">
                  <span class="badge {{statusClass}}">{{statusLabel}}</span>
                </td>
                <td data-label="Actions">
                  <form hx-delete="/admin/llm/models/{{id}}"
                        hx-confirm="Delete model {{displayName}}?"
                        hx-target="#llm-messages"
                        hx-swap="innerHTML"
                        style="display:inline">
                    <input type="hidden" name="_csrf" value="{{../../csrfToken}}">
                    <button type="submit" class="btn btn--sm btn--danger">Delete</button>
                  </form>
                </td>
              </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
        {{else}}
        <p class="text-muted">No models registered for this provider.</p>

        {{/if}}
      </div>
    </div>
    {{/each}}
    {{else}}
    <div class="alert alert--warning mt-sm">No providers configured. Add a provider first.</div>
    {{/if}}

    {{!-- Register model form --}}
    {{#if providers}}
    <div class="card mt-md">
      <div class="card__header">
        <h2 class="card__title">Register Model</h2>
      </div>
      <form class="card__body"
            hx-post="/admin/llm/models"
            hx-target="#llm-messages"
            hx-swap="innerHTML"
            data-reset-on-success>
        <input type="hidden" name="_csrf" value="{{csrfToken}}">
        <div class="form-row" style="flex-wrap: wrap">
          <div class="form-group">
            <label for="model-provider">Provider <span aria-hidden="true">*</span></label>
            <select id="model-provider" name="providerId" class="input" required
                    hx-get="/admin/llm/remote-models"
                    hx-target="#remote-model-list"
                    hx-swap="innerHTML"
                    hx-trigger="change"
                    hx-include="this">
              <option value="">Select provider...</option>
              {{#each providers}}
              <option value="{{id}}">{{name}}</option>
              {{/each}}
            </select>
          </div>
          <div class="form-group">
            <label for="remote-model-list">Model <span aria-hidden="true">*</span></label>
            <select id="remote-model-list" name="modelId" class="input" required>
              <option value="">Select provider first...</option>
            </select>
          </div>
        </div>
        <div class="form-row" style="flex-wrap: wrap">
          <div class="form-group">
            <label for="model-name">Display Name <span aria-hidden="true">*</span></label>
            <input type="text" id="model-name" name="displayName" class="input" required
                   placeholder="e.g. GPT-4o" />
          </div>
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn--primary">Register Model</button>
        </div>
      </form>
    </div>
    {{/if}}
  </div>
  {{/if}}

  {{!-- ── CAPABILITIES TAB ─────────────────────────────────────────────────── --}}
  {{#if (eq activeTab 'capabilities')}}
  <div id="tab-capabilities" class="tab-content" role="tabpanel">

    {{#if capabilities}}
    <div class="cards mt-sm">
      {{#each capabilities}}
      <div class="card">
        <div class="card__header">
          <h2 class="card__title"><code>{{name}}</code></h2>
        </div>
        <div class="card__body">
          {{#if assignedModels.length}}
          <p class="form-hint">Assigned models:</p>
          <ul class="badge-list">
            {{#each assignedModels}}
            <li>
              <span class="badge badge--info">{{name}}</span>
              <form hx-delete="/admin/llm/capabilities/{{../name}}/unassign/{{id}}"
                    hx-confirm="Unassign this model from {{../name}}?"
                    hx-target="#llm-messages"
                    hx-swap="innerHTML"
                    style="display:inline">
                <input type="hidden" name="_csrf" value="{{../../csrfToken}}">
                <button type="submit"
                  class="btn btn--xs btn--ghost"
                  aria-label="Unassign {{name}}">&times;</button>
              </form>
            </li>
            {{/each}}
          </ul>
          {{else}}
          <p class="text-muted">No models assigned.</p>
          {{/if}}

          {{#if ../models.length}}
          <form class="mt-sm"
                hx-put="/admin/llm/capabilities/{{name}}/assign"
                hx-target="#llm-messages"
                hx-swap="innerHTML"
                data-reset-on-success>
            <input type="hidden" name="_csrf" value="{{../csrfToken}}">
            <div class="form-row" style="flex-wrap: wrap">
              <div class="form-group" style="flex:1">
                <label for="cap-model-{{name}}" class="sr-only">Assign model to {{name}}</label>
                <select id="cap-model-{{name}}" name="modelId" class="input" required>
                  <option value="">Assign model...</option>
                  {{#each ../models}}
                  <option value="{{id}}">{{displayName}} ({{modelId}})</option>
                  {{/each}}
                </select>
              </div>
              <button type="submit" class="btn btn--primary btn--sm">Assign</button>
            </div>
          </form>
          {{/if}}
        </div>
      </div>
      {{/each}}
    </div>
    {{else}}
    <div class="alert alert--warning mt-sm">No capabilities found. Ensure the LLM service is seeded.</div>
    {{/if}}
  </div>
  {{/if}}

  {{!-- ── PROMPTS TAB ──────────────────────────────────────────────────────── --}}
  {{#if (eq activeTab 'prompts')}}
  <div id="tab-prompts" class="tab-content" role="tabpanel">

    {{#if prompts}}
    {{#each prompts}}
    <div class="card mt-sm">
      <div class="card__header">
        <h2 class="card__title"><code>{{capability}}</code></h2>
        {{#if isCustom}}
        <span class="badge badge--info">Custom</span>
        {{else if template}}
        <span class="badge badge--neutral">Default</span>
        {{else}}
        <span class="badge badge--neutral">Not Available</span>
        {{/if}}
      </div>
      {{#if template}}
      <form class="card__body"
            hx-put="/admin/llm/prompts/{{capability}}"
            hx-target="#llm-messages"
            hx-swap="innerHTML">
        <input type="hidden" name="_csrf" value="{{../csrfToken}}">
        <div class="form-group">
          <label for="prompt-{{capability}}">Prompt Template</label>
          <textarea id="prompt-{{capability}}" name="template" class="input"
                    rows="8"
                    placeholder="Enter prompt template...">{{template}}</textarea>
          <small class="form-hint">Use <code>{{"{{"}}content{{"}}"}}</code> to inject the document text.</small>
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn--primary">Save Override</button>
        </div>
      </form>
      {{#if isCustom}}
      <form class="card__body" style="padding-top:0"
            hx-delete="/admin/llm/prompts/{{capability}}"
            hx-confirm="Reset prompt for {{capability}} to the default?"
            hx-target="#llm-messages"
            hx-swap="innerHTML">
        <input type="hidden" name="_csrf" value="{{../csrfToken}}">
        <div class="form-actions">
          <button type="submit" class="btn btn--secondary">Reset to Default</button>
        </div>
      </form>
      {{/if}}
      {{else}}
      <div class="card__body">
        <p class="text-muted">This capability does not have a prompt template yet. It will be available in a future update.</p>
      </div>
      {{/if}}
    </div>
    {{/each}}
    {{else}}
    <div class="alert alert--info mt-sm">Prompt management is not available when the LLM service is disconnected.</div>
    {{/if}}
  </div>
  {{/if}}

  {{/unless}}

  <script>
  (function () {
    var userEditedName = false;

    var nameInput = document.getElementById('model-name');
    if (nameInput) {
      nameInput.addEventListener('input', function () {
        userEditedName = true;
      });
    }

    /* Auto-fill display name from selected remote model */
    document.addEventListener('change', function (e) {
      if (e.target && e.target.id === 'remote-model-list') {
        var ni = document.getElementById('model-name');
        if (ni && !userEditedName) {
          ni.value = e.target.options[e.target.selectedIndex].text;
        }
      }
    });

    /* Reset flag when provider changes (new model list loaded) */
    document.addEventListener('change', function (e) {
      if (e.target && e.target.id === 'model-provider') {
        userEditedName = false;
        var ni = document.getElementById('model-name');
        if (ni) ni.value = '';
      }
    });
  })();
  </script>
</section>
