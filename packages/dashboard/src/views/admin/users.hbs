<section aria-label="Users management">
  <div class="page-actions">
    <button hx-get="/admin/users/new"
            hx-target="#modal-container"
            hx-swap="innerHTML"
            class="btn btn--primary"
            aria-haspopup="dialog">
      {{t "admin.users.addUser"}}
    </button>
  </div>

  {{#if error}}
  <div class="alert alert--error" role="alert">
    <p>{{error}}</p>
  </div>
  {{/if}}

  <div class="table-wrapper" aria-live="polite" aria-atomic="false">
    <table class="table" aria-label="Users">
      <thead>
        <tr>
          <th scope="col">{{t "admin.users.username"}}</th>
          <th scope="col">{{t "admin.users.role"}}</th>
          <th scope="col">{{t "admin.users.created"}}</th>
          <th scope="col">{{t "common.status"}}</th>
          <th scope="col">{{t "common.actions"}}</th>
        </tr>
      </thead>
      <tbody id="users-table-body">
        {{#each users}}
        <tr id="user-{{id}}">
          <td data-label="Username">{{username}}</td>
          <td data-label="Role"><span class="badge badge--neutral">{{role}}</span></td>
          <td data-label="Created">{{createdAtDisplay}}</td>
          <td data-label="Status">
            <span class="badge {{#if active}}badge--success{{else}}badge--error{{/if}}">
              {{#if active}}{{t "common.active"}}{{else}}{{t "common.inactive"}}{{/if}}
            </span>
          </td>
          <td>
            {{#if active}}
            <button hx-post="/admin/users/{{id}}/deactivate"
                    hx-confirm="Deactivate user {{username}}?"
                    hx-target="#user-{{id}}"
                    hx-swap="outerHTML"
                    class="btn btn--sm btn--warning"
                    aria-label="Deactivate {{username}}">{{t "admin.users.deactivate"}}</button>
      <input type="hidden" name="_csrf" value="{{csrfToken}}">
            {{/if}}
          </td>
        </tr>
        {{else}}
        <tr>
          <td colspan="5" class="table__empty">{{t "admin.users.noUsers"}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</section>
