<tr id="system-branding-guideline-{{id}}">
  <td class="table__cell" data-label="Logo">
    {{#if imagePath}}
    <img src="{{imagePath}}"
         alt="{{name}} brand logo"
         width="40" height="40"
         style="width:40px;height:40px;max-width:40px;max-height:40px;border-radius:var(--radius-sm);object-fit:contain;background:var(--bg-secondary);">
    {{else}}
    <div style="width:40px;height:40px;border-radius:var(--radius-sm);background:var(--bg-secondary);display:flex;align-items:center;justify-content:center;">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <rect x="3" y="3" width="14" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/>
        <circle cx="7" cy="7" r="1.5" fill="currentColor"/>
        <path d="M3 13 L7 9 L11 13 L14 10 L17 13" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linejoin="round"/>
      </svg>
    </div>
    {{/if}}
  </td>
  <td data-label="Name">
    <span>{{name}}</span>
    {{#if description}}
    <p class="text-sm text-muted">{{description}}</p>
    {{/if}}
  </td>
  <td data-label="Scope">
    <span class="badge badge--info">{{t "admin.systemBrand.systemBadge"}}</span>
  </td>
  <td data-label="Version">
    {{#if version}}
    <span class="badge badge--info">v{{version}}</span>
    {{else}}
    <span class="text-muted">—</span>
    {{/if}}
  </td>
  <td>
    <div style="display:flex;flex-direction:column;gap:var(--space-xs);">
      <details class="inline-details">
        <summary class="btn btn--sm btn--secondary" style="width:100%;"
                 aria-label="Link to site — {{name}}">
          {{t "admin.systemBrand.action.linkToSite"}}
        </summary>
        <form hx-post="/admin/branding-guidelines/{{id}}/sites"
              hx-target="#branding-guidelines-alert"
              hx-swap="innerHTML"
              data-reset-on-success
              style="display:flex;flex-direction:column;gap:var(--space-xs);margin-top:var(--space-xs);">
          <input type="hidden" name="_csrf" value="{{../csrfToken}}">
          <input type="url" name="siteUrl" class="input input--sm"
                 placeholder="https://example.com" required
                 aria-label="{{t "admin.branding.siteUrl"}}">
          <button type="submit" class="btn btn--sm btn--primary">
            {{t "admin.branding.assign"}}
          </button>
        </form>
      </details>
      <details class="inline-details">
        <summary class="btn btn--sm btn--primary" style="width:100%;"
                 aria-label="Clone {{name}} into organization">
          {{t "admin.systemBrand.action.cloneIntoOrg"}}
        </summary>
        <form hx-post="/admin/branding-guidelines/system/{{id}}/clone"
              hx-target="#branding-guidelines-alert"
              hx-swap="innerHTML"
              style="display:flex;flex-direction:column;gap:var(--space-xs);margin-top:var(--space-xs);">
          <input type="hidden" name="_csrf" value="{{../csrfToken}}">
          <input type="text" name="name" class="input input--sm"
                 value="{{name}} (cloned)" required
                 aria-label="{{t "admin.systemBrand.cloneName"}}">
          <button type="submit" class="btn btn--sm btn--primary">
            {{t "admin.systemBrand.action.cloneConfirm"}}
          </button>
        </form>
      </details>
    </div>
  </td>
</tr>
