<section aria-label="Update proposals management">
  <div class="filter-bar">
    <label for="proposal-status-filter" class="form-label">{{t "common.status"}}</label>
    <select id="proposal-status-filter"
            name="status"
            hx-get="/admin/proposals"
            hx-trigger="change"
            hx-target="#proposals-table-body"
            class="select"
            aria-label="Filter proposals by status">
      <option value="" {{#if (eq statusFilter '')}}selected{{/if}}>{{t "admin.proposals.allStatuses"}}</option>
      <option value="pending" {{#if (eq statusFilter 'pending')}}selected{{/if}}>{{t "admin.proposals.statusPending"}}</option>
      <option value="approved" {{#if (eq statusFilter 'approved')}}selected{{/if}}>{{t "admin.proposals.statusApproved"}}</option>
      <option value="rejected" {{#if (eq statusFilter 'rejected')}}selected{{/if}}>{{t "admin.proposals.statusRejected"}}</option>
    </select>
  </div>

  {{#if error}}
  <div class="alert alert--error" role="alert">
    <p>{{error}}</p>
  </div>
  {{/if}}

  <div class="table-wrapper" aria-live="polite" aria-atomic="false">
    <table class="table" aria-label="Update proposals">
      <thead>
        <tr>
          <th scope="col">{{t "admin.proposals.colSource"}}</th>
          <th scope="col">{{t "admin.proposals.colType"}}</th>
          <th scope="col">{{t "admin.proposals.colSummary"}}</th>
          <th scope="col">{{t "admin.proposals.colDetected"}}</th>
          <th scope="col">{{t "common.status"}}</th>
          <th scope="col">{{t "common.actions"}}</th>
        </tr>
      </thead>
      <tbody id="proposals-table-body">
        {{#each proposals}}
        <tr id="proposal-{{id}}">
          <td data-label="Source">{{source}}</td>
          <td data-label="Type">{{type}}</td>
          <td data-label="Summary">{{summary}}</td>
          <td data-label="Detected">{{detectedAtDisplay}}</td>
          <td data-label="Status">
            <span class="badge {{#if (eq status 'pending')}}badge--warning{{else if (eq status 'approved')}}badge--success{{else}}badge--error{{/if}}">
              {{status}}
            </span>
          </td>
          <td>
            {{#if isPending}}
            <button hx-post="/admin/proposals/{{id}}/approve"
                    hx-confirm="{{t "admin.proposals.confirmApprove"}}"
                    hx-target="#proposal-{{id}}"
                    hx-swap="outerHTML"
                    class="btn btn--sm btn--success"
                    aria-label="Approve proposal: {{summary}}">{{t "admin.proposals.approve"}}</button>
            <button hx-post="/admin/proposals/{{id}}/reject"
                    hx-confirm="{{t "admin.proposals.confirmReject"}}"
                    hx-target="#proposal-{{id}}"
                    hx-swap="outerHTML"
                    class="btn btn--sm btn--danger"
                    aria-label="Reject proposal: {{summary}}">{{t "admin.proposals.reject"}}</button>
            {{/if}}
          </td>
        </tr>
        {{else}}
        <tr>
          <td colspan="6" class="table__empty">{{t "admin.proposals.noProposals"}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</section>
