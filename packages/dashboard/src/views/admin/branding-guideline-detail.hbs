<section aria-label="Branding guideline detail">

  {{!-- Header --}}
  <div class="admin-header">
    <div class="flex flex-wrap items-center gap-sm mb-sm">
      <a href="/admin/branding-guidelines" class="btn btn--ghost btn--sm">&larr; Back to Guidelines</a>
    </div>
    <div class="flex flex-wrap items-center gap-sm">
      <h2 class="page-header__title">{{guideline.name}}</h2>
      {{#if guideline.version}}
      <span class="badge badge--info">v{{guideline.version}}</span>
      {{/if}}
      {{#if guideline.active}}
      <span class="badge badge--success">{{t "common.active"}}</span>
      {{else}}
      <span class="badge badge--neutral">{{t "common.inactive"}}</span>
      {{/if}}
    </div>
    {{#if guideline.description}}
    <p class="text-muted mt-xs">{{guideline.description}}</p>
    {{/if}}

    {{#if perm.brandingManage}}
    <div class="flex flex-wrap gap-sm mt-sm">
      <button hx-post="/admin/branding-guidelines/{{guideline.id}}/toggle"
              hx-target="#branding-detail-toast"
              hx-swap="innerHTML"
              class="btn btn--sm btn--ghost">
        <input type="hidden" name="_csrf" value="{{csrfToken}}">
        {{#if guideline.active}}Deactivate{{else}}Activate{{/if}}
      </button>
      <button hx-post="/admin/branding-guidelines/{{guideline.id}}/delete"
              hx-confirm="Delete guideline &quot;{{guideline.name}}&quot;? This cannot be undone."
              hx-target="#branding-detail-toast"
              hx-swap="innerHTML"
              class="btn btn--sm btn--danger">
        <input type="hidden" name="_csrf" value="{{csrfToken}}">
        {{t "common.delete"}}
      </button>
    </div>
    {{/if}}
  </div>

  <div id="branding-detail-toast" aria-live="polite"></div>

  {{!-- Tab navigation --}}
  <div class="tabs" role="tablist" aria-label="Guideline sections">
    <button class="tab tab--active" role="tab" aria-selected="true" aria-controls="tab-colors"
            data-action="switch-tab" data-target-show="tab-colors" data-target-hide="tab-fonts tab-selectors tab-sites tab-import"
            data-peer="tab-btn-fonts tab-btn-selectors tab-btn-sites tab-btn-import"
            id="tab-btn-colors">
      Colors <span class="badge badge--neutral">{{colors.length}}</span>
    </button>
    <button class="tab" role="tab" aria-selected="false" aria-controls="tab-fonts"
            data-action="switch-tab" data-target-show="tab-fonts" data-target-hide="tab-colors tab-selectors tab-sites tab-import"
            data-peer="tab-btn-colors tab-btn-selectors tab-btn-sites tab-btn-import"
            id="tab-btn-fonts">
      Fonts <span class="badge badge--neutral">{{fonts.length}}</span>
    </button>
    <button class="tab" role="tab" aria-selected="false" aria-controls="tab-selectors"
            data-action="switch-tab" data-target-show="tab-selectors" data-target-hide="tab-colors tab-fonts tab-sites tab-import"
            data-peer="tab-btn-colors tab-btn-fonts tab-btn-sites tab-btn-import"
            id="tab-btn-selectors">
      Selectors <span class="badge badge--neutral">{{selectors.length}}</span>
    </button>
    <button class="tab" role="tab" aria-selected="false" aria-controls="tab-sites"
            data-action="switch-tab" data-target-show="tab-sites" data-target-hide="tab-colors tab-fonts tab-selectors tab-import"
            data-peer="tab-btn-colors tab-btn-fonts tab-btn-selectors tab-btn-import"
            id="tab-btn-sites">
      Sites <span class="badge badge--neutral">{{sites.length}}</span>
    </button>
    <button class="tab" role="tab" aria-selected="false" aria-controls="tab-import"
            data-action="switch-tab" data-target-show="tab-import" data-target-hide="tab-colors tab-fonts tab-selectors tab-sites"
            data-peer="tab-btn-colors tab-btn-fonts tab-btn-selectors tab-btn-sites"
            id="tab-btn-import">
      Import / Export
    </button>
  </div>

  {{!-- Colors tab --}}
  <div id="tab-colors" role="tabpanel" aria-labelledby="tab-btn-colors">
    {{#if perm.brandingManage}}
    <form hx-post="/admin/branding-guidelines/{{guideline.id}}/colors"
          hx-target="#branding-detail-toast"
          hx-swap="innerHTML"
          data-reset-on-success
          class="card mb-lg mt-md">
      <input type="hidden" name="_csrf" value="{{csrfToken}}">
      <h3>Add Color</h3>
      <div class="flex flex-wrap gap-sm mt-sm">
        <div class="form-group form-group--inline">
          <label class="form-label" for="color-name">Name</label>
          <input id="color-name" type="text" name="name" class="input" placeholder="Primary Blue" required>
        </div>
        <div class="form-group form-group--inline">
          <label class="form-label" for="color-hex">Hex Value</label>
          <input id="color-hex" type="text" name="hexValue" class="input" placeholder="#0056b3" pattern="^#[0-9a-fA-F]{3,8}$" required>
        </div>
        <div class="form-group form-group--inline">
          <label class="form-label" for="color-usage">Usage</label>
          <input id="color-usage" type="text" name="usage" class="input" placeholder="primary">
        </div>
        <div class="form-group form-group--inline">
          <label class="form-label" for="color-context">Context</label>
          <input id="color-context" type="text" name="context" class="input" placeholder="backgrounds, buttons">
        </div>
        <button type="submit" class="btn btn--primary btn--sm">Add Color</button>
      </div>
    </form>
    {{/if}}

    {{#if colors.length}}
    <div class="card-grid">
      {{#each colors}}
      <div class="card card--compact" id="color-card-{{this.id}}">
        <div class="color-swatch" style="background-color: {{this.hexValue}}; width: 48px; height: 48px; border-radius: 4px; border: 1px solid var(--border-color);" aria-label="Color swatch for {{this.name}}"></div>
        <div class="mt-xs">
          <strong>{{this.name}}</strong>
          <code class="text-sm">{{this.hexValue}}</code>
          {{#if this.usage}}
          <span class="badge badge--info">{{this.usage}}</span>
          {{/if}}
          {{#if this.context}}
          <p class="text-sm text-muted">{{this.context}}</p>
          {{/if}}
        </div>
        {{#if ../perm.brandingManage}}
        <button hx-post="/admin/branding-guidelines/{{../guideline.id}}/colors/{{this.id}}/delete"
                hx-confirm="Remove color &quot;{{this.name}}&quot;?"
                hx-target="#color-card-{{this.id}}"
                hx-swap="outerHTML"
                class="btn btn--sm btn--danger mt-xs">
          <input type="hidden" name="_csrf" value="{{csrfToken}}">
          Remove
        </button>
        {{/if}}
      </div>
      {{/each}}
    </div>
    {{else}}
    <p class="text-muted mt-md">No colors defined. Add colors above to enable color matching.</p>
    {{/if}}
  </div>

  {{!-- Fonts tab --}}
  <div id="tab-fonts" role="tabpanel" aria-labelledby="tab-btn-fonts" class="rpt-tab-panel--hidden">
    {{#if perm.brandingManage}}
    <form hx-post="/admin/branding-guidelines/{{guideline.id}}/fonts"
          hx-target="#branding-detail-toast"
          hx-swap="innerHTML"
          data-reset-on-success
          class="card mb-lg mt-md">
      <input type="hidden" name="_csrf" value="{{csrfToken}}">
      <h3>Add Font</h3>
      <div class="flex flex-wrap gap-sm mt-sm">
        <div class="form-group form-group--inline">
          <label class="form-label" for="font-family">Family</label>
          <input id="font-family" type="text" name="family" class="input" placeholder="Helvetica Neue" required>
        </div>
        <div class="form-group form-group--inline">
          <label class="form-label" for="font-weights">Weights (comma-separated)</label>
          <input id="font-weights" type="text" name="weights" class="input" placeholder="400, 700">
        </div>
        <div class="form-group form-group--inline">
          <label class="form-label" for="font-usage">Usage</label>
          <input id="font-usage" type="text" name="usage" class="input" placeholder="body">
        </div>
        <button type="submit" class="btn btn--primary btn--sm">Add Font</button>
      </div>
    </form>
    {{/if}}

    {{#if fonts.length}}
    <div class="card-grid">
      {{#each fonts}}
      <div class="card card--compact" id="font-card-{{this.id}}">
        <strong>{{this.family}}</strong>
        {{#if this.weights}}
        <p class="text-sm text-muted">Weights: {{this.weights}}</p>
        {{/if}}
        {{#if this.usage}}
        <span class="badge badge--info">{{this.usage}}</span>
        {{/if}}
        {{#if ../perm.brandingManage}}
        <button hx-post="/admin/branding-guidelines/{{../guideline.id}}/fonts/{{this.id}}/delete"
                hx-confirm="Remove font &quot;{{this.family}}&quot;?"
                hx-target="#font-card-{{this.id}}"
                hx-swap="outerHTML"
                class="btn btn--sm btn--danger mt-xs">
          <input type="hidden" name="_csrf" value="{{csrfToken}}">
          Remove
        </button>
        {{/if}}
      </div>
      {{/each}}
    </div>
    {{else}}
    <p class="text-muted mt-md">No fonts defined. Add fonts above to enable font matching.</p>
    {{/if}}
  </div>

  {{!-- Selectors tab --}}
  <div id="tab-selectors" role="tabpanel" aria-labelledby="tab-btn-selectors" class="rpt-tab-panel--hidden">
    {{#if perm.brandingManage}}
    <form hx-post="/admin/branding-guidelines/{{guideline.id}}/selectors"
          hx-target="#branding-detail-toast"
          hx-swap="innerHTML"
          data-reset-on-success
          class="card mb-lg mt-md">
      <input type="hidden" name="_csrf" value="{{csrfToken}}">
      <h3>Add Selector</h3>
      <div class="flex flex-wrap gap-sm mt-sm">
        <div class="form-group form-group--inline">
          <label class="form-label" for="selector-pattern">Pattern</label>
          <input id="selector-pattern" type="text" name="pattern" class="input" placeholder=".brand-header, #hero-section" required>
        </div>
        <div class="form-group form-group--inline">
          <label class="form-label" for="selector-description">Description</label>
          <input id="selector-description" type="text" name="description" class="input" placeholder="Brand header elements">
        </div>
        <button type="submit" class="btn btn--primary btn--sm">Add Selector</button>
      </div>
    </form>
    {{/if}}

    {{#if selectors.length}}
    <div class="table-wrapper mt-md">
      <table class="table" aria-label="CSS selectors">
        <thead>
          <tr>
            <th scope="col">Pattern</th>
            <th scope="col">Description</th>
            {{#if perm.brandingManage}}
            <th scope="col">{{t "common.actions"}}</th>
            {{/if}}
          </tr>
        </thead>
        <tbody id="selectors-table">
          {{#each selectors}}
          <tr id="selector-row-{{this.id}}">
            <td data-label="Pattern"><code>{{this.pattern}}</code></td>
            <td data-label="Description">{{#if this.description}}{{this.description}}{{else}}<span class="text-muted">—</span>{{/if}}</td>
            {{#if ../perm.brandingManage}}
            <td>
              <button hx-post="/admin/branding-guidelines/{{../guideline.id}}/selectors/{{this.id}}/delete"
                      hx-confirm="Remove selector &quot;{{this.pattern}}&quot;?"
                      hx-target="#selector-row-{{this.id}}"
                      hx-swap="outerHTML"
                      class="btn btn--sm btn--danger">
                <input type="hidden" name="_csrf" value="{{csrfToken}}">
                Remove
              </button>
            </td>
            {{/if}}
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
    {{else}}
    <p class="text-muted mt-md">No selectors defined. Add selectors above to enable selector-based matching.</p>
    {{/if}}
  </div>

  {{!-- Sites tab --}}
  <div id="tab-sites" role="tabpanel" aria-labelledby="tab-btn-sites" class="rpt-tab-panel--hidden">
    {{#if perm.brandingManage}}
    <form hx-post="/admin/branding-guidelines/{{guideline.id}}/sites"
          hx-target="#branding-detail-toast"
          hx-swap="innerHTML"
          data-reset-on-success
          class="card mb-lg mt-md">
      <input type="hidden" name="_csrf" value="{{csrfToken}}">
      <h3>Assign to Site</h3>
      <div class="flex flex-wrap items-center gap-sm mt-sm">
        <div class="form-group form-group--inline">
          <label class="form-label" for="site-url">Site URL</label>
          <input id="site-url" type="url" name="siteUrl" class="input" placeholder="https://example.com" required>
        </div>
        <button type="submit" class="btn btn--primary btn--sm">Assign</button>
      </div>
    </form>
    {{/if}}

    {{#if sites.length}}
    <div class="table-wrapper mt-md">
      <table class="table" aria-label="Assigned sites">
        <thead>
          <tr>
            <th scope="col">Site URL</th>
            <th scope="col">Assigned</th>
            {{#if perm.brandingManage}}
            <th scope="col">{{t "common.actions"}}</th>
            {{/if}}
          </tr>
        </thead>
        <tbody id="sites-table">
          {{#each sites}}
          <tr id="site-row-{{@index}}">
            <td data-label="Site URL">{{this.siteUrl}}</td>
            <td data-label="Assigned">{{this.assignedAt}}</td>
            {{#if ../perm.brandingManage}}
            <td>
              <button hx-post="/admin/branding-guidelines/{{../guideline.id}}/sites/unassign"
                      hx-confirm="Unassign &quot;{{this.siteUrl}}&quot; from this guideline?"
                      hx-target="#site-row-{{@index}}"
                      hx-swap="outerHTML"
                      class="btn btn--sm btn--warning">
                <input type="hidden" name="_csrf" value="{{csrfToken}}">
                <input type="hidden" name="siteUrl" value="{{this.siteUrl}}">
                Unassign
              </button>
            </td>
            {{/if}}
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
    {{else}}
    <p class="text-muted mt-md">No sites assigned. Assign a site above to apply this guideline to its scans.</p>
    {{/if}}
  </div>

  {{!-- Import / Export tab --}}
  <div id="tab-import" role="tabpanel" aria-labelledby="tab-btn-import" class="rpt-tab-panel--hidden">
    <div class="card mt-md mb-lg">
      <h3>Export Templates</h3>
      <p class="text-muted mb-sm">Download blank templates to see the expected format for importing data.</p>
      <div class="flex gap-sm">
        <a href="/admin/branding-guidelines/templates/csv" class="btn btn--ghost btn--sm">Download CSV Template</a>
        <a href="/admin/branding-guidelines/templates/json" class="btn btn--ghost btn--sm">Download JSON Template</a>
      </div>
    </div>

    {{#if perm.brandingManage}}
    <div class="card">
      <h3>Import Data</h3>
      <p class="text-muted mb-sm">Upload a CSV or JSON file to import colors, fonts, and selectors for this guideline.</p>
      <form hx-post="/admin/branding-guidelines/upload"
            hx-target="#branding-detail-toast"
            hx-swap="innerHTML"
            class="mt-md">
        <input type="hidden" name="_csrf" value="{{csrfToken}}">
        <input type="hidden" name="guidelineId" value="{{guideline.id}}">
        <div class="form-group">
          <label class="form-label" for="import-content">Content (CSV or JSON)</label>
          <textarea id="import-content"
                    name="content"
                    class="input"
                    rows="8"
                    placeholder="Paste CSV or JSON content here…"></textarea>
        </div>
        <div class="form-group">
          <label class="form-label" for="import-format">Format</label>
          <select id="import-format" name="format" class="select">
            <option value="csv">CSV</option>
            <option value="json">JSON</option>
          </select>
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn--primary">Import</button>
        </div>
      </form>
    </div>
    {{/if}}
  </div>

</section>
