<div class="modal-overlay" role="dialog" aria-modal="true" aria-labelledby="modal-title">
  <div class="modal">
    <h2 id="modal-title">{{t "admin.apiKeys.createApiKey"}}</h2>

    <form hx-post="/admin/api-keys"
          hx-target="#api-keys-table"
          hx-swap="beforeend"
          novalidate>
      <input type="hidden" name="_csrf" value="{{csrfToken}}">

      <div class="form-group">
        <label for="ak-label" class="form-label">{{t "admin.apiKeys.label"}} <span aria-hidden="true">*</span></label>
        <input id="ak-label" name="label" type="text" class="input"
               required aria-required="true" value="default"
               placeholder="{{t "admin.apiKeys.labelPlaceholder"}}">
      </div>

      <div class="form-group">
        <label for="ak-role" class="form-label">Role</label>
        <select id="ak-role" name="role" class="select">
          <option value="admin">Admin (full access)</option>
          <option value="read-only">Read Only (GET requests only)</option>
          <option value="scan-only">Scan Only (read + scan endpoints)</option>
        </select>
      </div>

      <div class="form-group">
        <label for="ak-ttl" class="form-label">Expiry</label>
        <select id="ak-ttl" name="ttl" class="select">
          <option value="30">30 days</option>
          <option value="90" selected>90 days</option>
          <option value="180">180 days</option>
          <option value="365">365 days</option>
          <option value="0">Never (use with care)</option>
        </select>
        <p id="ak-ttl-warning" class="text-muted" style="color:var(--status-warning)" hidden>
          Non-expiring keys cannot be rotated automatically. Prefer a finite TTL.
        </p>
      </div>

      <script>
        (function () {
          var sel = document.getElementById('ak-ttl');
          var warn = document.getElementById('ak-ttl-warning');
          if (!sel || !warn) return;
          function toggle() { warn.hidden = sel.value !== '0'; }
          sel.addEventListener('change', toggle); toggle();
        })();
      </script>

      <div class="form-actions">
        <button type="submit" class="btn btn--primary">{{t "admin.apiKeys.generateKey"}}</button>
        <button type="button" class="btn btn--ghost close-modal-btn"
                aria-label="Cancel and close dialog">{{t "common.cancel"}}</button>
      </div>
    </form>
  </div>
</div>
