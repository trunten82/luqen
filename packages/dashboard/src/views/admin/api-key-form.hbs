<div class="modal-overlay" role="dialog" aria-modal="true" aria-labelledby="modal-title">
  <div class="modal">
    <h2 id="modal-title">Create API Key</h2>

    <form hx-post="/admin/api-keys"
          hx-target="#api-keys-table"
          hx-swap="beforeend"
          hx-on::after-request="if(event.detail.successful) document.getElementById('modal-container').replaceChildren()"
          novalidate>

      <div class="form-group">
        <label for="ak-label" class="form-label">Label <span aria-hidden="true">*</span></label>
        <input id="ak-label" name="label" type="text" class="input"
               required aria-required="true" value="default"
               placeholder="e.g. CI pipeline, monitoring">
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn--primary">Generate Key</button>
        <button type="button" class="btn btn--ghost close-modal-btn"
                aria-label="Cancel and close dialog">Cancel</button>
      </div>
    </form>
  </div>
</div>
