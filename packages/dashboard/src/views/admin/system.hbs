<section aria-label="System health dashboard">
  <div class="cards">
    {{#each services}}
    <div class="card {{#if (eq status 'ok')}}card--success{{else if (eq status 'error')}}card--error{{else}}card--neutral{{/if}}"
         aria-label="{{label}} status: {{status}}">
      <div class="card__header">
        <h2 class="card__title">{{label}}</h2>
      </div>
      <div class="card__body">
        <span class="status-indicator {{#if (eq status 'ok')}}status--ok{{else if (eq status 'error')}}status--error{{else}}status--unknown{{/if}}"
              aria-label="Status: {{status}}">
          {{status}}
        </span>
      </div>
    </div>
    {{/each}}
  </div>

  <section class="admin-section" aria-label="Database statistics">
    <h2 class="section-title">{{t "admin.system.database"}}</h2>
    <dl class="stats-list">
      <div class="stats-list__item">
        <dt>{{t "admin.system.fileSize"}}</dt>
        <dd>{{db.sizeKb}} KB</dd>
      </div>
    </dl>
  </section>

  <section class="admin-section" aria-label="Compliance seed status">
    <h2 class="section-title">{{t "admin.system.seedStatus"}}</h2>
    <dl class="stats-list">
      <div class="stats-list__item">
        <dt>{{t "admin.system.seeded"}}</dt>
        <dd>
          <span class="badge {{#if seed.seeded}}badge--success{{else}}badge--warning{{/if}}">
            {{#if seed.seeded}}{{t "common.yes"}}{{else}}{{t "common.no"}}{{/if}}
          </span>
        </dd>
      </div>
      <div class="stats-list__item">
        <dt>{{t "admin.system.jurisdictions"}}</dt>
        <dd>{{seed.jurisdictions}}</dd>
      </div>
      <div class="stats-list__item">
        <dt>{{t "admin.system.regulations"}}</dt>
        <dd>{{seed.regulations}}</dd>
      </div>
      <div class="stats-list__item">
        <dt>{{t "admin.system.requirements"}}</dt>
        <dd>{{seed.requirements}}</dd>
      </div>
    </dl>
  </section>

  <section class="admin-section" aria-label="Runtime information">
    <h2 class="section-title">{{t "admin.system.runtime"}}</h2>
    <dl class="stats-list">
      <div class="stats-list__item">
        <dt>{{t "admin.system.dashboardVersion"}}</dt>
        <dd>{{version}}</dd>
      </div>
      <div class="stats-list__item">
        <dt>{{t "admin.system.nodeVersion"}}</dt>
        <dd>{{nodeVersion}}</dd>
      </div>
      <div class="stats-list__item">
        <dt>{{t "admin.system.uptime"}}</dt>
        <dd>{{uptime}}</dd>
      </div>
    </dl>
  </section>
</section>
