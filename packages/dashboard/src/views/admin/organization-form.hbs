<div class="modal-overlay" role="dialog" aria-modal="true" aria-labelledby="modal-title">
  <div class="modal">
    <h2 id="modal-title">{{t "admin.organizations.addOrganization"}}</h2>

    <form hx-post="/admin/organizations"
          hx-target="#organizations-table"
          hx-swap="beforeend"
          novalidate>
      <input type="hidden" name="_csrf" value="{{csrfToken}}">

      <div class="form-group">
        <label for="org-name" class="form-label">{{t "common.name"}} <span aria-hidden="true">*</span></label>
        <input id="org-name" name="name" type="text" class="input"
               required aria-required="true"
               placeholder="{{t "admin.organizations.namePlaceholder"}}">
      </div>

      <div class="form-group">
        <label for="org-slug" class="form-label">{{t "admin.organizations.slug"}} <span aria-hidden="true">*</span></label>
        <input id="org-slug" name="slug" type="text" class="input"
               required aria-required="true"
               pattern="[a-z0-9\-]+"
               placeholder="{{t "admin.organizations.slugPlaceholder"}}"
               aria-describedby="org-slug-hint">
        <span id="org-slug-hint" class="form-hint">{{t "admin.organizations.slugHint"}}</span>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn--primary">{{t "admin.organizations.createOrganization"}}</button>
        <button type="button" class="btn btn--ghost close-modal-btn"
                aria-label="Cancel and close dialog">{{t "common.cancel"}}</button>
      </div>
    </form>
  </div>
</div>
