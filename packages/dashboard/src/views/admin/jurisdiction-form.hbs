<div class="modal-overlay" role="dialog" aria-modal="true" aria-labelledby="modal-title">
  <div class="modal">
    <h2 id="modal-title">{{#if isNew}}{{t "admin.jurisdictions.addJurisdiction"}}{{else}}{{t "admin.jurisdictions.editJurisdiction"}}{{/if}}</h2>

    <form {{#if isNew}}
          hx-post="/admin/jurisdictions"
          hx-target="#jurisdictions-table-body"
          hx-swap="beforeend"
          {{else}}
          hx-patch="/admin/jurisdictions/{{jurisdiction.id}}"
          hx-target="#jurisdiction-{{jurisdiction.id}}"
          hx-swap="outerHTML"
          {{/if}}
          hx-on::after-request="if(event.detail.successful) document.getElementById('modal-container').replaceChildren()"
          novalidate>

      <div class="form-group">
        <label for="jur-id" class="form-label">{{t "admin.jurisdictions.fieldId"}} <span aria-hidden="true">*</span></label>
        <input id="jur-id"
               name="id"
               type="text"
               class="input"
               value="{{jurisdiction.id}}"
               {{#unless isNew}}readonly{{/unless}}
               required
               aria-required="true"
               aria-describedby="jur-id-hint">
        <span id="jur-id-hint" class="form-hint">{{t "admin.jurisdictions.fieldIdHint"}}</span>
      </div>

      <div class="form-group">
        <label for="jur-name" class="form-label">{{t "admin.jurisdictions.fieldName"}} <span aria-hidden="true">*</span></label>
        <input id="jur-name"
               name="name"
               type="text"
               class="input"
               value="{{jurisdiction.name}}"
               required
               aria-required="true">
      </div>

      <div class="form-group">
        <label for="jur-type" class="form-label">{{t "admin.jurisdictions.fieldType"}} <span aria-hidden="true">*</span></label>
        <input id="jur-type"
               name="type"
               type="text"
               class="input"
               value="{{jurisdiction.type}}"
               {{#unless isNew}}readonly{{/unless}}
               required
               aria-required="true"
               aria-describedby="jur-type-hint">
        <span id="jur-type-hint" class="form-hint">{{t "admin.jurisdictions.fieldTypeHint"}}</span>
      </div>

      <div class="form-group">
        <label for="jur-parent" class="form-label">{{t "admin.jurisdictions.fieldParentId"}}</label>
        <input id="jur-parent"
               name="parentId"
               type="text"
               class="input"
               value="{{jurisdiction.parentId}}">
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn--primary">
          {{#if isNew}}{{t "common.create"}}{{else}}{{t "common.save"}}{{/if}}
        </button>
        <button type="button"
                class="btn btn--ghost close-modal-btn"
                aria-label="Cancel and close dialog">{{t "common.cancel"}}</button>
      </div>
    </form>
  </div>
</div>
