{{! Report comparison — diff between two scan reports }}

<section aria-labelledby="compare-heading" class="report-meta mb-lg">
  <h1 id="compare-heading" class="section-title mb-sm">{{t "reportCompare.scanComparison"}}</h1>
  <p class="text-muted mb-md">
    {{t "reportCompare.comparingScans"}} <strong>{{scanA.siteUrl}}</strong>
    &mdash; {{t "reportCompare.changedBetween"}} <time datetime="{{scanA.createdAt}}">{{scanA.createdAtDisplay}}</time>
    {{t "reportCompare.and"}} <time datetime="{{scanB.createdAt}}">{{scanB.createdAtDisplay}}</time>.
  </p>

  {{! ── Outcome Banner ─────────────────────────────────────────────────────── }}
  {{#if (cmpPositive diff.summaryDelta.errors)}}
  <div class="alert alert--error mb-md" role="alert">
    <strong>{{t "reportCompare.regressionDetected"}}</strong> {{diff.summaryDelta.errors}} {{t "reportCompare.regressionMsg"}} {{diff.addedCount}} {{t "reportCompare.newIssuesTotal"}} {{diff.removedCount}} {{t "reportCompare.resolvedCount"}}
  </div>
  {{else}}
    {{#if (cmpNegative diff.summaryDelta.errors)}}
    <div class="alert alert--success mb-md" role="status">
      <strong>{{t "reportCompare.improvement"}}</strong> {{cmpSign diff.summaryDelta.errors}} {{t "reportCompare.improvementMsg"}} {{diff.removedCount}} {{t "reportCompare.issuesResolved"}} {{diff.addedCount}} {{t "reportCompare.newWord"}}
    </div>
    {{else}}
    <div class="alert alert--info mb-md" role="status">
      <strong>{{t "reportCompare.noChangeErrors"}}</strong> {{diff.addedCount}} new issue(s), {{diff.removedCount}} resolved, {{diff.unchangedCount}} unchanged.
    </div>
    {{/if}}
  {{/if}}

  {{! ── KPI Cards ──────────────────────────────────────────────────────────── }}
  <div class="rpt-summary-grid mb-md" role="region" aria-label="Change summary">
    <div class="rpt-card rpt-card--error">
      <div class="rpt-card__label">{{t "reportCompare.errors"}}</div>
      <div class="rpt-card__value">{{scanB.errors}}</div>
      <div class="rpt-card__delta {{#if (cmpPositive diff.summaryDelta.errors)}}rpt-card__delta--worse{{else}}{{#if (cmpNegative diff.summaryDelta.errors)}}rpt-card__delta--better{{/if}}{{/if}}">
        {{cmpSign diff.summaryDelta.errors}} {{t "reportCompare.vsBaseline"}}
      </div>
    </div>
    <div class="rpt-card rpt-card--warning">
      <div class="rpt-card__label">{{t "reportCompare.warnings"}}</div>
      <div class="rpt-card__value">{{scanB.warnings}}</div>
      <div class="rpt-card__delta {{#if (cmpPositive diff.summaryDelta.warnings)}}rpt-card__delta--worse{{else}}{{#if (cmpNegative diff.summaryDelta.warnings)}}rpt-card__delta--better{{/if}}{{/if}}">
        {{cmpSign diff.summaryDelta.warnings}} {{t "reportCompare.vsBaseline"}}
      </div>
    </div>
    <div class="rpt-card rpt-card--notice">
      <div class="rpt-card__label">{{t "reportCompare.notices"}}</div>
      <div class="rpt-card__value">{{scanB.notices}}</div>
      <div class="rpt-card__delta {{#if (cmpPositive diff.summaryDelta.notices)}}rpt-card__delta--worse{{else}}{{#if (cmpNegative diff.summaryDelta.notices)}}rpt-card__delta--better{{/if}}{{/if}}">
        {{cmpSign diff.summaryDelta.notices}} {{t "reportCompare.vsBaseline"}}
      </div>
    </div>
    <div class="rpt-card rpt-card--neutral">
      <div class="rpt-card__label">{{t "reportCompare.newIssuesTab"}}</div>
      <div class="rpt-card__value text--error">{{diff.addedCount}}</div>
      <div class="rpt-card__hint">{{t "reportCompare.notInBaseline"}}</div>
    </div>
    <div class="rpt-card rpt-card--neutral">
      <div class="rpt-card__label">{{t "reportCompare.resolvedTab"}}</div>
      <div class="rpt-card__value text--success">{{diff.removedCount}}</div>
      <div class="rpt-card__hint">{{t "reportCompare.fixedSinceBaseline"}}</div>
    </div>
    <div class="rpt-card rpt-card--neutral">
      <div class="rpt-card__label">{{t "reportCompare.unchangedTab"}}</div>
      <div class="rpt-card__value">{{diff.unchangedCount}}</div>
      <div class="rpt-card__hint">{{t "reportCompare.presentInBoth"}}</div>
    </div>
  </div>

  {{! ── Scan Details (collapsible) ─────────────────────────────────────────── }}
  <details class="mb-md">
    <summary class="btn btn--ghost btn--sm">{{t "reportCompare.showScanDetails"}}</summary>
    <div class="cmp-scans-grid mt-sm">
      <div class="card">
        <div class="card__header">
          <h3 class="card__title">{{t "reportCompare.baselineScan"}}</h3>
          <span class="badge badge--neutral">{{scanA.totalIssues}} issues</span>
        </div>
        <div class="card__body">
          <dl class="stats-list">
            <div class="stats-list__item"><dt>URL</dt><dd><a href="{{scanA.siteUrl}}" target="_blank" rel="noopener noreferrer">{{scanA.siteUrl}}</a></dd></div>
            <div class="stats-list__item"><dt>Standard</dt><dd>{{formatStandard scanA.standard}}</dd></div>
            <div class="stats-list__item"><dt>Date</dt><dd><time datetime="{{scanA.createdAt}}">{{scanA.createdAtDisplay}}</time></dd></div>
            <div class="stats-list__item"><dt>Errors / Warnings / Notices</dt><dd>{{scanA.errors}} / {{scanA.warnings}} / {{scanA.notices}}</dd></div>
          </dl>
          <a href="/reports/{{scanA.id}}" class="btn btn--ghost btn--sm mt-sm">{{t "reportCompare.viewFullReport"}}</a>
        </div>
      </div>
      <div class="card">
        <div class="card__header">
          <h3 class="card__title">{{t "reportCompare.latestScan"}}</h3>
          <span class="badge badge--info">{{scanB.totalIssues}} issues</span>
        </div>
        <div class="card__body">
          <dl class="stats-list">
            <div class="stats-list__item"><dt>URL</dt><dd><a href="{{scanB.siteUrl}}" target="_blank" rel="noopener noreferrer">{{scanB.siteUrl}}</a></dd></div>
            <div class="stats-list__item"><dt>Standard</dt><dd>{{formatStandard scanB.standard}}</dd></div>
            <div class="stats-list__item"><dt>Date</dt><dd><time datetime="{{scanB.createdAt}}">{{scanB.createdAtDisplay}}</time></dd></div>
            <div class="stats-list__item"><dt>Errors / Warnings / Notices</dt><dd>{{scanB.errors}} / {{scanB.warnings}} / {{scanB.notices}}</dd></div>
          </dl>
          <a href="/reports/{{scanB.id}}" class="btn btn--ghost btn--sm mt-sm">{{t "reportCompare.viewFullReport"}}</a>
        </div>
      </div>
    </div>
  </details>

  <div class="report-actions mb-md" role="group" aria-label="Navigation">
    <a href="/reports" class="btn btn--ghost btn--sm">&larr; {{t "reportCompare.backToReports"}}</a>
  </div>
</section>

{{! ── Issue Tabs ───────────────────────────────────────────────────────────── }}
<div class="cmp-tabs" role="tablist" aria-label="Comparison sections">
  <button class="cmp-tab cmp-tab--active" role="tab" aria-selected="true" aria-controls="cmp-panel-added" id="cmp-tab-added" data-action="cmpSwitchTab" data-tab="added">
    {{t "reportCompare.newIssuesTab"}} ({{diff.addedCount}})
  </button>
  <button class="cmp-tab" role="tab" aria-selected="false" aria-controls="cmp-panel-removed" id="cmp-tab-removed" data-action="cmpSwitchTab" data-tab="removed">
    {{t "reportCompare.resolvedTab"}} ({{diff.removedCount}})
  </button>
  <button class="cmp-tab" role="tab" aria-selected="false" aria-controls="cmp-panel-unchanged" id="cmp-tab-unchanged" data-action="cmpSwitchTab" data-tab="unchanged">
    {{t "reportCompare.unchangedTab"}} ({{diff.unchangedCount}})
  </button>
</div>

{{! ── New Issues panel ─────────────────────────────────────────────────────── }}
<div class="cmp-panel" id="cmp-panel-added" role="tabpanel" aria-labelledby="cmp-tab-added">
  {{#if diff.addedCount}}
  <p class="text-sm text-muted mb-sm">{{t "reportCompare.newIssuesExplain"}}</p>
  <div class="rpt-table-wrap">
    <table class="rpt-table" aria-label="New issues">
      <thead>
        <tr>
          <th scope="col">{{t "reportCompare.severity"}}</th>
          <th scope="col">{{t "reportCompare.code"}}</th>
          <th scope="col">{{t "reportCompare.wcag"}}</th>
          <th scope="col">{{t "reportCompare.description"}}</th>
          <th scope="col">{{t "reportCompare.element"}}</th>
          <th scope="col">{{t "reportCompare.page"}}</th>
          {{#if diff.hasRegulations}}<th scope="col">{{t "reportCompare.regulations"}}</th>{{/if}}
        </tr>
      </thead>
      <tbody>
        {{#each diff.added}}
        <tr class="rpt-row rpt-row--{{type}}">
          <td><span class="rpt-severity rpt-severity--{{type}}">{{type}}</span></td>
          <td><span class="rpt-code">{{code}}</span></td>
          <td>
            {{#if wcagCriterion}}
            <a href="{{wcagUrl}}" target="_blank" rel="noopener noreferrer" class="rpt-wcag-link" title="{{wcagTitle}}">{{wcagCriterion}}</a>
            <span class="rpt-wcag-title">{{wcagTitle}}</span>
            {{else}}<span class="text-muted">&mdash;</span>{{/if}}
          </td>
          <td>{{message}}</td>
          <td><code class="rpt-code">{{selector}}</code></td>
          <td class="cell--url">{{pageUrl}}</td>
          {{#if ../diff.hasRegulations}}
          <td>{{#each regulationTags}}<span class="rpt-regulation-tag">{{this}}</span> {{/each}}{{#unless regulationTags}}<span class="text-muted">&mdash;</span>{{/unless}}</td>
          {{/if}}
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{else}}
  <div class="empty-state" role="status">
    <div class="empty-state__title">{{t "reportCompare.noNewIssuesTitle"}}</div>
    <div class="empty-state__desc">{{t "reportCompare.noNewIssuesDesc"}}</div>
  </div>
  {{/if}}
</div>

{{! ── Resolved Issues panel ────────────────────────────────────────────────── }}
<div class="cmp-panel cmp-panel--hidden" id="cmp-panel-removed" role="tabpanel" aria-labelledby="cmp-tab-removed">
  {{#if diff.removedCount}}
  <p class="text-sm text-muted mb-sm">{{t "reportCompare.resolvedExplain"}}</p>
  <div class="rpt-table-wrap">
    <table class="rpt-table" aria-label="Resolved issues">
      <thead>
        <tr>
          <th scope="col">{{t "reportCompare.severity"}}</th>
          <th scope="col">{{t "reportCompare.code"}}</th>
          <th scope="col">{{t "reportCompare.wcag"}}</th>
          <th scope="col">{{t "reportCompare.description"}}</th>
          <th scope="col">{{t "reportCompare.element"}}</th>
          <th scope="col">{{t "reportCompare.page"}}</th>
          {{#if diff.hasRegulations}}<th scope="col">{{t "reportCompare.regulations"}}</th>{{/if}}
        </tr>
      </thead>
      <tbody>
        {{#each diff.removed}}
        <tr class="rpt-row rpt-row--{{type}}">
          <td><span class="rpt-severity rpt-severity--{{type}}">{{type}}</span></td>
          <td><span class="rpt-code">{{code}}</span></td>
          <td>
            {{#if wcagCriterion}}
            <a href="{{wcagUrl}}" target="_blank" rel="noopener noreferrer" class="rpt-wcag-link" title="{{wcagTitle}}">{{wcagCriterion}}</a>
            <span class="rpt-wcag-title">{{wcagTitle}}</span>
            {{else}}<span class="text-muted">&mdash;</span>{{/if}}
          </td>
          <td>{{message}}</td>
          <td><code class="rpt-code">{{selector}}</code></td>
          <td class="cell--url">{{pageUrl}}</td>
          {{#if ../diff.hasRegulations}}
          <td>{{#each regulationTags}}<span class="rpt-regulation-tag">{{this}}</span> {{/each}}{{#unless regulationTags}}<span class="text-muted">&mdash;</span>{{/unless}}</td>
          {{/if}}
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{else}}
  <div class="empty-state" role="status">
    <div class="empty-state__title">{{t "reportCompare.noResolvedIssuesTitle"}}</div>
    <div class="empty-state__desc">{{t "reportCompare.noResolvedIssuesDesc"}}</div>
  </div>
  {{/if}}
</div>

{{! ── Unchanged Issues panel ───────────────────────────────────────────────── }}
<div class="cmp-panel cmp-panel--hidden" id="cmp-panel-unchanged" role="tabpanel" aria-labelledby="cmp-tab-unchanged">
  {{#if diff.unchangedCount}}
  <p class="text-sm text-muted mb-sm">{{t "reportCompare.unchangedExplain"}}</p>
  <div class="rpt-table-wrap">
    <table class="rpt-table" aria-label="Unchanged issues">
      <thead>
        <tr>
          <th scope="col">{{t "reportCompare.severity"}}</th>
          <th scope="col">{{t "reportCompare.code"}}</th>
          <th scope="col">{{t "reportCompare.wcag"}}</th>
          <th scope="col">{{t "reportCompare.description"}}</th>
          <th scope="col">{{t "reportCompare.element"}}</th>
          <th scope="col">{{t "reportCompare.page"}}</th>
          {{#if diff.hasRegulations}}<th scope="col">{{t "reportCompare.regulations"}}</th>{{/if}}
        </tr>
      </thead>
      <tbody>
        {{#each diff.unchanged}}
        <tr class="rpt-row rpt-row--{{type}}">
          <td><span class="rpt-severity rpt-severity--{{type}}">{{type}}</span></td>
          <td><span class="rpt-code">{{code}}</span></td>
          <td>
            {{#if wcagCriterion}}
            <a href="{{wcagUrl}}" target="_blank" rel="noopener noreferrer" class="rpt-wcag-link" title="{{wcagTitle}}">{{wcagCriterion}}</a>
            <span class="rpt-wcag-title">{{wcagTitle}}</span>
            {{else}}<span class="text-muted">&mdash;</span>{{/if}}
          </td>
          <td>{{message}}</td>
          <td><code class="rpt-code">{{selector}}</code></td>
          <td class="cell--url">{{pageUrl}}</td>
          {{#if ../diff.hasRegulations}}
          <td>{{#each regulationTags}}<span class="rpt-regulation-tag">{{this}}</span> {{/each}}{{#unless regulationTags}}<span class="text-muted">&mdash;</span>{{/unless}}</td>
          {{/if}}
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{else}}
  <div class="empty-state" role="status">
    <div class="empty-state__title">{{t "reportCompare.noSharedIssuesTitle"}}</div>
    <div class="empty-state__desc">{{t "reportCompare.noSharedIssuesDesc"}}</div>
  </div>
  {{/if}}
</div>

<style>
  /* ── Compare-specific styles using design system tokens ───────────────── */

  .cmp-scans-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md, 1rem);
  }

  .rpt-card__delta {
    font-size: var(--font-size-sm, 0.82rem);
    color: var(--text-muted);
    margin-top: var(--space-xs, 0.25rem);
  }
  .rpt-card__delta--worse { color: var(--status-error, #dc2626); font-weight: 600; }
  .rpt-card__delta--better { color: var(--status-success, #16a34a); font-weight: 600; }
  .rpt-card__hint {
    font-size: 0.72rem;
    color: var(--text-muted);
    margin-top: var(--space-xs, 0.25rem);
  }

  .rpt-wcag-link {
    color: var(--accent);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.82rem;
  }
  .rpt-wcag-link:hover { text-decoration: underline; }
  .rpt-wcag-title {
    display: block;
    font-size: 0.72rem;
    color: var(--text-muted);
    line-height: 1.3;
    margin-top: 0.1rem;
  }
  .rpt-regulation-tag {
    display: inline-block;
    background: var(--accent-light);
    color: var(--accent);
    font-size: 0.68rem;
    padding: 0.1rem 0.4rem;
    border-radius: var(--border-radius-sm, 3px);
    font-weight: 600;
    margin-right: 0.2rem;
  }

  /* Tabs */
  .cmp-tabs {
    display: flex;
    border-bottom: 2px solid var(--border-color, #e5e7eb);
    margin-bottom: 0;
  }
  .cmp-tab {
    padding: 0.6rem 1.2rem;
    font-size: 0.84rem;
    font-weight: 600;
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    margin-bottom: -2px;
    cursor: pointer;
    color: var(--text-muted, #6b7280);
    transition: color 0.15s, border-color 0.15s;
  }
  .cmp-tab:hover { color: var(--text-primary, #111827); }
  .cmp-tab--active {
    color: var(--text-primary, #111827);
    border-bottom-color: var(--accent, #2563eb);
  }

  .cmp-panel {
    background: var(--surface, var(--bg-primary));
    border-radius: 0 0 var(--border-radius, 8px) var(--border-radius, 8px);
    box-shadow: var(--shadow-sm, 0 1px 3px rgba(0,0,0,0.06));
    padding: var(--space-md, 1rem);
    margin-bottom: var(--space-lg, 1.5rem);
  }
  .cmp-panel--hidden { display: none; }

  @media (max-width: 640px) {
    .cmp-scans-grid { grid-template-columns: 1fr; }
    .cmp-tab { padding: 0.5rem 0.7rem; font-size: 0.76rem; }
  }
</style>

<script>
  function cmpSwitchTab(name, btn) {
    document.querySelectorAll('.cmp-panel').forEach(function(p) { p.classList.add('cmp-panel--hidden'); });
    document.querySelectorAll('.cmp-tab').forEach(function(t) { t.classList.remove('cmp-tab--active'); t.setAttribute('aria-selected', 'false'); });
    var panel = document.getElementById('cmp-panel-' + name);
    if (panel) panel.classList.remove('cmp-panel--hidden');
    if (btn) { btn.classList.add('cmp-tab--active'); btn.setAttribute('aria-selected', 'true'); }
  }
  document.querySelectorAll('.cmp-tab').forEach(function(tab) {
    tab.addEventListener('keydown', function(e) { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); tab.click(); } });
  });
</script>
