{{! Reports list — docket style (Phase 58 / R3). Searchable, paginated, deletable.
    Same htmx target ID (#reports-table-body) preserved for live filtering. }}

<div class="reports-controls" role="search">
  <form method="GET" action="/reports" aria-label="Search and filter reports">
    <div class="controls-row">
      <div class="form-group form-group--inline">
        <label for="q">{{t "reports.searchByUrl"}}</label>
        <div class="input-with-indicator">
          <input
            type="search"
            id="q"
            name="q"
            class="form-control"
            placeholder="{{t "reports.filterPlaceholder"}}"
            value="{{q}}"
            autocomplete="off"
            hx-get="/reports"
            hx-trigger="input changed delay:300ms, search"
            hx-target="#reports-table-body"
            hx-indicator="#search-spinner"
            hx-include="[name='status']"
            role="searchbox"
            aria-label="Search reports by URL"
          >
          <span id="search-spinner" class="htmx-indicator" aria-hidden="true">{{t "common.searching"}}</span>
        </div>
      </div>

      <div class="form-group form-group--inline">
        <label for="status">{{t "common.status"}}</label>
        <select
          id="status"
          name="status"
          class="form-control"
          hx-get="/reports"
          hx-trigger="change"
          hx-target="#reports-table-body"
          hx-include="[name='q']"
          aria-label="Filter by scan status"
        >
          <option value="all" {{#if (eq status 'all')}}selected{{/if}}>{{t "reports.allStatuses"}}</option>
          <option value="completed" {{#if (eq status 'completed')}}selected{{/if}}>{{t "reports.completed"}}</option>
          <option value="running" {{#if (eq status 'running')}}selected{{/if}}>{{t "reports.running"}}</option>
          <option value="queued" {{#if (eq status 'queued')}}selected{{/if}}>{{t "reports.queued"}}</option>
          <option value="failed" {{#if (eq status 'failed')}}selected{{/if}}>{{t "reports.failed"}}</option>
        </select>
      </div>

      <button
        id="compare-btn"
        class="btn btn--sm btn--ghost"
        disabled
        data-action="cmpNavigate"
        aria-label="Compare two selected reports"
      >{{t "common.compare"}}</button>

      <a href="/api/v1/export/scans.xlsx" class="btn btn--ghost btn--sm" aria-label="Export all scans as Excel">{{t "reports.exportExcel"}}</a>

      <a href="/scan/new" class="btn btn--primary btn--sm">
        {{t "reports.newScan"}}
      </a>
    </div>
  </form>
</div>

<div
  id="reports-table-body"
  aria-live="polite"
  aria-atomic="false"
  aria-label="Reports list"
>
  {{#if scans.length}}
  <ol class="reports-docket" role="list">
    {{#each scans}}
    <li class="reports-docket__row{{#if (gt errors 0)}} reports-docket__row--flag{{/if}}" id="report-{{id}}">
      {{#if (eq status 'completed')}}
      <input
        type="checkbox"
        class="cmp-check reports-docket__check"
        value="{{id}}"
        data-action-change="cmpUpdateBtn"
        aria-label="Select report for {{siteUrl}} for comparison"
      >
      {{else}}
      <span class="reports-docket__check-placeholder" aria-hidden="true"></span>
      {{/if}}

      <time class="reports-docket__time" datetime="{{createdAt}}">{{createdAtDisplay}}</time>

      <a class="reports-docket__headline" href="/reports/{{id}}" aria-label="View report for {{siteUrl}}">{{siteUrl}}</a>

      <span class="reports-docket__status reports-docket__status--{{status}}">{{status}}</span>

      <span class="reports-docket__detail">
        {{#if (eq status 'completed')}}
          {{#if totalIssues}}
            <span class="text--error">{{errors}}</span> · <span class="text--warning">{{warnings}}</span> · {{notices}} · {{pagesScanned}} {{t "home.pages"}}{{#if confirmedViolations}} · {{confirmedViolations}} {{t "reports.violations"}}{{/if}}{{#if jurisdictions}} · {{jurisdictions}}{{/if}}
          {{else}}
            {{t "home.noIssues"}} · {{pagesScanned}} {{t "home.pages"}}
          {{/if}}
        {{else if (eq status 'running')}}
          <a href="/scan/{{id}}/progress">{{t "home.viewProgress"}}</a>
        {{else if (eq status 'queued')}}
          <a href="/scan/{{id}}/progress">{{t "home.viewQueue"}}</a>
        {{else if (eq status 'failed')}}
          {{t "home.scanFailed"}}
        {{/if}}
      </span>

      <div class="reports-docket__actions" role="group" aria-label="Row actions">
        {{#if previousScanId}}
        <a
          href="/reports/compare?a={{previousScanId}}&b={{id}}"
          class="reports-docket__action-link"
          aria-label="Compare with previous scan for {{siteUrl}}"
          title="Compare with previous scan"
        >{{t "reports.vsPrevious"}}</a>
        {{else}}
        <span class="reports-docket__action-placeholder" aria-hidden="true"></span>
        {{/if}}
        <button
          class="reports-docket__action-link reports-docket__action-link--danger"
          hx-delete="/reports/{{id}}"
          hx-confirm="Delete the scan report for {{siteUrl}}? This cannot be undone."
          hx-target="#report-{{id}}"
          hx-swap="outerHTML swap:300ms"
          aria-label="Delete scan report for {{siteUrl}}"
        >{{t "common.delete"}}</button>
      </div>
    </li>
    {{/each}}
  </ol>

  <nav aria-label="Reports pagination" class="pagination">
    {{#if hasPrev}}
    <a
      href="/reports?offset={{prevOffset}}&limit={{limit}}{{#if q}}&q={{q}}{{/if}}{{#if status}}&status={{status}}{{/if}}"
      class="btn btn--ghost btn--sm"
      hx-get="/reports?offset={{prevOffset}}&limit={{limit}}{{#if q}}&q={{q}}{{/if}}{{#if status}}&status={{status}}{{/if}}"
      hx-target="#reports-table-body"
      hx-push-url="true"
      aria-label="Previous page"
    >
      &larr; {{t "common.previous"}}
    </a>
    {{/if}}

    <span class="pagination__info" aria-current="page">{{t "common.page"}} {{currentPage}}</span>

    {{#if hasNext}}
    <a
      href="/reports?offset={{nextOffset}}&limit={{limit}}{{#if q}}&q={{q}}{{/if}}{{#if status}}&status={{status}}{{/if}}"
      class="btn btn--ghost btn--sm"
      hx-get="/reports?offset={{nextOffset}}&limit={{limit}}{{#if q}}&q={{q}}{{/if}}{{#if status}}&status={{status}}{{/if}}"
      hx-target="#reports-table-body"
      hx-push-url="true"
      aria-label="Next page"
    >
      {{t "common.next"}} &rarr;
    </a>
    {{/if}}
  </nav>

  {{else}}
  <div class="empty-state" role="status">
    {{#if q}}
    <p class="docket__empty-headline">{{t "reports.noMatchTitle"}}</p>
    <p>{{t "reports.noMatchDesc"}} <strong>&ldquo;{{q}}&rdquo;</strong>.</p>
    <a href="/reports" class="btn btn--ghost btn--sm">{{t "reports.clearSearch"}}</a>
    {{else}}
    <p class="docket__empty-headline">{{t "reports.noReportsTitle"}}</p>
    <p>{{t "reports.noReportsDesc"}}</p>
    <a href="/scan/new" class="btn btn--primary">{{t "reports.newScan"}}</a>
    {{/if}}
  </div>
  {{/if}}
</div>

{{! Compare logic is in app.js handlers (cmpUpdateBtn, cmpNavigate) }}
