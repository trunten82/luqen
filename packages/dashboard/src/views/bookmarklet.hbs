<section aria-labelledby="bookmarklet-heading">
  <h2 id="bookmarklet-heading" class="section-title">{{t "bookmarklet.title"}}</h2>

  <div class="card mb-md">
    <h3 class="card__title mb-md">{{t "bookmarklet.scanCardTitle"}}</h3>
    <p class="form-hint mb-md">
      {{t "bookmarklet.dragHint"}}
    </p>

    <div style="text-align:center; margin: 1.5rem 0;">
      <a class="btn btn--primary"
         href="javascript:void(function(){var d='{{dashboardUrl}}';var u=encodeURIComponent(window.location.href);window.open(d+'/scan/new?prefill='+u,'_blank');})()"
         data-action="bookmarkletAlert" data-alert-msg="{{t "bookmarklet.dragAlertMsg"}}"
         draggable="true"
         aria-label="Drag this link to your bookmark bar to install the Luqen bookmarklet">
        {{t "bookmarklet.scanButtonLabel"}}
      </a>
    </div>
  </div>

  <div class="card mb-md">
    <h3 class="card__title mb-md">{{t "bookmarklet.howToUseTitle"}}</h3>
    <ol style="padding-left: 1.5rem; line-height: 1.8;">
      <li>{{{t "bookmarklet.step1"}}}</li>
      <li>{{{t "bookmarklet.step2"}}}</li>
      <li>{{{t "bookmarklet.step3"}}}</li>
    </ol>
  </div>

  <div class="card mb-md">
    <h3 class="card__title mb-md">{{t "bookmarklet.manualInstallTitle"}}</h3>
    <p class="form-hint mb-sm">
      {{t "bookmarklet.manualInstallDesc"}}
    </p>
    <pre style="background: var(--bg-muted, #f4f5f7); padding: 1rem; border-radius: 6px; overflow-x: auto; font-size: 0.85rem; line-height: 1.5;"><code>javascript:void(function(){var d='{{dashboardUrl}}';var u=encodeURIComponent(window.location.href);window.open(d+'/scan/new?prefill='+u,'_blank');})()</code></pre>
  </div>

  <div class="card mb-md">
    <h3 class="card__title mb-md">{{t "bookmarklet.requirementsTitle"}}</h3>
    <ul style="padding-left: 1.5rem; line-height: 1.8;">
      <li>{{{t "bookmarklet.req1"}}}</li>
      <li>{{t "bookmarklet.req2"}}</li>
      <li>{{t "bookmarklet.req3"}}</li>
    </ul>
  </div>
</section>
