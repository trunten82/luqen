{{! Fix Proposals — proposed accessibility fixes for a scan report }}

<section aria-labelledby="fixes-heading">
  <div class="report-actions mb-md" role="group" aria-label="Navigation">
    <a href="/reports/{{scan.id}}" class="btn btn--ghost btn--sm" aria-label="Back to report">
      &larr; {{t "fixes.backToReport"}}
    </a>
  </div>

  <h2 id="fixes-heading" class="section-title">{{t "fixes.title"}}</h2>

  <div class="detail-list detail-list--horizontal mb-lg">
    <div class="detail-list__item">
      <dt>{{t "fixes.site"}}</dt>
      <dd><a href="{{scan.siteUrl}}" target="_blank" rel="noopener noreferrer">{{scan.siteUrl}}</a></dd>
    </div>
    {{#if connectedRepo}}
    <div class="detail-list__item">
      <dt>{{t "fixes.repository"}}</dt>
      <dd>
        <a href="{{connectedRepo.repoUrl}}" target="_blank" rel="noopener noreferrer">
          {{connectedRepo.repoUrl}}
        </a>
        <span class="badge badge--success ml-sm">{{t "fixes.connected"}}</span>
      </dd>
    </div>
    <div class="detail-list__item">
      <dt>{{t "fixes.branch"}}</dt>
      <dd><code>{{connectedRepo.branch}}</code></dd>
    </div>
    {{#if connectedRepo.repoPath}}
    <div class="detail-list__item">
      <dt>{{t "fixes.localPath"}}</dt>
      <dd><code>{{connectedRepo.repoPath}}</code></dd>
    </div>
    {{/if}}
    {{else}}
    <div class="detail-list__item">
      <dt>{{t "fixes.repository"}}</dt>
      <dd>
        <span class="text--muted">{{t "fixes.notConnected"}}</span>
        {{#if perm.adminUsers}}
        <a href="/admin/repos" class="btn btn--ghost btn--sm ml-sm">{{t "fixes.connectRepo"}}</a>
        {{/if}}
      </dd>
    </div>
    {{/if}}
  </div>

  {{#if noReport}}
  <div class="empty-state" role="status">
    <p class="empty-state__desc">{{t "fixes.noReportData"}}</p>
  </div>
  {{else}}

  {{! ── Summary Bar ──────────────────────────────────────────────────── }}
  <div class="rpt-summary-bar mb-lg" role="region" aria-label="Fix proposal summary">
    <span class="rpt-badge rpt-badge--neutral">{{fixCount}} {{t "fixes.fixProposals"}}</span>
    {{#if fixGroups.length}}
    <span class="rpt-badge rpt-badge--neutral">{{fixGroups.length}} {{t "fixes.wcagCriteria"}}</span>
    {{/if}}
  </div>

  {{#unless fixes.length}}
  <div class="empty-state" role="status">
    <p class="empty-state__desc">{{t "fixes.noProposals"}}</p>
    <p class="empty-state__desc mt-sm">{{t "fixes.noProposalsHint"}}</p>
  </div>
  {{/unless}}

  {{! ── Fix Groups by WCAG Criterion ───────────────────────────────── }}
  {{#each fixGroups}}
  <div class="card mb-lg">
    <div class="card__header-row">
      <h3 class="card__title">{{t "fixes.wcagLabel"}} {{this.criterion}}: {{this.title}}</h3>
      <span class="badge badge--neutral">{{this.fixes.length}} {{t "fixes.fixLabel"}}{{#unless (eq this.fixes.length 1)}}{{t "fixes.fixLabelPlural"}}{{/unless}}</span>
    </div>

    {{#each this.fixes}}
    <div class="rpt-fix-proposal">
      <div class="fix-meta-row">
        <span class="badge badge--{{this.severity}}">{{this.severity}}</span>
        <span class="rpt-fix-effort rpt-fix-effort--{{this.effort}}">{{this.effort}} {{t "fixes.effort"}}</span>
        <span class="badge badge--neutral" style="font-size:0.75rem;">{{this.confidence}}</span>
      </div>

      <p class="fix-description">{{this.description}}</p>

      <details class="fix-details">
        <summary class="fix-details__summary">{{t "fixes.issueDetails"}}</summary>
        <div class="fix-details__body">
          <p class="fix-details__item"><strong>{{t "fixes.message"}}</strong> {{this.message}}</p>
          <p class="fix-details__item"><strong>{{t "fixes.selector"}}</strong> <code>{{this.selector}}</code></p>
          <p class="fix-details__item"><strong>{{t "fixes.page"}}</strong> <a href="{{this.pageUrl}}" target="_blank" rel="noopener noreferrer">{{this.pageUrl}}</a></p>
          {{#if this.context}}
          <pre class="code-block code-block--sm mt-sm"><code>{{this.context}}</code></pre>
          {{/if}}
        </div>
      </details>

      <div class="fix-code-block">
        <p class="fix-code-block__label">{{t "fixes.suggestedFix"}}</p>
        <pre class="rpt-fix-hint__code fix-code-block__pre"><code id="fix-code-{{this.index}}">{{this.codeExample}}</code><button type="button" class="btn btn--ghost btn--sm fix-code-block__copy" data-action="copyFixCode" data-index="{{this.index}}" aria-label="Copy fix code to clipboard">{{t "fixes.copy"}}</button></pre>
      </div>
    </div>
    {{/each}}
  </div>
  {{/each}}

  {{! ── Integration Notes ──────────────────────────────────────────── }}
  <div class="card card--alt mt-lg">
    <h3 class="card__title">{{t "fixes.automatedFixOptionsTitle"}}</h3>
    <ul class="text--muted list--padded">
      <li class="mb-sm">{{{t "fixes.integrationMcp"}}}</li>
      <li class="mb-sm">{{{t "fixes.integrationRest"}}}</li>
      <li>{{t "fixes.integrationA2a"}}</li>
    </ul>
  </div>

  {{/if}}
</section>

<script>
function copyFixCode(index) {
  var codeEl = document.getElementById('fix-code-' + index);
  if (!codeEl) return;
  var text = codeEl.textContent || codeEl.innerText;
  if (navigator.clipboard && navigator.clipboard.writeText) {
    navigator.clipboard.writeText(text).then(function() {
      showCopyToast('{{t "fixes.copiedToClipboard"}}');
    }).catch(function() {
      fallbackCopy(text);
    });
  } else {
    fallbackCopy(text);
  }
}

function fallbackCopy(text) {
  var ta = document.createElement('textarea');
  ta.value = text;
  ta.style.position = 'fixed';
  ta.style.left = '-9999px';
  document.body.appendChild(ta);
  ta.select();
  try { document.execCommand('copy'); showCopyToast('{{t "fixes.copiedToClipboard"}}'); }
  catch(e) { showCopyToast('{{t "fixes.copyFailed"}}'); }
  document.body.removeChild(ta);
}

function showCopyToast(msg) {
  var existing = document.getElementById('copy-toast');
  if (existing) existing.remove();
  var toast = document.createElement('div');
  toast.id = 'copy-toast';
  toast.setAttribute('role', 'alert');
  toast.setAttribute('aria-live', 'assertive');
  toast.className = 'toast toast--success';
  toast.textContent = msg;
  document.body.appendChild(toast);
  setTimeout(function() { toast.remove(); }, 3000);
}
</script>
