{{! Fix Proposals — proposed accessibility fixes for a scan report }}

<section aria-labelledby="fixes-heading">
  <div class="report-actions mb-md" role="group" aria-label="Navigation">
    <a href="/reports/{{scan.id}}" class="btn btn--ghost btn--sm" aria-label="Back to report">
      &larr; {{t "fixes.backToReport"}}
    </a>
  </div>

  <h2 id="fixes-heading" class="section-title">{{t "fixes.title"}}</h2>

  <div class="detail-list detail-list--horizontal mb-lg">
    <div class="detail-list__item">
      <dt>{{t "fixes.site"}}</dt>
      <dd><a href="{{scan.siteUrl}}" target="_blank" rel="noopener noreferrer">{{scan.siteUrl}}</a></dd>
    </div>
    {{#if connectedRepo}}
    <div class="detail-list__item">
      <dt>{{t "fixes.repository"}}</dt>
      <dd>
        <a href="{{connectedRepo.repoUrl}}" target="_blank" rel="noopener noreferrer">
          {{connectedRepo.repoUrl}}
        </a>
        <span class="badge badge--success ml-sm">{{t "fixes.connected"}}</span>
      </dd>
    </div>
    <div class="detail-list__item">
      <dt>{{t "fixes.branch"}}</dt>
      <dd><code>{{connectedRepo.branch}}</code></dd>
    </div>
    {{#if connectedRepo.repoPath}}
    <div class="detail-list__item">
      <dt>{{t "fixes.localPath"}}</dt>
      <dd><code>{{connectedRepo.repoPath}}</code></dd>
    </div>
    {{/if}}
    {{else}}
    <div class="detail-list__item">
      <dt>{{t "fixes.repository"}}</dt>
      <dd>
        <span class="text--muted">{{t "fixes.notConnected"}}</span>
        {{#if perm.adminUsers}}
        <a href="/admin/repos" class="btn btn--ghost btn--sm ml-sm">{{t "fixes.connectRepo"}}</a>
        {{/if}}
      </dd>
    </div>
    {{/if}}
  </div>

  {{#if noReport}}
  <div class="empty-state" role="status">
    <p class="empty-state__desc">{{t "fixes.noReportData"}}</p>
  </div>
  {{else}}

  {{! ── Summary Bar ──────────────────────────────────────────────────── }}
  <div class="rpt-summary-bar mb-lg" role="region" aria-label="Fix proposal summary">
    <span class="rpt-badge rpt-badge--neutral">{{fixCount}} {{t "fixes.fixProposals"}}</span>
    {{#if fixGroups.length}}
    <span class="rpt-badge rpt-badge--neutral">{{fixGroups.length}} {{t "fixes.wcagCriteria"}}</span>
    {{/if}}
  </div>

  {{#unless fixes.length}}
  <div class="empty-state" role="status">
    <p class="empty-state__desc">{{t "fixes.noProposals"}}</p>
    <p class="empty-state__desc mt-sm">{{t "fixes.noProposalsHint"}}</p>
  </div>
  {{/unless}}

  {{! ── Fix Groups by WCAG Criterion ───────────────────────────────── }}
  {{#if canCreatePr}}
  <form method="POST" action="/reports/{{scan.id}}/fixes/create-pr" id="create-pr-form">
    <input type="hidden" name="_csrf" value="{{csrfToken}}">
  {{/if}}

  {{#each fixGroups}}
  <div class="mb-lg">
    <div class="card__header-row">
      <h3 class="card__title">{{t "fixes.wcagLabel"}} {{this.criterion}}: {{this.title}}</h3>
      <span class="badge badge--neutral">{{this.fixes.length}} {{t "fixes.fixLabel"}}{{#unless (eq this.fixes.length 1)}}{{t "fixes.fixLabelPlural"}}{{/unless}}</span>
    </div>

    {{#each this.fixes}}
    <article class="fix-proposal">
      <header class="fix-proposal__head">
        {{#if ../../canCreatePr}}
        <label class="fix-proposal__check-label">
          <input type="checkbox" name="fixIndices" value="{{this.index}}" class="fix-checkbox">
          <span class="sr-only">{{t "fixes.selectFix"}}</span>
        </label>
        {{/if}}
        <span class="fix-proposal__meta">
          <span class="fix-proposal__severity fix-proposal__severity--{{this.severity}}">{{this.severity}}</span>
          <span class="fix-proposal__effort">{{this.effort}} {{t "fixes.effort"}}</span>
          <span class="fix-proposal__confidence">{{this.confidence}}</span>
        </span>
      </header>

      <div class="fix-proposal__panes">
        <div class="fix-proposal__rationale">
          <p class="fix-proposal__description">{{this.description}}</p>
          <dl class="fix-proposal__provenance">
            <div class="fix-proposal__provenance-row">
              <dt>{{t "fixes.message"}}</dt>
              <dd>{{this.message}}</dd>
            </div>
            <div class="fix-proposal__provenance-row">
              <dt>{{t "fixes.selector"}}</dt>
              <dd><code>{{this.selector}}</code></dd>
            </div>
            <div class="fix-proposal__provenance-row">
              <dt>{{t "fixes.page"}}</dt>
              <dd><a href="{{this.pageUrl}}" target="_blank" rel="noopener noreferrer">{{this.pageUrl}}</a></dd>
            </div>
          </dl>
          {{#if this.context}}
          <details class="fix-proposal__context-toggle">
            <summary>{{t "fixes.issueDetails"}}</summary>
            <pre class="fix-proposal__context"><code>{{this.context}}</code></pre>
          </details>
          {{/if}}
        </div>

        <div class="fix-proposal__diff">
          <header class="fix-proposal__diff-head">
            <span class="fix-proposal__diff-label">{{t "fixes.suggestedFix"}}</span>
            <button type="button" class="fix-proposal__copy" data-action="copyFixCode" data-index="{{this.index}}" aria-label="Copy fix code to clipboard">{{t "fixes.copy"}}</button>
          </header>
          <pre class="fix-proposal__code"><code id="fix-code-{{this.index}}">{{this.codeExample}}</code></pre>
        </div>
      </div>
    </article>
    {{/each}}
  </div>
  {{/each}}

  {{#if canCreatePr}}
  <div class="card card--alt mt-lg mb-lg">
    <div class="card__header-row">
      <h3 class="card__title">{{t "fixes.createPrTitle"}}</h3>
    </div>
    <p class="text--muted mb-md">{{t "fixes.createPrDescription"}}</p>
    <div class="btn-group">
      <button type="button" class="btn btn--ghost btn--sm" id="select-all-fixes">{{t "fixes.selectAll"}}</button>
      <button type="button" class="btn btn--ghost btn--sm" id="deselect-all-fixes">{{t "fixes.deselectAll"}}</button>
    </div>
    <button type="submit" class="btn btn--primary mt-md" id="create-pr-btn">
      {{t "fixes.createPr"}}
    </button>
  </div>
  </form>
  {{/if}}

  {{! ── Integration Notes ──────────────────────────────────────────── }}
  <div class="card card--alt mt-lg">
    <h3 class="card__title">{{t "fixes.automatedFixOptionsTitle"}}</h3>
    <ul class="text--muted list--padded">
      <li class="mb-sm">{{{t "fixes.integrationMcp"}}}</li>
      <li class="mb-sm">{{{t "fixes.integrationRest"}}}</li>
      <li>{{t "fixes.integrationA2a"}}</li>
    </ul>
  </div>

  {{/if}}
</section>

<script>
function copyFixCode(index) {
  var codeEl = document.getElementById('fix-code-' + index);
  if (!codeEl) return;
  var text = codeEl.textContent || codeEl.innerText;
  if (navigator.clipboard && navigator.clipboard.writeText) {
    navigator.clipboard.writeText(text).then(function() {
      showCopyToast('{{t "fixes.copiedToClipboard"}}');
    }).catch(function() {
      fallbackCopy(text);
    });
  } else {
    fallbackCopy(text);
  }
}

function fallbackCopy(text) {
  var ta = document.createElement('textarea');
  ta.value = text;
  ta.style.position = 'fixed';
  ta.style.left = '-9999px';
  document.body.appendChild(ta);
  ta.select();
  try { document.execCommand('copy'); showCopyToast('{{t "fixes.copiedToClipboard"}}'); }
  catch(e) { showCopyToast('{{t "fixes.copyFailed"}}'); }
  document.body.removeChild(ta);
}

// Select/deselect all fix checkboxes
var selectAllBtn = document.getElementById('select-all-fixes');
var deselectAllBtn = document.getElementById('deselect-all-fixes');
if (selectAllBtn) {
  selectAllBtn.addEventListener('click', function() {
    var checkboxes = document.querySelectorAll('.fix-checkbox');
    for (var i = 0; i < checkboxes.length; i++) {
      checkboxes[i].checked = true;
    }
  });
}
if (deselectAllBtn) {
  deselectAllBtn.addEventListener('click', function() {
    var checkboxes = document.querySelectorAll('.fix-checkbox');
    for (var i = 0; i < checkboxes.length; i++) {
      checkboxes[i].checked = false;
    }
  });
}

function showCopyToast(msg) {
  var existing = document.getElementById('copy-toast');
  if (existing) existing.remove();
  var toast = document.createElement('div');
  toast.id = 'copy-toast';
  toast.setAttribute('role', 'alert');
  toast.setAttribute('aria-live', 'assertive');
  toast.className = 'toast toast--success';
  toast.textContent = msg;
  document.body.appendChild(toast);
  setTimeout(function() { toast.remove(); }, 3000);
}
</script>
