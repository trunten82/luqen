{{!-- Fleet page — registered WP sites for the caller's org (scope=org)
     or all orgs (scope=admin). Mirrors reports-list.hbs structure. --}}

<div class="page-header">
  <h1>{{pageTitle}}</h1>
  <p class="text-muted">
    Sites running the Luqen WordPress plugin connected to <strong>{{scopeLabel}}</strong>.
    {{#if (eq scope "org")}}
      <a href="/admin/fleet" class="text-muted">View all orgs</a>
    {{else}}
      <a href="/fleet" class="text-muted">View my org only</a>
    {{/if}}
  </p>
</div>

<dl class="stat-grid" aria-label="Fleet summary">
  <div class="stat">
    <dt>Total sites</dt>
    <dd>{{siteCount}}</dd>
  </div>
  <div class="stat">
    <dt>Active</dt>
    <dd>{{activeCount}}</dd>
  </div>
  <div class="stat">
    <dt>Stale</dt>
    <dd>{{staleCount}}</dd>
  </div>
  <div class="stat">
    <dt>{{t "fleet.highestExposure"}}</dt>
    <dd>
      {{#if fleetExposureSummary.highBandCount}}
        <span class="rpt-badge rpt-badge--error-light">{{fleetExposureSummary.highBandCount}} {{t "exposure.band.high"}}</span>
      {{else}}
        <span class="text-muted">—</span>
      {{/if}}
    </dd>
  </div>
</dl>

{{#if sites.length}}
<table class="data-table" aria-label="Fleet sites">
  <thead>
    <tr>
      <th scope="col">Site URL</th>
      {{#if (eq scope "admin")}}<th scope="col">Org</th>{{/if}}
      <th scope="col">WP / plugin</th>
      <th scope="col">Status</th>
      <th scope="col">Last seen</th>
      <th scope="col">Last scan</th>
      <th scope="col">
        <button class="table-sort-btn" aria-sort="descending" data-sort="exposure">
          {{t "fleet.exposureBand"}}
        </button>
      </th>
      <th scope="col">Actions</th>
    </tr>
  </thead>
  <tbody>
    {{#each sites}}
    <tr>
      <td>
        <a href="{{url}}" target="_blank" rel="noopener noreferrer">{{url}}</a>
        <br><code class="text-muted" style="font-size: 0.75em">{{id}}</code>
      </td>
      {{#if (eq ../scope "admin")}}<td><code>{{orgId}}</code></td>{{/if}}
      <td>
        <span class="text-muted" style="font-size: 0.875em">WP</span>
        {{#if wpVersion}}{{wpVersion}}{{else}}<span class="text-muted">—</span>{{/if}}
        <br>
        <span class="text-muted" style="font-size: 0.875em">plugin</span>
        {{#if pluginVersion}}{{pluginVersion}}{{else}}<span class="text-muted">—</span>{{/if}}
      </td>
      <td>
        <span class="badge badge--{{#if (eq status "active")}}success{{else}}warning{{/if}}">{{status}}</span>
      </td>
      <td><time datetime="{{lastSeenAt}}">{{lastSeenAt}}</time></td>
      <td>
        {{#if latestScan}}
          <a href="/reports/{{latestScan.id}}"><time datetime="{{latestScan.createdAt}}">{{latestScan.createdAt}}</time></a>
          {{#if latestScan.totalIssues}}<br><span class="text-muted">{{latestScan.totalIssues}} issues</span>{{/if}}
        {{else}}
          <span class="text-muted">no scan yet</span>
        {{/if}}
      </td>
      <td data-label="{{t 'fleet.exposureBand'}}">
        {{#if this.exposure}}
          <span class="rpt-badge rpt-badge--{{this.exposure.badgeModifier}} rpt-exposure-band{{#if (eq this.exposure.band "high")}} rpt-exposure-band--high{{/if}}"
                aria-label="{{t "fleet.exposureBandLabel" band=this.exposure.band}}">
            <span aria-hidden="true">{{this.exposure.bandIcon}}</span>
            {{t (concat "exposure.band." this.exposure.band)}}
          </span>
        {{else}}
          <span class="text-muted">—</span>
        {{/if}}
      </td>
      <td>
        <a class="btn btn--sm btn--ghost" href="{{#if (eq ../scope "admin")}}/admin/fleet/{{id}}{{else}}/fleet/{{id}}{{/if}}">Details</a>
      </td>
    </tr>
    {{/each}}
  </tbody>
</table>
{{else}}
<div class="empty-state" role="status">
  <p>No WP sites registered yet for <strong>{{scopeLabel}}</strong>.</p>
  <p class="text-muted">
    Sites self-register on the plugin's first <code>/api/v1/fleet</code> heartbeat
    after the dashboard connection is saved.
  </p>
</div>
{{/if}}
