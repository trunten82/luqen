<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Sign in to Luqen">
  <title>Sign In — Luqen</title>
  <link rel="stylesheet" href="/static/style.css">
</head>
<body>
  <!-- Skip to main content -->
  <a class="skip-link" href="#main-content">Skip to main content</a>

  <main id="main-content" class="login-page" role="main">
    <div class="login-card">
      <div class="login-card__logo" aria-label="Luqen">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" aria-hidden="true" style="display:inline-block;vertical-align:middle;margin-right:8px">
          <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
          <path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Luqen
      </div>

      <h1 class="login-card__title">Sign in</h1>
      <p class="login-card__subtitle">
        {{#if (eq mode "solo")}}Enter your API key to access the dashboard{{/if}}
        {{#if (eq mode "team")}}Enter your credentials to access the dashboard{{/if}}
        {{#if (eq mode "enterprise")}}Choose a sign-in method{{/if}}
        {{#unless mode}}Enter your credentials to access the dashboard{{/unless}}
      </p>

      {{#if error}}
      <div class="alert alert--error" role="alert" aria-live="assertive" id="login-error">
        <svg class="alert__icon" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.5"/>
          <path d="M10 6v4M10 13v1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <div class="alert__body">
          <div class="alert__title">Sign in failed</div>
          {{error}}
        </div>
      </div>
      {{/if}}

      {{!-- Solo mode: API key form --}}
      {{#if (eq mode "solo")}}
      <form method="POST" action="/login" novalidate>
        <input type="hidden" name="_csrf" value="{{csrfToken}}">
        <div class="form-group">
          <label for="apiKey">
            API Key
            <span class="required" aria-hidden="true">*</span>
          </label>
          <input
            type="password"
            id="apiKey"
            name="apiKey"
            autocomplete="off"
            required
            aria-required="true"
            {{#if error}}aria-invalid="true" aria-describedby="login-error"{{/if}}
          >
        </div>

        <div class="form-group" style="margin-top: var(--space-lg)">
          <button type="submit" class="btn btn--primary btn--full btn--lg">
            Sign in
          </button>
        </div>
      </form>
      {{/if}}

      {{!-- Enterprise mode: SSO buttons --}}
      {{#if (eq mode "enterprise")}}
      <div class="login-sso" style="margin-bottom: var(--space-lg, 1.5rem)">
        {{#each loginMethods}}
          {{#if (eq this.type "sso")}}
          <a href="/auth/sso/{{this.pluginId}}" class="btn btn--primary btn--full btn--lg" style="margin-bottom: var(--space-sm, 0.5rem); display: block; text-align: center; text-decoration: none;">
            Sign in with {{this.label}}
          </a>
          {{/if}}
        {{/each}}
      </div>

      <details class="login-password-fallback">
        <summary style="cursor: pointer; margin-bottom: var(--space-md, 1rem); color: var(--text-secondary, #666);">Or sign in with password</summary>
        <form method="POST" action="/login" novalidate>
          <div class="form-group">
            <label for="username">
              Username
              <span class="required" aria-hidden="true">*</span>
            </label>
            <input
              type="text"
              id="username"
              name="username"
              autocomplete="username"
              autocapitalize="none"
              autocorrect="off"
              spellcheck="false"
              required
              aria-required="true"
              {{#if error}}aria-invalid="true" aria-describedby="login-error"{{/if}}
              value="{{username}}"
            >
          </div>

          <div class="form-group">
            <label for="password">
              Password
              <span class="required" aria-hidden="true">*</span>
            </label>
            <input
              type="password"
              id="password"
              name="password"
              autocomplete="current-password"
              required
              aria-required="true"
              {{#if error}}aria-invalid="true" aria-describedby="login-error"{{/if}}
            >
          </div>

          <div class="form-group" style="margin-top: var(--space-lg)">
            <button type="submit" class="btn btn--primary btn--full btn--lg">
              Sign in
            </button>
          </div>
        </form>
      </details>
      {{/if}}

      {{!-- Team mode (or fallback when mode is not set): username/password form --}}
      {{#if (eq mode "team")}}
      <form method="POST" action="/login" novalidate>
        <input type="hidden" name="_csrf" value="{{csrfToken}}">
        <div class="form-group">
          <label for="username">
            Username
            <span class="required" aria-hidden="true">*</span>
          </label>
          <input
            type="text"
            id="username"
            name="username"
            autocomplete="username"
            autocapitalize="none"
            autocorrect="off"
            spellcheck="false"
            required
            aria-required="true"
            {{#if error}}aria-invalid="true" aria-describedby="login-error"{{/if}}
            value="{{username}}"
          >
        </div>

        <div class="form-group">
          <label for="password">
            Password
            <span class="required" aria-hidden="true">*</span>
          </label>
          <input
            type="password"
            id="password"
            name="password"
            autocomplete="current-password"
            required
            aria-required="true"
            {{#if error}}aria-invalid="true" aria-describedby="login-error"{{/if}}
          >
        </div>

        <div class="form-group" style="margin-top: var(--space-lg)">
          <button type="submit" class="btn btn--primary btn--full btn--lg">
            Sign in
          </button>
        </div>
      </form>
      {{/if}}

      {{!-- Fallback when mode is not set (backward compat) --}}
      {{#unless mode}}
      <form method="POST" action="/login" novalidate>
        <input type="hidden" name="_csrf" value="{{csrfToken}}">
        <div class="form-group">
          <label for="username">
            Username
            <span class="required" aria-hidden="true">*</span>
          </label>
          <input
            type="text"
            id="username"
            name="username"
            autocomplete="username"
            autocapitalize="none"
            autocorrect="off"
            spellcheck="false"
            required
            aria-required="true"
            {{#if error}}aria-invalid="true" aria-describedby="login-error"{{/if}}
            value="{{username}}"
          >
        </div>

        <div class="form-group">
          <label for="password">
            Password
            <span class="required" aria-hidden="true">*</span>
          </label>
          <input
            type="password"
            id="password"
            name="password"
            autocomplete="current-password"
            required
            aria-required="true"
            {{#if error}}aria-invalid="true" aria-describedby="login-error"{{/if}}
          >
        </div>

        <div class="form-group" style="margin-top: var(--space-lg)">
          <button type="submit" class="btn btn--primary btn--full btn--lg">
            Sign in
          </button>
        </div>
      </form>
      {{/unless}}
    </div>
  </main>
</body>
</html>
