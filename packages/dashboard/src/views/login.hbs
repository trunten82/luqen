<div class="login-page">
    <div class="login-card">
      <div class="login-card__logo" aria-label="Luqen">
        <svg width="28" height="28" viewBox="0 0 32 32" fill="none" aria-hidden="true" style="display:inline-block;vertical-align:middle;margin-right:8px">
          <path d="M6 4 V18 a8 8 0 0 0 8 8 h4 a8 8 0 0 0 8 -8 V4" stroke="currentColor" stroke-width="5" stroke-linecap="square" fill="none"/>
          <rect x="23" y="4" width="3" height="3" fill="#d6c43c"/>
        </svg>
        {{t "common.appName"}}
      </div>

      <h1 class="login-card__title">{{t "auth.signInTitle"}}</h1>
      <p class="login-card__subtitle">
        {{#if (eq mode "solo")}}{{t "auth.soloSubtitle"}}{{/if}}
        {{#if (eq mode "team")}}{{t "auth.teamSubtitle"}}{{/if}}
        {{#if (eq mode "enterprise")}}{{t "auth.enterpriseSubtitle"}}{{/if}}
        {{#unless mode}}{{t "auth.teamSubtitle"}}{{/unless}}
      </p>

      {{#if error}}
      {{> alert type="error" title=(t "auth.signInFailed") message=error alertId="login-error"}}
      {{/if}}

      {{!-- Solo mode: API key only --}}
      {{#if (eq mode "solo")}}
      {{> login-form showApiKey=true apiKeyId="apiKey" buttonLabel=(t "auth.signInButton") csrfToken=csrfToken returnTo=returnTo error=error}}
      {{/if}}

      {{!-- Enterprise mode: SSO + password fallback + API key fallback --}}
      {{#if (eq mode "enterprise")}}
      <div class="login-sso" style="margin-bottom: var(--space-lg, 1.5rem)">
        {{#each loginMethods}}
          {{#if (eq this.type "sso")}}
          <a href="/auth/sso/{{this.pluginId}}" class="btn btn--primary btn--full btn--lg" style="margin-bottom: var(--space-sm, 0.5rem); display: block; text-align: center; text-decoration: none;">
            Sign in with {{this.label}}
          </a>
          {{/if}}
        {{/each}}
      </div>

      <details class="login-password-fallback">
        <summary class="login-details-summary" style="margin-bottom: var(--space-md, 1rem);">{{t "auth.signInWithPassword"}}</summary>
        {{> login-form showUsername=true usernameId="username" passwordId="password" buttonLabel=(t "auth.signInButton") csrfToken=csrfToken returnTo=returnTo error=error username=username}}
      </details>

      <details class="login-apikey-fallback" style="margin-top: var(--space-md, 1rem)">
        <summary class="login-details-summary">{{t "auth.signInWithApiKey"}}</summary>
        <div style="margin-top: var(--space-md, 1rem)">
          {{> login-form showApiKey=true apiKeyId="apiKeyEnterprise" buttonLabel=(t "auth.signInWithApiKey") csrfToken=csrfToken returnTo=returnTo error=error}}
        </div>
      </details>
      {{/if}}

      {{!-- Team mode: username/password + API key fallback --}}
      {{#if (eq mode "team")}}
      {{> login-form showUsername=true usernameId="username" passwordId="password" buttonLabel=(t "auth.signInButton") csrfToken=csrfToken returnTo=returnTo error=error username=username}}

      <details class="login-apikey-fallback" style="margin-top: var(--space-lg, 1.5rem)">
        <summary class="login-details-summary">{{t "auth.signInWithApiKey"}}</summary>
        <div style="margin-top: var(--space-md, 1rem)">
          {{> login-form showApiKey=true apiKeyId="apiKeyTeam" buttonLabel=(t "auth.signInWithApiKey") csrfToken=csrfToken returnTo=returnTo error=error}}
        </div>
      </details>
      {{/if}}

      {{!-- Fallback when mode is not set (backward compat) --}}
      {{#unless mode}}
      {{> login-form showUsername=true usernameId="username" passwordId="password" buttonLabel=(t "auth.signInButton") csrfToken=csrfToken returnTo=returnTo error=error username=username}}
      {{/unless}}

      <p class="login-card__learn-more">
        {{{t "auth.learnMore"}}}
      </p>

      {{#if selfScanId}}
      <a class="login-card__self-badge"
         href="/reports/{{selfScanId}}/public"
         aria-label="View Luqen's own accessibility self-scan report">
        <img src="/api/v1/badge/{{selfScanId}}.svg"
             alt="Verified by Luqen"
             width="180" height="32">
      </a>
      {{/if}}
    </div>
    <p class="app-version">{{appVersion}}</p>
</div>
