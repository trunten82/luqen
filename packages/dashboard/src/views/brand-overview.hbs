{{! Brand Overview — org-level brand accessibility KPIs with per-site selector }}

{{#if isGlobalAdmin}}
<div class="mb-md">
  <label for="org-picker" class="text-muted">{{t "brandOverview.organization"}}</label>
  <select id="org-picker" class="form-select form-select--inline"
          onchange="window.location.href='/brand-overview?org='+this.value">
    {{#each allOrgs}}
    <option value="{{this.id}}" {{#if (eq this.id ../selectedOrgId)}}selected{{/if}}>{{this.name}}</option>
    {{/each}}
  </select>
</div>
{{/if}}

{{#if canManageBranding}}
<section class="mb-md" aria-label="Rescore controls">
  {{#if rescoreInProgress}}
    {{> rescore-progress}}
  {{else}}
    {{> rescore-button}}
  {{/if}}
</section>
{{/if}}

{{#if hasSites}}
<section aria-labelledby="brand-summary-heading" class="mb-lg">
  <h2 id="brand-summary-heading" class="section-title">{{t "brandOverview.summary"}}</h2>
  <div class="exec-summary" role="list" aria-label="Brand score summary">
    <article class="stat-card" role="listitem" style="border-left: 3px solid var(--accent)">
      <span class="stat-card__value {{summary.avgScoreClass}}">{{#if summary.avgScore}}{{summary.avgScore}}{{else}}&mdash;{{/if}}</span>
      <span class="stat-card__label">{{t "brandOverview.avgScore"}}</span>
      {{#if targetScore}}
      <span class="stat-card__sub text-sm">
        {{t "brandOverview.target"}}: {{targetScore}}
        {{#if gapValue}}
          <span class="{{gapClass}}">({{#if (gte gapValue 0)}}+{{/if}}{{gapValue}})</span>
        {{/if}}
      </span>
      {{/if}}
    </article>
    <article class="stat-card" role="listitem">
      <span class="stat-card__value">{{summary.totalScored}}</span>
      <span class="stat-card__label">{{t "brandOverview.scoredSites"}}</span>
    </article>
    <article class="stat-card" role="listitem" style="border-left: 3px solid var(--status-success)">
      <span class="stat-card__value">{{summary.improving}}</span>
      <span class="stat-card__label">{{t "brandOverview.improving"}}</span>
    </article>
    <article class="stat-card" role="listitem" style="border-left: 3px solid var(--status-error)">
      <span class="stat-card__value">{{summary.regressing}}</span>
      <span class="stat-card__label">{{t "brandOverview.regressing"}}</span>
    </article>
  </div>
  {{#if canManageBranding}}
  <form method="POST" action="/brand-overview/target" class="brand-overview__target-form mt-sm">
    <input type="hidden" name="_csrf" value="{{csrfToken}}">
    <label for="brand-target" class="text-muted text-sm">{{t "brandOverview.setTarget"}}</label>
    <input type="number" id="brand-target" name="target" min="0" max="100" step="1"
           value="{{#if targetScore}}{{targetScore}}{{/if}}"
           placeholder="0-100" class="form-input form-input--sm" style="width: 5rem">
    <button type="submit" class="btn btn--sm btn--secondary">{{t "brandOverview.saveTarget"}}</button>
    {{#if targetScore}}
    <button type="submit" name="target" value="" class="btn btn--sm btn--ghost">{{t "brandOverview.clearTarget"}}</button>
    {{/if}}
  </form>
  {{/if}}
</section>

<span id="brand-loading" class="htmx-indicator" aria-hidden="true">{{t "common.loading"}}</span>
<div class="brand-overview__layout" id="brand-overview-content">
  {{> brand-overview-inner}}
</div>

{{else}}
<div class="card">
  <div class="card__body text-center" style="padding: var(--space-xl)">
    <h2 class="mb-sm">{{t "brandOverview.noSites"}}</h2>
    <p class="text-muted mb-md">{{t "brandOverview.noSitesDesc"}}</p>
    <a href="/admin/branding-guidelines" class="btn btn--primary">{{t "brandOverview.setupGuidelines"}}</a>
  </div>
</div>
{{/if}}
