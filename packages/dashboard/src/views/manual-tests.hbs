{{! Manual Testing Checklist — guided WCAG criteria that cannot be fully automated }}

<section aria-labelledby="mt-heading" class="report-meta mb-lg">
  <div class="detail-list detail-list--horizontal">
    <div class="detail-list__item">
      <dt>{{t "manualTests.siteUrl"}}</dt>
      <dd><a href="{{scan.siteUrl}}" target="_blank" rel="noopener noreferrer">{{scan.siteUrl}}</a></dd>
    </div>
    <div class="detail-list__item">
      <dt>{{t "manualTests.standard"}}</dt>
      <dd>{{formatStandard scan.standard}}</dd>
    </div>
    <div class="detail-list__item">
      <dt>{{t "manualTests.status"}}</dt>
      <dd><span class="badge badge--{{scan.status}}">{{scan.status}}</span></dd>
    </div>
  </div>

  <div class="report-actions mt-md" role="group" aria-label="Navigation">
    <a href="/reports/{{scan.id}}" class="btn btn--ghost btn--sm">&larr; {{t "manualTests.backToReport"}}</a>
    <a href="/reports" class="btn btn--ghost btn--sm">{{t "manualTests.allReports"}}</a>
  </div>
</section>

{{! ── Progress bar ──────────────────────────────────────────────────────── }}
<div class="mt-progress" role="region" aria-label="Manual testing progress">
  <div class="mt-progress__bar">
    <div class="mt-progress__fill" id="mt-progress-fill" style="width:{{stats.percentage}}%"></div>
  </div>
  <div class="mt-progress__stats" id="mt-progress-stats">
    <span id="mt-stat-pct"><strong>{{stats.percentage}}%</strong> {{t "manualTests.complete"}}</span>
    <span class="mt-stat-sep">|</span>
    <span id="mt-stat-tested">{{stats.tested}} {{t "manualTests.tested"}}</span>
    <span class="mt-stat-sep">|</span>
    <span class="mt-stat--pass" id="mt-stat-pass">{{stats.passed}} {{t "manualTests.pass"}}</span>
    <span class="mt-stat-sep">|</span>
    <span class="mt-stat--fail" id="mt-stat-fail">{{stats.failed}} {{t "manualTests.fail"}}</span>
    <span class="mt-stat-sep">|</span>
    <span class="mt-stat--na" id="mt-stat-na">{{stats.na}} {{t "manualTests.na"}}</span>
    <span class="mt-stat-sep">|</span>
    <span id="mt-stat-untested">{{stats.untested}} {{t "manualTests.remaining"}}</span>
  </div>
</div>

{{! ── Filter buttons ─────────────────────────────────────────────────── }}
<div class="mt-filters" role="group" aria-label="Filter criteria by status">
  <button type="button" class="mt-filter mt-filter--active" data-action="mtFilter" data-status="all">{{t "manualTests.filterAll"}}</button>
  <button type="button" class="mt-filter" data-action="mtFilter" data-status="untested">{{t "manualTests.filterUntested"}}</button>
  <button type="button" class="mt-filter" data-action="mtFilter" data-status="pass">{{t "manualTests.filterPass"}}</button>
  <button type="button" class="mt-filter" data-action="mtFilter" data-status="fail">{{t "manualTests.filterFail"}}</button>
  <button type="button" class="mt-filter" data-action="mtFilter" data-status="na">{{t "manualTests.filterNa"}}</button>
</div>

{{! ── Manual-only criteria ──────────────────────────────────────────── }}
<section class="mt-section" aria-labelledby="mt-manual-heading">
  <h2 id="mt-manual-heading" class="mt-section__title">
    {{t "manualTests.requiresManualTitle"}}
    <span class="mt-section__count">{{manualItems.length}} {{t "manualTests.criteria"}}</span>
  </h2>
  <p class="mt-section__desc">{{t "manualTests.requiresManualDesc"}}</p>

  <div class="mt-list" id="mt-list-manual">
    {{#each manualItems}}
    <div class="mt-criterion" id="mt-row-{{id}}" data-status="{{status}}">
      <div class="mt-criterion__header">
        <span class="mt-badge {{#if (eq status 'pass')}}mt-badge--pass{{else if (eq status 'fail')}}mt-badge--fail{{else if (eq status 'na')}}mt-badge--na{{else}}mt-badge--untested{{/if}}">
          {{#if (eq status 'pass')}}{{t "manualTests.pass"}}{{else if (eq status 'fail')}}{{t "manualTests.fail"}}{{else if (eq status 'na')}}{{t "manualTests.na"}}{{else}}{{t "manualTests.untested"}}{{/if}}
        </span>
        <strong>{{id}}</strong> &mdash; {{title}}
        <span class="mt-level mt-level--{{level}}">{{level}}</span>
        <button type="button" class="mt-toggle" data-action="mtToggle" aria-label="Toggle details" aria-expanded="false">&#9660;</button>
      </div>
      <div class="mt-criterion__body mt-criterion__body--collapsed">
        <p class="mt-instructions">{{testInstructions}}</p>
        <ul class="mt-checklist">
          {{#each whatToCheck}}
          <li>{{this}}</li>
          {{/each}}
        </ul>
        {{#if steps.length}}
        <details class="mt-steps-detail">
          <summary class="mt-steps-toggle">{{t "manualTests.stepByStepGuide"}}</summary>
          <ol class="mt-steps">
            {{#each steps}}
            <li>{{this}}</li>
            {{/each}}
          </ol>
        </details>
        {{/if}}
        {{#if goodExample}}
        <details class="mt-examples-detail">
          <summary class="mt-examples-toggle">{{t "manualTests.examples"}}</summary>
          <div class="mt-examples">
            <div class="mt-example mt-example--good">
              <div class="mt-example__label">{{t "manualTests.good"}}</div>
              <pre class="mt-example__code"><code>{{goodExample}}</code></pre>
            </div>
            <div class="mt-example mt-example--bad">
              <div class="mt-example__label">{{t "manualTests.bad"}}</div>
              <pre class="mt-example__code"><code>{{badExample}}</code></pre>
            </div>
          </div>
        </details>
        {{/if}}
        <div class="mt-actions">
          <button type="button" class="mt-btn mt-btn--pass{{#if (eq status 'pass')}} mt-btn--active{{/if}}" data-action="mtSave" data-scan-id="{{../scan.id}}" data-test-id="{{id}}" data-status="pass">{{t "manualTests.pass"}}</button>
          <button type="button" class="mt-btn mt-btn--fail{{#if (eq status 'fail')}} mt-btn--active{{/if}}" data-action="mtSave" data-scan-id="{{../scan.id}}" data-test-id="{{id}}" data-status="fail">{{t "manualTests.fail"}}</button>
          <button type="button" class="mt-btn mt-btn--na{{#if (eq status 'na')}} mt-btn--active{{/if}}" data-action="mtSave" data-scan-id="{{../scan.id}}" data-test-id="{{id}}" data-status="na">{{t "manualTests.na"}}</button>
        </div>
        <div class="mt-notes-wrap">
          <label for="mt-notes-{{id}}">{{t "manualTests.notes"}}</label>
          <textarea id="mt-notes-{{id}}" class="mt-notes" rows="2" placeholder="{{t "manualTests.optionalNotes"}}">{{notes}}</textarea>
        </div>
        {{#if testedBy}}
        <div class="mt-tested-info">{{t "manualTests.testedBy"}} {{testedBy}} {{t "manualTests.on"}} {{testedAt}}</div>
        {{/if}}
      </div>
    </div>
    {{/each}}
  </div>
</section>

