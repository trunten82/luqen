<script>
  /* ── Event delegation for manual test actions ────────────────────────── */
  (function() {
    // Bind the document-level listener at most once per page lifetime. Inline
    // page scripts can be re-executed (e.g. htmx history restore) while the
    // document — and thus prior listeners — persists; without this guard the
    // handler would fire N times per click (duplicate toasts / double upload).
    if (window.__mtManualBound) return;
    window.__mtManualBound = true;
    document.addEventListener('click', function(e) {
      var target = e.target.closest('[data-action]');
      if (!target) return;

      var action = target.getAttribute('data-action');

      if (action === 'mtToggle') {
        var body = target.closest('.mt-criterion__header').nextElementSibling;
        var collapsed = body.classList.toggle('mt-criterion__body--collapsed');
        target.setAttribute('aria-expanded', collapsed ? 'false' : 'true');
        target.textContent = collapsed ? '\u25BC' : '\u25B2';
      }

      if (action === 'mtSelect') {
        mtSelect(target.getAttribute('data-criterion-id'), target.getAttribute('data-status'), target);
      }

      if (action === 'mtSaveCommit') {
        mtSaveCommit(target.getAttribute('data-scan-id'), target.getAttribute('data-criterion-id'));
      }

      if (action === 'mtFilter') {
        mtFilter(target.getAttribute('data-status'), target);
      }

      if (action === 'mtEvidenceUpload') {
        mtEvidenceUpload(target.getAttribute('data-scan-id'), target.getAttribute('data-criterion-id'));
      }

      if (action === 'mtEvidenceDelete') {
        mtEvidenceDelete(
          target.getAttribute('data-scan-id'),
          target.getAttribute('data-evidence-id'),
          target.getAttribute('data-criterion-id')
        );
      }
    });
  })();

  /* ── CSRF helper ─────────────────────────────────────────────────────── */
  function mtCsrfToken() {
    var meta = document.querySelector('meta[name="csrf-token"]');
    return meta ? meta.getAttribute('content') : '';
  }

  /* ── Upload an evidence file for a criterion ─────────────────────────── */
  function mtEvidenceUpload(scanId, criterionId) {
    var input = document.getElementById('mt-ev-file-' + criterionId);
    var file = input && input.files && input.files[0];
    if (!file) {
      showToast('Choose a file first', 'error');
      return;
    }
    // In-flight guard: ignore re-entrant calls for the same input until the
    // current upload settles (belt-and-suspenders against any double trigger).
    if (input.getAttribute('data-uploading') === '1') return;
    input.setAttribute('data-uploading', '1');

    var fd = new FormData();
    fd.append('file', file);

    fetch('/reports/' + scanId + '/evidence/' + encodeURIComponent(criterionId), {
      method: 'POST',
      headers: { 'x-csrf-token': mtCsrfToken(), 'HX-Request': 'true' },
      body: fd
    })
    .then(function(r) { if (!r.ok) throw new Error('Upload failed (' + r.status + ')'); return r.text(); })
    .then(function(html) {
      mtSwapEvidenceList(criterionId, html);
      input.value = '';
      showToast('Evidence uploaded', 'success');
    })
    .catch(function(err) { showToast(err.message, 'error'); })
    .then(function() { input.removeAttribute('data-uploading'); });
  }

  /* ── Delete an evidence file (irreversible — confirm first) ──────────── */
  function mtEvidenceDelete(scanId, evidenceId, criterionId) {
    if (!window.confirm('Delete this evidence file? This cannot be undone.')) return;
    fetch('/reports/' + scanId + '/evidence/' + evidenceId + '/delete', {
      method: 'POST',
      headers: { 'x-csrf-token': mtCsrfToken(), 'HX-Request': 'true' }
    })
    .then(function(r) { if (!r.ok) throw new Error('Delete failed'); return r.text(); })
    .then(function(html) {
      mtSwapEvidenceList(criterionId, html);
      showToast('Evidence removed', 'success');
    })
    .catch(function(err) { showToast(err.message, 'error'); });
  }

  /* ── Replace a criterion's evidence list with the returned fragment ──── */
  function mtSwapEvidenceList(criterionId, html) {
    var existing = document.getElementById('mt-ev-list-' + criterionId);
    if (!existing) return;
    var temp = document.createElement('div');
    temp.innerHTML = html;
    var fresh = temp.querySelector('.mt-evidence__list');
    if (fresh) existing.replaceWith(fresh);
  }

  /* ── Status label / badge-class maps ────────────────────────────────── */
  var MT_LABELS = { pass: 'Pass', fail: 'Fail', na: 'N/A', untested: 'Untested' };
  var MT_BADGE = { pass: 'mt-badge--pass', fail: 'mt-badge--fail', na: 'mt-badge--na', untested: 'mt-badge--untested' };

  /* ── Select a verdict (pending only — nothing is saved until Save) ──── */
  function mtSelect(criterionId, status, btn) {
    var actions = btn.parentNode;
    var already = btn.classList.contains('mt-btn--active');
    actions.querySelectorAll('.mt-btn').forEach(function(b) { b.classList.remove('mt-btn--active'); });
    // Clicking the active verdict again clears it (→ untested) so mistakes are
    // freely revisable before committing.
    if (!already) btn.classList.add('mt-btn--active');
    var hint = document.getElementById('mt-dirty-' + criterionId);
    if (hint) hint.hidden = false;
  }

  /* ── Commit the selected verdict (explicit save; confirm on change) ──── */
  function mtSaveCommit(scanId, criterionId) {
    var row = document.getElementById('mt-row-' + criterionId);
    if (!row) return;
    var actions = row.querySelector('.mt-actions');
    var activeBtn = actions ? actions.querySelector('.mt-btn--active') : null;
    var selected = activeBtn ? activeBtn.getAttribute('data-status') : 'untested';
    var saved = row.getAttribute('data-status') || 'untested';

    // Confirm changing an EXISTING verdict — disruptive, the user decides.
    if (selected !== saved && saved !== 'untested') {
      var msg = selected === 'untested'
        ? 'Clear the ' + MT_LABELS[saved] + ' verdict for ' + criterionId + '?'
        : 'Change ' + criterionId + ' from ' + MT_LABELS[saved] + ' to ' + MT_LABELS[selected] + '?';
      if (!window.confirm(msg)) return;
    }

    var notesEl = document.getElementById('mt-notes-' + criterionId);
    var notes = notesEl ? notesEl.value : '';

    var fd = new URLSearchParams();
    fd.append('criterionId', criterionId);
    fd.append('status', selected);
    fd.append('notes', notes);
    fd.append('comment', notes); // the note doubles as the change reason (audit)

    fetch('/reports/' + scanId + '/manual', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/x-www-form-urlencoded',
        'x-csrf-token': mtCsrfToken(),
        'HX-Request': 'true'
      },
      body: fd.toString()
    })
    .then(function(r) { if (!r.ok) throw new Error('Save failed (' + r.status + ')'); return r.json(); })
    .then(function(data) {
      row.setAttribute('data-status', data.status);
      var badge = row.querySelector('.mt-badge');
      if (badge) {
        badge.className = 'mt-badge ' + (MT_BADGE[data.status] || 'mt-badge--untested');
        badge.textContent = MT_LABELS[data.status] || 'Untested';
      }
      if (data.stats) {
        mtUpdateStats(data.stats.tested, data.stats.passed, data.stats.failed, data.stats.na, data.stats.untested, data.stats.percentage);
      }
      if (data.auditEntry) mtPrependHistory(criterionId, data.auditEntry);
      var hint = document.getElementById('mt-dirty-' + criterionId);
      if (hint) hint.hidden = true;
      showToast('Saved ' + criterionId + ' = ' + (MT_LABELS[data.status] || 'Untested'), 'success');
    })
    .catch(function(err) { showToast('Failed to save: ' + err.message, 'error'); });
  }

  /* ── Prepend a new audit entry to a criterion's history (safe DOM) ──── */
  function mtPrependHistory(criterionId, entry) {
    var list = document.getElementById('mt-history-' + criterionId);
    if (!list) return;
    var li = document.createElement('li');
    li.className = 'mt-history__item';
    var change = document.createElement('span');
    change.className = 'mt-history__change';
    change.textContent = (entry.fromStatus || 'untested') + ' → ' + entry.toStatus;
    li.appendChild(change);
    if (entry.comment) {
      var c = document.createElement('span');
      c.className = 'mt-history__comment';
      c.textContent = '“' + entry.comment + '”';
      li.appendChild(c);
    }
    var meta = document.createElement('span');
    meta.className = 'mt-history__meta';
    var when = entry.createdAt ? new Date(entry.createdAt).toLocaleString() : '';
    meta.textContent = (entry.actor || 'unknown') + ' · ' + when;
    li.appendChild(meta);
    list.insertBefore(li, list.firstChild);

    var wrap = document.getElementById('mt-history-wrap-' + criterionId);
    if (wrap) wrap.hidden = false;
    var count = document.getElementById('mt-history-count-' + criterionId);
    if (count) count.textContent = String(list.children.length);
  }

  /* ── Update progress stats (using textContent for safe DOM updates) ── */
  function mtUpdateStats(tested, passed, failed, na, untested, pct) {
    var fill = document.getElementById('mt-progress-fill');
    if (fill) fill.style.width = pct + '%';

    var pctEl = document.getElementById('mt-stat-pct');
    if (pctEl) {
      pctEl.textContent = '';
      var strong = document.createElement('strong');
      strong.textContent = pct + '%';
      pctEl.appendChild(strong);
      pctEl.appendChild(document.createTextNode(' complete'));
    }

    var map = {
      'mt-stat-tested': tested + ' tested',
      'mt-stat-pass': passed + ' pass',
      'mt-stat-fail': failed + ' fail',
      'mt-stat-na': na + ' N/A',
      'mt-stat-untested': untested + ' remaining'
    };
    for (var key in map) {
      var el = document.getElementById(key);
      if (el) el.textContent = map[key];
    }
  }

  /* ── Filter by status ───────────────────────────────────────────────── */
  function mtFilter(status, btn) {
    document.querySelectorAll('.mt-filter').forEach(function(f) {
      f.classList.remove('mt-filter--active');
    });
    btn.classList.add('mt-filter--active');

    document.querySelectorAll('.mt-criterion').forEach(function(row) {
      if (status === 'all') {
        row.style.display = '';
      } else {
        row.style.display = row.getAttribute('data-status') === status ? '' : 'none';
      }
    });
  }

  /* ── Toast helper (reuse existing toast container from layout) ───── */
  function showToast(msg, type) {
    var tc = document.getElementById('toast-container');
    if (!tc) return;
    var toast = document.createElement('div');
    toast.className = 'toast toast--' + (type || 'info');
    toast.setAttribute('role', 'status');
    toast.textContent = msg;
    tc.appendChild(toast);
    setTimeout(function() { toast.remove(); }, 3000);
  }
</script>
