{{! Trends — org-wide overview + per-site detail }}

<section aria-labelledby="trends-heading">
  <div class="page-header-row">
    <h2 id="trends-heading" class="section-title">{{t "trends.title"}}</h2>
    <a href="/api/v1/export/trends.csv" class="btn btn--ghost btn--sm" aria-label="Export trend data as Excel">{{t "trends.exportExcel"}}</a>
  </div>

  {{#if hasTrends}}
  {{! ── KPI Summary Cards ─────────────────────────────────────────── }}
  <section aria-labelledby="kpi-heading" class="mb-lg">
    <div class="trends-kpi-grid" role="region" aria-label="{{t "trends.kpiLabel"}}">
      <div class="card trends-kpi-card">
        <div class="trends-kpi-card__value">{{kpi.totalSites}}</div>
        <div class="trends-kpi-card__label">{{t "trends.sitesMonitored"}}</div>
      </div>
      <div class="card trends-kpi-card">
        <div class="trends-kpi-card__value">{{kpi.totalScans}}</div>
        <div class="trends-kpi-card__label">{{t "trends.totalScans"}}</div>
      </div>
      <div class="card trends-kpi-card">
        <div class="trends-kpi-card__value {{orgScoreClass}}">{{orgScore}}</div>
        <div class="trends-kpi-card__label">{{t "trends.accessibilityScore"}}</div>
      </div>
      <div class="card trends-kpi-card">
        {{#if kpi.hasChangePct}}
        <div class="trends-kpi-card__value {{kpiDirectionClass}}">{{kpi.overallChangePct}}%</div>
        {{else}}
        <div class="trends-kpi-card__value text--muted">&mdash;</div>
        {{/if}}
        <div class="trends-kpi-card__label">{{t "trends.overallChange"}}</div>
        <div class="trends-kpi-card__sub {{kpiDirectionClass}}">{{kpiDirectionLabel}}</div>
      </div>
    </div>
  </section>

  {{! ── Organization Overview ─────────────────────────────────────── }}
  <section aria-labelledby="org-overview-heading" class="mb-lg">
    <h3 id="org-overview-heading" class="section-title">{{t "trends.orgOverview"}}</h3>

    <div class="card mb-lg">
      <div class="trends-chart-container trends-chart-container--tall">
        <canvas id="org-trends-chart" aria-label="Organization-wide issue trends chart" role="img"></canvas>
      </div>
    </div>

    <div class="card mb-lg">
      <h4 class="card__subtitle">{{t "trends.siteScorecard"}}</h4>
      <div class="table-responsive" role="region" aria-label="Site scorecard table" tabindex="0">
        <table class="data-table" aria-label="Site scores and trends">
          <caption class="sr-only">{{t "trends.scorecardCaption"}}</caption>
          <thead>
            <tr>
              <th scope="col">{{t "trends.siteUrl"}}</th>
              <th scope="col">{{t "trends.score"}}</th>
              <th scope="col">{{t "trends.trend"}}</th>
              <th scope="col">{{t "trends.lastScanned"}}</th>
            </tr>
          </thead>
          <tbody>
            {{#each siteScores}}
            <tr>
              <td data-label="Site URL" class="cell--url">{{siteUrl}}</td>
              <td data-label="Score"><span class="{{scoreClass}} fw-bold">{{score}}</span></td>
              <td data-label="Trend">
                <span class="{{trendClass}}">{{{trendArrow}}} {{trendLabel}}</span>
              </td>
              <td data-label="Last Scanned">{{lastScannedDisplay}}</td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  {{! ── Per-Site Detail ───────────────────────────────────────────── }}
  <section aria-labelledby="per-site-heading">
    <h3 id="per-site-heading" class="section-title">{{t "trends.perSiteDetail"}}</h3>

    <div class="card mb-lg">
      <div class="form-group">
        <label for="site-selector">{{t "trends.selectSite"}}</label>
        <select id="site-selector" class="select" aria-label="Select site to view trends">
          {{#each siteUrls}}
          <option value="{{this}}">{{this}}</option>
          {{/each}}
        </select>
      </div>

      <div class="trends-chart-container">
        <canvas id="trends-chart" aria-label="Issue trends chart" role="img"></canvas>
      </div>
    </div>
  </section>

  <section aria-labelledby="summary-table-heading">
    <h2 id="summary-table-heading" class="section-title">{{t "trends.siteSummary"}}</h2>
    <div class="table-responsive" role="region" aria-label="Site trend summary table" tabindex="0">
      <table class="data-table" aria-label="Site trend summary">
        <caption class="sr-only">{{t "trends.summaryCaption"}}</caption>
        <thead>
          <tr>
            <th scope="col">{{t "trends.siteUrl"}}</th>
            <th scope="col">{{t "trends.latestScan"}}</th>
            <th scope="col">{{t "trends.errors"}}</th>
            <th scope="col">{{t "trends.warnings"}}</th>
            <th scope="col">{{t "trends.notices"}}</th>
            <th scope="col">{{t "trends.total"}}</th>
            <th scope="col">{{t "trends.trend"}}</th>
          </tr>
        </thead>
        <tbody>
          {{#each summaryTable}}
          <tr>
            <td data-label="Site URL" class="cell--url">{{siteUrl}}</td>
            <td data-label="Latest Scan">{{latestDateDisplay}}</td>
            <td data-label="Errors">
              <span class="text--error">{{latestErrors}}</span>
              {{#if deltaErrors}}
                <span class="trend-delta {{#if (cmpNegative deltaErrors)}}text--success{{else if (cmpPositive deltaErrors)}}text--error{{/if}}">
                  ({{cmpSign deltaErrors}})
                </span>
              {{/if}}
            </td>
            <td data-label="Warnings">
              <span class="text--warning">{{latestWarnings}}</span>
              {{#if deltaWarnings}}
                <span class="trend-delta {{#if (cmpNegative deltaWarnings)}}text--success{{else if (cmpPositive deltaWarnings)}}text--error{{/if}}">
                  ({{cmpSign deltaWarnings}})
                </span>
              {{/if}}
            </td>
            <td data-label="Notices">
              {{latestNotices}}
              {{#if deltaNotices}}
                <span class="trend-delta {{#if (cmpNegative deltaNotices)}}text--success{{else if (cmpPositive deltaNotices)}}text--error{{/if}}">
                  ({{cmpSign deltaNotices}})
                </span>
              {{/if}}
            </td>
            <td data-label="Total">
              <strong>{{latestTotal}}</strong>
              {{#if deltaTotal}}
                <span class="trend-delta {{#if (cmpNegative deltaTotal)}}text--success{{else if (cmpPositive deltaTotal)}}text--error{{/if}}">
                  ({{cmpSign deltaTotal}})
                </span>
              {{/if}}
            </td>
            <td data-label="Trend">
              <span class="badge {{trendClass}}">{{trendLabel}}</span>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </section>

  {{else}}
  <div class="empty-state" role="status">
    <div class="empty-state__icon">&#128200;</div>
    <div class="empty-state__title">{{t "trends.noDataTitle"}}</div>
    <div class="empty-state__desc">{{t "trends.noDataDesc"}}</div>
    <a href="/scan/new" class="btn btn--primary">{{t "common.newScan"}}</a>
  </div>
  {{/if}}
</section>

{{#if hasTrends}}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
<script>
  var trendData = {{{json trendData}}};
  var orgTotals = {{{json orgTotals}}};

  (function () {
    // ── Helpers ────────────────────────────────────────────────────
    function formatDate(dateStr) {
      return new Date(dateStr).toLocaleDateString(undefined, {
        month: 'short', day: 'numeric', year: 'numeric'
      });
    }

    function pctChange(prev, cur) {
      if (prev === 0) return cur > 0 ? '+100%' : '0%';
      var pct = Math.round(((cur - prev) / prev) * 100);
      return (pct > 0 ? '+' : '') + pct + '%';
    }

    // Generate per-point colors: green for decrease, red for increase, default otherwise
    function trendPointColors(data, defaultColor) {
      return data.map(function (val, i) {
        if (i === 0) return defaultColor;
        if (val < data[i - 1]) return '#1a7a3a';
        if (val > data[i - 1]) return '#b91c1c';
        return defaultColor;
      });
    }

    function trendPointRadii(data) {
      return data.map(function (val, i) {
        if (i === 0) return 3;
        return val !== data[i - 1] ? 5 : 3;
      });
    }

    // Shared tooltip with percentage change from previous point
    var tooltipWithChange = {
      callbacks: {
        afterLabel: function (context) {
          var idx = context.dataIndex;
          if (idx === 0) return '';
          var prev = context.dataset.data[idx - 1];
          var cur = context.dataset.data[idx];
          return pctChange(prev, cur) + ' vs previous';
        }
      }
    };

    // ── Org-wide trend chart ──────────────────────────────────────
    var orgCtx = document.getElementById('org-trends-chart');
    if (orgCtx && orgTotals.length > 0) {
      var orgTotalIssues = orgTotals.map(function (p) { return p.totalIssues; });
      var orgErrors = orgTotals.map(function (p) { return p.errors; });
      var orgWarnings = orgTotals.map(function (p) { return p.warnings; });
      var orgNotices = orgTotals.map(function (p) { return p.notices; });

      new Chart(orgCtx.getContext('2d'), {
        type: 'line',
        data: {
          labels: orgTotals.map(function (p) { return formatDate(p.date); }),
          datasets: [
            {
              label: '{{t "trends.total"}}',
              data: orgTotalIssues,
              borderColor: '#374151',
              backgroundColor: 'rgba(55, 65, 81, 0.08)',
              borderWidth: 2,
              tension: 0.3,
              fill: true,
              pointBackgroundColor: trendPointColors(orgTotalIssues, '#374151'),
              pointRadius: trendPointRadii(orgTotalIssues),
              order: 1
            },
            {
              label: '{{t "trends.errors"}}',
              data: orgErrors,
              borderColor: '#8b1a1a',
              backgroundColor: 'rgba(139, 26, 26, 0.1)',
              tension: 0.3,
              fill: false,
              pointBackgroundColor: trendPointColors(orgErrors, '#8b1a1a'),
              pointRadius: trendPointRadii(orgErrors),
              order: 2
            },
            {
              label: '{{t "trends.warnings"}}',
              data: orgWarnings,
              borderColor: '#7a4f00',
              backgroundColor: 'rgba(122, 79, 0, 0.1)',
              tension: 0.3,
              fill: false,
              pointBackgroundColor: trendPointColors(orgWarnings, '#7a4f00'),
              pointRadius: trendPointRadii(orgWarnings),
              order: 3
            },
            {
              label: '{{t "trends.notices"}}',
              data: orgNotices,
              borderColor: '#00416a',
              backgroundColor: 'rgba(0, 65, 106, 0.1)',
              tension: 0.3,
              fill: false,
              pointBackgroundColor: trendPointColors(orgNotices, '#00416a'),
              pointRadius: trendPointRadii(orgNotices),
              order: 4
            }
          ]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: { mode: 'index', intersect: false },
          plugins: {
            legend: { position: 'top' },
            title: { display: true, text: '{{t "trends.orgChartTitle"}}' },
            tooltip: tooltipWithChange
          },
          scales: {
            y: { beginAtZero: true, title: { display: true, text: '{{t "trends.issueCount"}}' } },
            x: { title: { display: true, text: '{{t "trends.date"}}' } }
          }
        }
      });
    }

    // ── Per-site trend chart ──────────────────────────────────────
    var ctx = document.getElementById('trends-chart').getContext('2d');
    var selector = document.getElementById('site-selector');
    var chart = null;

    function renderChart(siteUrl) {
      var site = trendData.find(function (t) { return t.siteUrl === siteUrl; });
      if (!site) return;

      var labels = site.points.map(function (p) { return formatDate(p.date); });
      var errors = site.points.map(function (p) { return p.errors; });
      var warnings = site.points.map(function (p) { return p.warnings; });
      var notices = site.points.map(function (p) { return p.notices; });
      var totals = site.points.map(function (p) { return p.totalIssues; });

      if (chart) {
        chart.destroy();
      }

      chart = new Chart(ctx, {
        type: 'line',
        data: {
          labels: labels,
          datasets: [
            {
              label: '{{t "trends.total"}}',
              data: totals,
              borderColor: '#374151',
              backgroundColor: 'rgba(55, 65, 81, 0.08)',
              borderWidth: 2,
              tension: 0.3,
              fill: true,
              pointBackgroundColor: trendPointColors(totals, '#374151'),
              pointRadius: trendPointRadii(totals),
              order: 1
            },
            {
              label: '{{t "trends.errors"}}',
              data: errors,
              borderColor: '#8b1a1a',
              backgroundColor: 'rgba(139, 26, 26, 0.1)',
              tension: 0.3,
              fill: false,
              pointBackgroundColor: trendPointColors(errors, '#8b1a1a'),
              pointRadius: trendPointRadii(errors),
              order: 2
            },
            {
              label: '{{t "trends.warnings"}}',
              data: warnings,
              borderColor: '#7a4f00',
              backgroundColor: 'rgba(122, 79, 0, 0.1)',
              tension: 0.3,
              fill: false,
              pointBackgroundColor: trendPointColors(warnings, '#7a4f00'),
              pointRadius: trendPointRadii(warnings),
              order: 3
            },
            {
              label: '{{t "trends.notices"}}',
              data: notices,
              borderColor: '#00416a',
              backgroundColor: 'rgba(0, 65, 106, 0.1)',
              tension: 0.3,
              fill: false,
              pointBackgroundColor: trendPointColors(notices, '#00416a'),
              pointRadius: trendPointRadii(notices),
              order: 4
            }
          ]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: { mode: 'index', intersect: false },
          plugins: {
            legend: { position: 'top' },
            title: {
              display: true,
              text: '{{t "trends.siteChartTitle"}} \u2014 ' + siteUrl
            },
            tooltip: tooltipWithChange
          },
          scales: {
            y: {
              beginAtZero: true,
              title: { display: true, text: '{{t "trends.issueCount"}}' }
            },
            x: {
              title: { display: true, text: '{{t "trends.scanDate"}}' }
            }
          }
        }
      });
    }

    selector.addEventListener('change', function () {
      renderChart(this.value);
    });

    // Render first site by default
    if (trendData.length > 0) {
      renderChart(trendData[0].siteUrl);
    }
  })();
</script>
{{/if}}
