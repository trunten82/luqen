{{! Trends — issue trends over time per site }}

<section aria-labelledby="trends-heading">
  <div style="display:flex;align-items:center;gap:1rem;flex-wrap:wrap;">
    <h2 id="trends-heading" class="section-title" style="margin:0;">Issue Trends</h2>
    <a href="/api/v1/export/trends.csv" class="btn btn--ghost btn--sm" aria-label="Export trend data as CSV">Export CSV</a>
  </div>

  {{#if hasTrends}}
  <div class="card mb-lg">
    <div class="form-group">
      <label for="site-selector">Select Site</label>
      <select id="site-selector" class="select" aria-label="Select site to view trends">
        {{#each siteUrls}}
        <option value="{{this}}">{{this}}</option>
        {{/each}}
      </select>
    </div>

    <div class="trends-chart-container">
      <canvas id="trends-chart" aria-label="Issue trends chart" role="img"></canvas>
    </div>
  </div>

  <section aria-labelledby="summary-table-heading">
    <h2 id="summary-table-heading" class="section-title">Site Summary</h2>
    <div class="table-responsive" role="region" aria-label="Site trend summary table" tabindex="0">
      <table class="data-table" aria-label="Site trend summary">
        <caption class="sr-only">Summary of latest scan results per site with trend indicators</caption>
        <thead>
          <tr>
            <th scope="col">Site URL</th>
            <th scope="col">Latest Scan</th>
            <th scope="col">Errors</th>
            <th scope="col">Warnings</th>
            <th scope="col">Notices</th>
            <th scope="col">Total</th>
            <th scope="col">Trend</th>
          </tr>
        </thead>
        <tbody>
          {{#each summaryTable}}
          <tr>
            <td data-label="Site URL" class="cell--url">{{siteUrl}}</td>
            <td data-label="Latest Scan">{{latestDateDisplay}}</td>
            <td data-label="Errors">
              <span class="text--error">{{latestErrors}}</span>
              {{#if deltaErrors}}
                <span class="trend-delta {{#if (cmpNegative deltaErrors)}}text--success{{else if (cmpPositive deltaErrors)}}text--error{{/if}}">
                  ({{cmpSign deltaErrors}})
                </span>
              {{/if}}
            </td>
            <td data-label="Warnings">
              <span class="text--warning">{{latestWarnings}}</span>
              {{#if deltaWarnings}}
                <span class="trend-delta {{#if (cmpNegative deltaWarnings)}}text--success{{else if (cmpPositive deltaWarnings)}}text--error{{/if}}">
                  ({{cmpSign deltaWarnings}})
                </span>
              {{/if}}
            </td>
            <td data-label="Notices">
              {{latestNotices}}
              {{#if deltaNotices}}
                <span class="trend-delta {{#if (cmpNegative deltaNotices)}}text--success{{else if (cmpPositive deltaNotices)}}text--error{{/if}}">
                  ({{cmpSign deltaNotices}})
                </span>
              {{/if}}
            </td>
            <td data-label="Total">
              <strong>{{latestTotal}}</strong>
              {{#if deltaTotal}}
                <span class="trend-delta {{#if (cmpNegative deltaTotal)}}text--success{{else if (cmpPositive deltaTotal)}}text--error{{/if}}">
                  ({{cmpSign deltaTotal}})
                </span>
              {{/if}}
            </td>
            <td data-label="Trend">
              <span class="badge {{trendClass}}">{{trendLabel}}</span>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </section>

  {{else}}
  <div class="empty-state" role="status">
    <p>No completed scans yet. Run some scans to see trend data here.</p>
  </div>
  {{/if}}
</section>

{{#if hasTrends}}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
<script>
  var trendData = {{{json trendData}}};

  (function () {
    var ctx = document.getElementById('trends-chart').getContext('2d');
    var selector = document.getElementById('site-selector');
    var chart = null;

    function renderChart(siteUrl) {
      var site = trendData.find(function (t) { return t.siteUrl === siteUrl; });
      if (!site) return;

      var labels = site.points.map(function (p) {
        return new Date(p.date).toLocaleDateString();
      });
      var errors = site.points.map(function (p) { return p.errors; });
      var warnings = site.points.map(function (p) { return p.warnings; });
      var notices = site.points.map(function (p) { return p.notices; });

      if (chart) {
        chart.destroy();
      }

      chart = new Chart(ctx, {
        type: 'line',
        data: {
          labels: labels,
          datasets: [
            {
              label: 'Errors',
              data: errors,
              borderColor: '#8b1a1a',
              backgroundColor: 'rgba(139, 26, 26, 0.1)',
              tension: 0.3,
              fill: false
            },
            {
              label: 'Warnings',
              data: warnings,
              borderColor: '#7a4f00',
              backgroundColor: 'rgba(122, 79, 0, 0.1)',
              tension: 0.3,
              fill: false
            },
            {
              label: 'Notices',
              data: notices,
              borderColor: '#00416a',
              backgroundColor: 'rgba(0, 65, 106, 0.1)',
              tension: 0.3,
              fill: false
            }
          ]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              position: 'top'
            },
            title: {
              display: true,
              text: 'Issues Over Time — ' + siteUrl
            }
          },
          scales: {
            y: {
              beginAtZero: true,
              title: {
                display: true,
                text: 'Issue Count'
              }
            },
            x: {
              title: {
                display: true,
                text: 'Scan Date'
              }
            }
          }
        }
      });
    }

    selector.addEventListener('change', function () {
      renderChart(this.value);
    });

    // Render first site by default
    if (trendData.length > 0) {
      renderChart(trendData[0].siteUrl);
    }
  })();
</script>
{{/if}}
