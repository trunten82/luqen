<main id="main-content" class="content-narrow" role="main">
  <section class="card consent" aria-labelledby="consent-heading">
    <h1 id="consent-heading">Authorize {{client.clientName}}</h1>
    <p class="muted">This application is requesting access to your Luqen account.</p>

    {{#if noMcpUse}}
      {{!-- Phase 31.2 D-05/D-06: user lacks mcp.use in the active org.
            Offer a switch CTA to any other org where they DO hold mcp.use,
            or render the ask-your-admin card if switchableOrgs is empty. --}}
      <div class="alert alert--warning" role="alert" aria-live="polite">
        <div class="alert__body">
          <div class="alert__title">MCP access required</div>
          <p>
            You don't have permission to connect via MCP in your active
            organisation (<strong>{{activeOrgId}}</strong>).
          </p>
          {{#if switchableOrgs.length}}
            <p>You do have MCP access in:</p>
            <ul class="org-list">
              {{#each switchableOrgs}}
                <li>
                  <form method="POST" action="/session/switch-org">
                    <input type="hidden" name="_csrf" value="{{../csrfToken}}" aria-label="CSRF token" />
                    <input type="hidden" name="orgId" value="{{this.id}}" aria-label="Target organisation id" />
                    <input type="hidden" name="returnTo" value="{{../returnTo}}" aria-label="Return URL" />
                    <button type="submit" class="btn btn--primary">
                      Switch to {{this.name}} and retry
                    </button>
                  </form>
                </li>
              {{/each}}
            </ul>
          {{else}}
            <p>
              Ask your organisation admin to grant you the
              <strong>Connect via MCP</strong> permission on your role in
              <code>/admin/roles</code>.
            </p>
          {{/if}}
        </div>
      </div>
    {{else if adminScopeBlocked}}
      {{!-- Deprecated variant (Phase 31.2 D-10): admin.* scopes are now
            rejected with 400 invalid_scope before this view is rendered, so
            this branch is unreachable from real traffic. Kept only for
            back-compat with any test harness that constructs this view
            shape directly. --}}
      <div class="alert alert--error" role="alert" aria-live="polite">
        <div class="alert__body">
          <div class="alert__title">No scopes you can grant</div>
          <p>
            The client asked for scopes that all require permissions you
            don't currently have in your active org. Ask your org admin to
            authorize this client, or reconfigure the client to request
            narrower scopes.
          </p>
          {{#if skippedScopes.length}}
            <p class="muted">Requested scopes you lack:</p>
            <ul class="consent__scopes">
              {{#each skippedScopes}}
                <li><code>{{this}}</code></li>
              {{/each}}
            </ul>
          {{/if}}
        </div>
      </div>
    {{else}}
      <dl class="consent__kv">
        <dt>Signed in as</dt>
        <dd>{{user.username}} <span class="muted">({{user.role}})</span></dd>

        <dt>Active org</dt>
        <dd>{{orgName}}</dd>

        <dt>Scopes to grant</dt>
        <dd>
          <ul class="consent__scopes">
            {{#each scopeDescriptions}}
              <li><code>{{this.scope}}</code><span class="consent__scope-desc">{{this.description}}</span></li>
            {{/each}}
          </ul>
        </dd>

        {{#if skippedScopeDescriptions.length}}
          <dt>Scopes skipped</dt>
          <dd>
            <p class="muted" style="margin-top:0;">These scopes the client asked for will NOT be granted because you don't have the matching permission:</p>
            <ul class="consent__scopes consent__scopes--skipped">
              {{#each skippedScopeDescriptions}}
                <li><code>{{this.scope}}</code><span class="consent__scope-desc">{{this.description}}</span></li>
              {{/each}}
            </ul>
          </dd>
        {{/if}}

        <dt>Can reach services</dt>
        <dd>
          <ul class="consent__resources">
            {{#each resources}}
              <li><code>{{this}}</code></li>
            {{/each}}
          </ul>
        </dd>

        <dt>Will redirect to</dt>
        <dd><code class="consent__redirect">{{redirectUri}}</code></dd>
      </dl>

      <form method="POST" action="/oauth/authorize/consent" class="consent__actions" aria-labelledby="consent-heading">
        <input type="hidden" name="_csrf"                 value="{{csrfToken}}" aria-label="CSRF token" />
        <input type="hidden" name="client_id"             value="{{clientId}}" aria-label="OAuth client id" />
        <input type="hidden" name="redirect_uri"          value="{{redirectUri}}" aria-label="Redirect URI" />
        <input type="hidden" name="scope"                 value="{{requestedScope}}" aria-label="Requested scope" />
        <input type="hidden" name="resource"              value="{{requestedResource}}" aria-label="Requested resource" />
        <input type="hidden" name="state"                 value="{{state}}" aria-label="OAuth state parameter" />
        <input type="hidden" name="code_challenge"        value="{{codeChallenge}}" aria-label="PKCE code challenge" />
        <input type="hidden" name="code_challenge_method" value="S256" aria-label="PKCE method" />

        <button type="submit" name="approved" value="true"  class="btn btn--primary">Allow</button>
        <button type="submit" name="approved" value="false" class="btn btn--secondary">Deny</button>
      </form>
    {{/if}}
  </section>
</main>
