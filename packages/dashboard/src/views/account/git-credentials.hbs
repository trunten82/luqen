<div class="page-header">
  <h1 class="page-header__title">Git Credentials</h1>
</div>

{{#if success}}
<div class="alert alert--success" role="status" aria-live="polite">
  <div class="alert__body">{{success}}</div>
</div>
{{/if}}

{{#if error}}
<div class="alert alert--error" role="alert" aria-live="assertive">
  <div class="alert__body">{{error}}</div>
</div>
{{/if}}

{{!-- Stored credentials table --}}
<div class="card mb-lg">
  <h2 class="card__title">Stored Credentials</h2>

  {{#if credentials.length}}
  <div class="table-responsive">
    <table class="data-table" aria-label="Stored git credentials">
      <thead>
        <tr>
          <th scope="col">Host</th>
          <th scope="col">Type</th>
          <th scope="col">Username</th>
          <th scope="col">Token</th>
          <th scope="col">Actions</th>
        </tr>
      </thead>
      <tbody>
        {{#each credentials}}
        <tr id="credential-{{this.id}}">
          <td data-label="Host">{{this.hostDisplayName}}</td>
          <td data-label="Type"><span class="badge badge--neutral">{{this.hostPluginType}}</span></td>
          <td data-label="Username">{{#if this.validatedUsername}}{{this.validatedUsername}}{{else}}<em>—</em>{{/if}}</td>
          <td data-label="Token"><code>{{this.tokenHint}}</code></td>
          <td data-label="Actions">
            <button
              hx-delete="/account/git-credentials/{{this.id}}"
              hx-confirm="Remove this credential? You will need to re-enter your token."
              hx-target="#credential-{{this.id}}"
              hx-swap="outerHTML swap:300ms"
              class="btn btn--sm btn--danger"
              aria-label="Remove credential for {{this.hostDisplayName}}"
            >Remove</button>
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{else}}
  <p class="text--muted">No git credentials stored yet. Add one below to enable repository integrations.</p>
  {{/if}}
</div>

{{!-- Add credential section --}}
{{#if availableHosts.length}}
<div class="card">
  <h2 class="card__title">Add Credential</h2>
  <p class="form-hint mb-md">Select a git host and enter your Personal Access Token (PAT). The token will be validated before saving.</p>

  {{#each availableHosts}}
  <div class="card card--nested mb-md">
    <h3 class="card__subtitle">{{this.displayName}} <span class="badge badge--neutral">{{this.pluginType}}</span></h3>
    <form method="POST" action="/account/git-credentials" hx-post="/account/git-credentials" hx-target="body" novalidate>
      <input type="hidden" name="_csrf" value="{{../csrfToken}}">
      <input type="hidden" name="gitHostConfigId" value="{{this.id}}">
      <div class="form-group">
        <label for="token-{{this.id}}">
          Personal Access Token
          <span class="required" aria-hidden="true">*</span>
        </label>
        <input
          type="password"
          id="token-{{this.id}}"
          name="token"
          class="input"
          placeholder="ghp_... or PAT"
          required
          aria-required="true"
          autocomplete="off"
        >
      </div>
      <div class="form-group mt-md">
        <button type="submit" class="btn btn--primary">Validate &amp; Save</button>
      </div>
    </form>
  </div>
  {{/each}}
</div>
{{else}}
{{#unless credentials.length}}
<div class="card">
  <p class="text--muted">No git host configurations available for your organisation. An administrator needs to set up git host connections first.</p>
</div>
{{/unless}}
{{/if}}
