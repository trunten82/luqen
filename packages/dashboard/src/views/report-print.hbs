<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Accessibility Report — {{scan.siteUrl}}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      color: #1a1a1a; background: #fff; margin: 0; padding: 2rem; font-size: 11pt; line-height: 1.5;
    }
    h1 { font-size: 1.4rem; margin: 0 0 0.15rem; }
    h2 { font-size: 1.1rem; margin: 1.5rem 0 0.6rem; border-bottom: 2px solid #0056b3; padding-bottom: 0.25rem; color: #0056b3; }
    a { color: #0056b3; text-decoration: none; }

    .print-bar { display: flex; justify-content: flex-end; gap: 0.75rem; margin-bottom: 1.25rem; padding: 0.5rem 0; border-bottom: 1px solid #d0d4de; }
    .print-btn { display: inline-block; padding: 0.45rem 1.1rem; background: #0056b3; color: #fff; border: none; border-radius: 4px; font-size: 0.85rem; cursor: pointer; }
    .print-btn:hover { background: #003d82; }
    .print-btn--secondary { background: #6b6b6b; }

    .header-meta { font-size: 0.85rem; color: #4a4a4a; margin-bottom: 1.25rem; }
    .header-meta span { margin-right: 1.5rem; }

    /* Summary cards */
    .kpi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 0.75rem; margin-bottom: 1.5rem; }
    .kpi { border: 1px solid #d0d4de; border-radius: 6px; padding: 0.75rem; text-align: center; }
    .kpi__value { font-size: 1.6rem; font-weight: 800; display: block; }
    .kpi__label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.04em; color: #6b6b6b; }
    .kpi--error .kpi__value { color: #8b1a1a; }
    .kpi--warning .kpi__value { color: #7a4f00; }
    .kpi--notice .kpi__value { color: #00416a; }

    /* Priority action table */
    table { width: 100%; border-collapse: collapse; font-size: 0.82rem; margin-bottom: 1rem; }
    th, td { padding: 0.45rem 0.6rem; text-align: left; border-bottom: 1px solid #d0d4de; }
    th { background: #f5f6fa; font-weight: 700; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.03em; }
    tr:nth-child(even) { background: #fafbfc; }

    .severity { display: inline-block; padding: 0.12rem 0.45rem; border-radius: 3px; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; }
    .severity--error { background: #f8d7da; color: #8b1a1a; }
    .severity--warning { background: #fff3cd; color: #7a4f00; }
    .severity--notice { background: #d1ecf1; color: #00416a; }

    .reg-tag { display: inline-block; padding: 0.08rem 0.35rem; border-radius: 3px; font-size: 0.65rem; font-weight: 600; margin-right: 0.15rem; }
    .reg-tag--mandatory { background: #f8d7da; color: #8b1a1a; }
    .reg-tag--recommended { background: #fff3cd; color: #7a4f00; }
    .reg-tag--optional { background: #d1ecf1; color: #00416a; }

    .component-tag { display: inline-block; padding: 0.08rem 0.35rem; border-radius: 3px; font-size: 0.65rem; font-weight: 600; background: #eef0f7; color: #4a4a4a; }

    /* Compliance cards */
    .juris-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 0.75rem; margin-bottom: 1rem; }
    .juris-card { border: 1px solid #d0d4de; border-radius: 6px; overflow: hidden; }
    .juris-card__head { padding: 0.45rem 0.65rem; display: flex; justify-content: space-between; align-items: center; }
    .juris-card__head--pass { background: #d4edda; }
    .juris-card__head--fail { background: #f8d7da; }
    .juris-card__head--review { background: #fff3cd; }
    .juris-card__name { font-weight: 700; font-size: 0.85rem; }
    .juris-card__status { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; }
    .juris-card__body { padding: 0.4rem 0.65rem; font-size: 0.8rem; }

    .text-muted { color: #6b6b6b; }
    .text-sm { font-size: 0.8rem; }
    .mb-0 { margin-bottom: 0; }

    .report-footer { margin-top: 2rem; padding-top: 0.5rem; border-top: 1px solid #d0d4de; font-size: 0.72rem; color: #6b6b6b; text-align: center; }

    @media print {
      body { padding: 0; font-size: 9.5pt; }
      .print-bar { display: none !important; }
      .kpi-grid { gap: 0.5rem; }
      table { page-break-inside: auto; }
      tr { page-break-inside: avoid; }
      a { color: #1a1a1a; }
      a[href]::after { content: none !important; }
    }
  </style>
</head>
<body>

<div class="print-bar">
  <button class="print-btn" onclick="window.print()">Print / Save as PDF</button>
  <button class="print-btn print-btn--secondary" onclick="window.close()">Close</button>
</div>

<h1>Accessibility Report</h1>
<div class="header-meta">
  <span><strong>{{scan.siteUrl}}</strong></span>
  <span>{{formatStandard scan.standard}}</span>
  {{#if scan.jurisdictions}}<span>{{scan.jurisdictions}}</span>{{/if}}
  <span>{{scan.createdAtDisplay}}</span>
</div>

{{#if reportData}}

{{! ── Key Metrics ──────────────────────────────────────────── }}
<div class="kpi-grid">
  <div class="kpi"><span class="kpi__value">{{reportData.summary.pagesScanned}}</span><span class="kpi__label">Pages Scanned</span></div>
  <div class="kpi"><span class="kpi__value">{{reportData.summary.totalIssues}}</span><span class="kpi__label">Total Issues</span></div>
  <div class="kpi kpi--error"><span class="kpi__value">{{reportData.summary.byLevel.error}}</span><span class="kpi__label">Errors</span></div>
  <div class="kpi kpi--warning"><span class="kpi__value">{{reportData.summary.byLevel.warning}}</span><span class="kpi__label">Warnings</span></div>
  <div class="kpi kpi--notice"><span class="kpi__value">{{reportData.summary.byLevel.notice}}</span><span class="kpi__label">Notices</span></div>
  {{#if reportData.templateIssueCount}}
  <div class="kpi"><span class="kpi__value">{{reportData.templateIssueCount}}</span><span class="kpi__label">Template Issues</span></div>
  {{/if}}
</div>

{{! ── Legal Compliance ─────────────────────────────────────── }}
{{#if reportData.complianceMatrix}}
<h2>Legal Compliance</h2>
<div class="juris-grid">
  {{#each reportData.complianceMatrix}}
  <div class="juris-card">
    <div class="juris-card__head juris-card__head--{{reviewStatusClass reviewStatus}}">
      <div>
        <div class="juris-card__name">{{jurisdictionName}}</div>
      </div>
      <div class="juris-card__status">{{reviewStatusLabel reviewStatus}}</div>
    </div>
    <div class="juris-card__body">
      WCAG criteria violated: <strong>{{confirmedViolations}}</strong>
      {{#if needsReview}} &middot; Needs review: <strong>{{needsReview}}</strong>{{/if}}
    </div>
  </div>
  {{/each}}
</div>
{{/if}}

{{! ── Priority Action Items (errors + warnings only) ────────── }}
<h2>Priority Action Items</h2>
<p class="text-sm text-muted">Errors and warnings grouped by WCAG criterion — address these first. Notices omitted for clarity.</p>

<table>
  <thead>
    <tr>
      <th style="width:70px;">Severity</th>
      <th style="width:90px;">WCAG</th>
      <th>Issue</th>
      <th style="width:110px;">Impact</th>
      <th style="width:80px;">Pages</th>
    </tr>
  </thead>
  <tbody>
    {{#each reportData.allIssueGroups}}
    {{#if errorCount}}
    <tr>
      <td><span class="severity severity--error">{{errorCount}} err</span></td>
      <td><strong>{{criterion}}</strong></td>
      <td>
        {{title}}
        {{#each regulations}}<span class="reg-tag reg-tag--{{obligationClass obligation}}">{{shortName}}</span>{{/each}}
        {{#each components}}<span class="component-tag">{{this}}</span>{{/each}}
      </td>
      <td>{{#if templateItems.length}}Template{{else}}Page-specific{{/if}}</td>
      <td>{{pageCount}}</td>
    </tr>
    {{/if}}
    {{#if warningCount}}
    {{#unless errorCount}}
    <tr>
      <td><span class="severity severity--warning">{{warningCount}} warn</span></td>
      <td><strong>{{criterion}}</strong></td>
      <td>
        {{title}}
        {{#each regulations}}<span class="reg-tag reg-tag--{{obligationClass obligation}}">{{shortName}}</span>{{/each}}
        {{#each components}}<span class="component-tag">{{this}}</span>{{/each}}
      </td>
      <td>{{#if templateItems.length}}Template{{else}}Page-specific{{/if}}</td>
      <td>{{pageCount}}</td>
    </tr>
    {{/unless}}
    {{#if errorCount}}
    <tr>
      <td><span class="severity severity--warning">+{{warningCount}} warn</span></td>
      <td colspan="4" class="text-sm text-muted" style="padding-left:1.5rem;">Additional warnings for same criterion</td>
    </tr>
    {{/if}}
    {{/if}}
    {{/each}}
  </tbody>
</table>

{{! ── Template / Shared Component Issues ───────────────────── }}
{{#unless isExecutive}}
{{#if reportData.templateComponents.length}}
<h2>Shared Component Issues</h2>
<p class="text-sm text-muted">These issues appear in shared components — fixing the component resolves all affected pages.</p>

<table>
  <thead>
    <tr>
      <th style="width:130px;">Component</th>
      <th style="width:70px;">Severity</th>
      <th style="width:80px;">WCAG</th>
      <th>Issue</th>
      <th style="width:70px;">Pages</th>
    </tr>
  </thead>
  <tbody>
    {{#each reportData.templateComponents}}
    {{#each issues}}
    <tr>
      {{#if @first}}<td rowspan="{{../issueCount}}"><strong>{{../componentName}}</strong></td>{{/if}}
      <td><span class="severity severity--{{type}}">{{type}}</span></td>
      <td>{{#if wcagCriterion}}{{wcagCriterion}}{{else}}<span class="text-muted">—</span>{{/if}}</td>
      <td>{{message}}</td>
      <td>{{affectedCount}}</td>
    </tr>
    {{/each}}
    {{/each}}
  </tbody>
</table>
{{/if}}
{{/unless}}

{{! ── Scan Errors ──────────────────────────────────────────── }}
{{#if reportData.errors.length}}
<h2>Scan Errors</h2>
{{#each reportData.errors}}
<div style="padding:0.35rem 0.6rem;background:#f8d7da;border-radius:4px;margin-bottom:0.4rem;font-size:0.82rem;">
  <strong>{{url}}</strong> — {{code}}: {{message}}
</div>
{{/each}}
{{/if}}

{{/if}}

<div class="report-footer">
  Generated by Pally Dashboard &middot; {{scan.createdAtDisplay}}
</div>

</body>
</html>
