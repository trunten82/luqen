<section aria-label="New accessibility scan">
  <p class="form-hint mb-md">
    Configure and launch a new accessibility scan. Fields marked with
    <span class="required" aria-hidden="true">*</span> are required.
  </p>

  <form method="POST" action="/scan/new" novalidate>
    <div class="card mb-md">
      <h3 class="card__title mb-md">Target URL</h3>
      <div class="form-group">
        <label for="siteUrl">
          Website URL <span class="required" aria-hidden="true">*</span>
        </label>
        <input type="url" id="siteUrl" name="siteUrl"
               placeholder="https://example.com"
               autocomplete="url" required aria-required="true"
               aria-describedby="siteUrl-hint">
        <p id="siteUrl-hint" class="form-hint">
          Enter the full URL including <code>https://</code>. The scanner will crawl linked pages.
        </p>
      </div>
    </div>

    <div class="card mb-md">
      <h3 class="card__title mb-md">WCAG Standard</h3>
      <div class="form-group">
        <label for="standard">
          Conformance Level <span class="required" aria-hidden="true">*</span>
        </label>
        <select id="standard" name="standard" required aria-required="true"
                aria-describedby="standard-hint">
          {{#each standards}}
          <option value="{{this}}" {{#if (eq this ../defaultStandard)}}selected{{/if}}>{{this}}</option>
          {{/each}}
        </select>
        <p id="standard-hint" class="form-hint">
          WCAG2AA is recommended for most compliance requirements.
        </p>
      </div>
    </div>

    {{#if jurisdictions.length}}
    <div class="card mb-md">
      <h3 class="card__title mb-md">Compliance Check</h3>
      <p class="form-hint mb-sm">Search and select jurisdictions or regulations. Leave empty to skip.</p>

      <div class="picker" id="scan-picker">
        <div class="picker__tabs">
          <button type="button" class="picker__tab picker__tab--active" onclick="pickerTab('jurisdictions',this)">Jurisdictions</button>
          <button type="button" class="picker__tab" onclick="pickerTab('regulations',this)">Regulations</button>
        </div>
        <input type="search" class="picker__search" placeholder="Search..." oninput="pickerSearch(this.value)" aria-label="Search">
        <div class="picker__list">
          {{#each jurisdictions}}
          <label class="picker__item" data-tab="jurisdictions" data-name="{{name}}">
            <input type="checkbox" name="jurisdictions" value="{{id}}">
            <span>{{name}}</span>
            <span class="text-xs text-muted">{{id}}</span>
          </label>
          {{/each}}
          {{#each regulations}}
          <label class="picker__item" data-tab="regulations" data-name="{{name}} {{shortName}}" style="display:none">
            <input type="checkbox" name="jurisdictions" value="{{jurisdictionId}}">
            <span>{{shortName}}</span>
            <span class="text-xs text-muted">{{name}}</span>
          </label>
          {{/each}}
        </div>
        <div class="picker__selected"></div>
      </div>
    </div>
    {{/if}}

    <div class="card mb-md">
      <h3 class="card__title mb-md">Scan Options</h3>
      <div class="form-group">
        <label for="concurrency">Concurrent Pages</label>
        <input type="range" id="concurrency" name="concurrency"
               min="1" max="{{maxConcurrency}}" value="{{defaultConcurrency}}"
               aria-describedby="concurrency-hint"
               oninput="document.getElementById('concurrency-value').textContent = this.value">
        <output id="concurrency-value" for="concurrency" aria-live="polite" class="text-sm text-muted">{{defaultConcurrency}}</output>
        <p id="concurrency-hint" class="form-hint">
          Number of pages scanned simultaneously (1–{{maxConcurrency}}).
        </p>
      </div>
    </div>

    <div class="page-actions">
      <button type="submit" class="btn btn--primary">Start Scan</button>
      <a href="/home" class="btn btn--ghost">Cancel</a>
    </div>
  </form>
</section>
