# Environment variables expected by the docker-compose templates in this dir.
# Copy to `.env` next to the compose file you want to use, fill in real values,
# then `docker compose -f docker-compose.<minimal|standard|full>.yml --env-file .env up -d`.
#
# The installer (install.sh / install.ps1) generates this file automatically
# when run in --mode docker. This template is for users who skip the
# installer and wire compose by hand.

# REQUIRED — long random string (≥32 bytes) used to sign dashboard cookies.
# Generate with: openssl rand -hex 32
DASHBOARD_SESSION_SECRET=
